<Window x:Class="MotorBike.Views.UserPermissionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MotorBike.ViewModels"
        mc:Ignorable="d"
        Title="صلاحيات المستخدم" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft" FontFamily="Segoe UI" FontSize="14"
        Background="#F3F4F6">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{Binding UserName, StringFormat='تعديل صلاحيات المستخدم: {0}'}" 
                       FontSize="20" FontWeight="Bold" Foreground="#1F2937"/>
            <TextBlock Text="حدد الصلاحيات المتاحة لكل شاشة من شاشات النظام." 
                       FontSize="14" Foreground="#6B7280" Margin="0,4,0,0"/>
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Button Content="تحديد الكل" Command="{Binding SelectAllCommand}" 
                        Padding="10,5" Margin="0,0,10,0" Background="#E5E7EB"/>
                <Button Content="إلغاء التحديد" Command="{Binding DeselectAllCommand}" 
                        Padding="10,5" Background="#E5E7EB"/>
            </StackPanel>
        </StackPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Permissions}" 
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  Background="White" RowHeight="35" AlternatingRowBackground="#F9FAFB"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E5E7EB">
            <DataGrid.Columns>
                <DataGridTextColumn Header="الشاشة" Binding="{Binding ScreenName}" Width="*" IsReadOnly="True"/>
                <DataGridCheckBoxColumn Header="عرض" Binding="{Binding CanView, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                <DataGridCheckBoxColumn Header="إضافة" Binding="{Binding CanAdd, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                <DataGridCheckBoxColumn Header="تعديل" Binding="{Binding CanEdit, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                <DataGridCheckBoxColumn Header="حذف" Binding="{Binding CanDelete, UpdateSourceTrigger=PropertyChanged}" Width="80"/>

            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="إلغاء" Click="Cancel_Click" 
                    Width="100" Height="36" Margin="0,0,10,0"
                    Background="White" Foreground="#374151" BorderBrush="#D1D5DB"/>
            <Button Content="حفظ الصلاحيات" Command="{Binding SaveCommand}" 
                    Width="120" Height="36" 
                    Background="#2563EB" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
