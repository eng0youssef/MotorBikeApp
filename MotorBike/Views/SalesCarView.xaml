<UserControl x:Class="MotorBike.Views.SalesCarView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:conv="clr-namespace:MotorBike.Converters" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" FlowDirection="RightToLeft" Loaded="OnLoaded"
             mc:Ignorable="d">

    <UserControl.Resources>
        <conv:HideZeroConverter x:Key="HideZeroConv" />
        <conv:IdToNameConverter x:Key="IdToNameConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />

        <Style x:Key="FormCard" TargetType="Border">
            <Setter Property="Background" Value="#272C3F" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#3D4560" />
            <Setter Property="Margin" Value="20" />
            <Setter Property="Padding" Value="28" />
        </Style>

        <Style x:Key="FormContainerStyle" TargetType="Grid">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="False">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <!--  Dark Column Header  -->
        <Style x:Key="DarkColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2A3040" />
            <Setter Property="Foreground" Value="#9BA4B5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="BorderBrush" Value="#3D4560" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style x:Key="FloatingLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="#7B84A0" />
            <Setter Property="Margin" Value="4,-14,0,0" />
        </Style>
        <!--  Dark Row  -->
        <Style x:Key="DarkRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#C8CEE0" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#323F58" />
                    <Setter Property="Foreground" Value="#E8A54B" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A3040" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  Dark Cell  -->
        <Style x:Key="DarkCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Foreground" Value="#C8CEE0" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="#E8A54B" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SearchContainerStyle" TargetType="Grid">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!--  Popup list-item button — full-width, no chrome  -->
        <Style x:Key="PopupItemButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="LightGray" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#2F3549">

        <!--  ════════════════════════════════════════════════════════════════  -->
        <!--  FORM SECTION  -->
        <!--  ════════════════════════════════════════════════════════════════  -->
        <Grid Style="{StaticResource FormContainerStyle}">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" ScrollChanged="ScrollViewer_ScrollChanged" VerticalScrollBarVisibility="Auto">
                <Border Style="{StaticResource FormCard}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="24" Direction="270" Opacity="0.04" ShadowDepth="4" Color="#0F172A" />
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <!--  Header  -->
                            <RowDefinition Height="Auto" />
                            <!--  Separator  -->
                            <RowDefinition Height="Auto" />
                            <!--  Main Info  -->
                            <RowDefinition Height="Auto" />
                            <!--  Treasury Selection  -->
                            <RowDefinition Height="Auto" />
                            <!--  Tax Section  -->
                            <RowDefinition Height="Auto" />
                            <!--  Payments  -->
                            <RowDefinition Height="Auto" />
                            <!--  Actions  -->
                        </Grid.RowDefinitions>

                        <!--  ── Header ───────────────────────────────────────  -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Border Margin="0,0,16,0" Padding="14,12" CornerRadius="12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Offset="0" Color="#E8A54B" />
                                            <GradientStop Offset="1" Color="#D4922F" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="26" Text="🏍️" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock FontSize="22" FontWeight="Bold" Foreground="White" Text="فاتورة بيع موتوسيكل" />
                                    <TextBlock Margin="0,4,0,0" FontSize="14" Foreground="#64748B" Text="سجل فاتورة بيع موتوسيكل جديدة أو استعلم عن فواتير سابقة" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                                <Button Margin="0,0,12,0" Padding="16,10"
                                        Command="{Binding ShowSearchPanelCommand}"
                                        Content="🔍 بحث عن فاتورة سابقة"
                                        Style="{StaticResource SecondaryButton}" />
                                <Button Padding="16,10" Command="{Binding AddNewCommand}" Content="➕ تـسـجيـل فاتورة جـديـدة" Style="{StaticResource PrimaryButton}" />
                            </StackPanel>
                        </Grid>

                        <Rectangle Grid.Row="1" Height="1" Margin="0,8,0,24" Fill="#E2E8F0" />

                        <!--  ── Main Info Grid ────────────────────────────────  -->
                        <Grid Grid.Row="2" Margin="0,0,0,24" IsEnabled="{Binding IsEditing}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="20" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="20" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Row 0 : Invoice ID | Date | Customer search  -->
                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="رقم الفاتورة" />
                            <TextBox Grid.Row="0" Grid.Column="1" Background="#F8FAFC" FontWeight="Bold" IsReadOnly="True"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding FormItem.SalesId, Converter={StaticResource HideZeroConv}}" />

                            <TextBlock Grid.Row="0" Grid.Column="3" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="التاريخ" />
                            <DatePicker Grid.Row="0" Grid.Column="4" Padding="10,4" FontSize="14"
                                        SelectedDate="{Binding FormItem.SalesDate}" />

                            <!--  Customer searchable field  -->
                            <TextBlock Grid.Row="0" Grid.Column="6" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="العميل" />
                            <StackPanel Grid.Row="0" Grid.Column="7" VerticalAlignment="Center">
                                <Grid>
                                    <TextBox x:Name="CustomerSearchBox" Padding="8,6" GotFocus="CustomerSearch_GotFocus"
                                             Style="{StaticResource FormTextBox}"
                                             Text="{Binding CustomerSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="ابحث عن العميل بالاسم" />
                                    <Popup x:Name="CustomerSearchPopup"
                                           Width="{Binding ActualWidth, ElementName=CustomerSearchBox}"
                                           AllowsTransparency="True"
                                           IsOpen="{Binding IsCustomerPopupOpen}"
                                           Placement="Bottom"
                                           PlacementTarget="{Binding ElementName=CustomerSearchBox}"
                                           StaysOpen="False">
                                        <Border MaxHeight="250" Background="#2F3549" BorderBrush="#4A5270" BorderThickness="1" CornerRadius="10">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="16" Direction="270" Opacity="0.2" ShadowDepth="4" Color="#000000" />
                                            </Border.Effect>
                                            <ListBox Background="Transparent" BorderThickness="0" ItemsSource="{Binding FilteredCustomersList}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="10,8" Cursor="Hand">
                                                            <TextBlock FontSize="13" Foreground="#C8CEE0">
                                                                <Run Text="{Binding CusName, Mode=OneWay}" />
                                                            </TextBlock>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                        <Setter Property="Padding" Value="0" />
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <EventSetter Event="PreviewMouseLeftButtonDown" Handler="SearchCustomer_Click" />
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#323F58" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>
                                <TextBlock Margin="0,4,0,0" FontSize="12" FontWeight="SemiBold" Foreground="#E8A54B"
                                           Text="{Binding CurrentCustomerBalance, StringFormat='الرصيد الحالي: {0:N2}'}" />
                            </StackPanel>

                            <!--  Row 2 : Car search | Mileage | Total  -->
                            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="الموتوسيكل" />
                            <StackPanel Grid.Row="2" Grid.Column="1" VerticalAlignment="Center">
                                <Grid>
                                    <TextBox x:Name="CarSearchBox" Padding="8,6" GotFocus="CarSearch_GotFocus"
                                             Style="{StaticResource FormTextBox}"
                                             Text="{Binding CarSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="ابحث عن الموتوسيكل بالشاسيه أو اللوحة" />
                                    <Popup x:Name="CarSearchPopup"
                                           Width="{Binding ActualWidth, ElementName=CarSearchBox}"
                                           AllowsTransparency="True"
                                           IsOpen="{Binding IsCarPopupOpen}"
                                           Placement="Bottom"
                                           PlacementTarget="{Binding ElementName=CarSearchBox}"
                                           StaysOpen="False">
                                        <Border MaxHeight="250" Background="#2F3549" BorderBrush="#4A5270" BorderThickness="1" CornerRadius="10">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="16" Direction="270" Opacity="0.2" ShadowDepth="4" Color="#000000" />
                                            </Border.Effect>
                                            <ListBox Background="Transparent" BorderThickness="0" ItemsSource="{Binding FilteredCarsList}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="10,8" Cursor="Hand">
                                                            <StackPanel>
                                                                <TextBlock FontSize="13" Foreground="#C8CEE0">
                                                                    <Run Text="{Binding ChassisNo, StringFormat='شاسيه: {0}', Mode=OneWay}" />
                                                                </TextBlock>
                                                                <TextBlock Margin="0,2,0,0" FontSize="11" Foreground="#9BA4B5">
                                                                    <TextBlock.Text>
                                                                        <MultiBinding StringFormat="{}لوحة: {0}  |  موتور: {1}">
                                                                            <Binding Path="PlateNo" />
                                                                            <Binding Path="MotorNo" />
                                                                        </MultiBinding>
                                                                    </TextBlock.Text>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                        <Setter Property="Padding" Value="0" />
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <EventSetter Event="PreviewMouseLeftButtonDown" Handler="SearchCar_Click" />
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#323F58" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </StackPanel>

                            <TextBlock Grid.Row="2" Grid.Column="3" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="كيلومتر" />
                            <Grid Grid.Row="2" Grid.Column="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Style="{StaticResource FormTextBox}" Text="{Binding FormItem.Mileage, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Column="1" Margin="10,0,10,0" VerticalAlignment="Center" Style="{StaticResource FormLabel}" Text="CC" />
                                <TextBox Grid.Column="2" Background="#F8FAFC" FontWeight="Bold" IsReadOnly="True"
                                         Style="{StaticResource FormTextBox}"
                                         Text="{Binding SelectedCarCC, Mode=OneWay, StringFormat={}{0} سم3, TargetNullValue=''}" />
                            </Grid>

                            <TextBlock Grid.Row="2" Grid.Column="6" VerticalAlignment="Center" FontWeight="Bold"
                                       Style="{StaticResource FormLabel}"
                                       Text="السعر" />
                            <TextBox Grid.Row="2" Grid.Column="7" FontSize="16" FontWeight="Bold" Foreground="#059669"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding FormTotal, UpdateSourceTrigger=PropertyChanged}" />

                            <!--  Row 4 : Notes & Cash Toggle  -->
                            <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="ملاحظات" />
                            <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="4"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding FormItem.Notes, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="4" Grid.Column="6" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="طريقة السداد" />
                            <ToggleButton Grid.Row="4" Grid.Column="7" Height="38" HorizontalAlignment="Stretch" VerticalAlignment="Center" Checked="IsCash_Changed" Cursor="Hand"
                                          IsChecked="{Binding FormItem.IsCash, UpdateSourceTrigger=PropertyChanged}"
                                          Unchecked="IsCash_Changed">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="TrackBorder" Height="38" Background="#2F3549" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="19">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border x:Name="SliderHighlight" Grid.Column="1" Margin="3" Background="#5BAE7C" CornerRadius="16">
                                                    <Border.RenderTransform>
                                                        <TranslateTransform x:Name="SliderTranslate" X="0" />
                                                    </Border.RenderTransform>
                                                </Border>
                                                <TextBlock x:Name="LabelRight" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="White" Text="أجل" />
                                                <TextBlock x:Name="LabelLeft" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="White" Text="كاش" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="False">
                                                <Setter TargetName="SliderHighlight" Property="Grid.Column" Value="0" />
                                                <Setter TargetName="SliderHighlight" Property="Background" Value="#E8A54B" />
                                                <Setter TargetName="LabelRight" Property="Foreground" Value="White" />
                                                <Setter TargetName="LabelLeft" Property="Foreground" Value="White" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TrackBorder" Property="BorderBrush" Value="#E8A54B" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                        </Grid>

                        <!--  ── Cash Mode Treasury ──────────────────────────  -->
                        <Border Grid.Row="4" Margin="0,0,0,24" Padding="22" Background="#283830" BorderBrush="#3D7A5A" BorderThickness="1" CornerRadius="12"
                                IsEnabled="{Binding IsEditing}"
                                Visibility="{Binding IsCashPaymentMode, Converter={StaticResource BoolToVis}}">
                            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                <TextBlock Margin="0,0,16,0" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="#5BAE7C" Text="💳 اختر الخزينة (كاش):" />
                                <ComboBox MinWidth="250" BorderBrush="#5BAE7C" DisplayMemberPath="CashName" FontSize="14" FontWeight="SemiBold"
                                          ItemsSource="{Binding Cashes}"
                                          SelectedValue="{Binding SelectedCashId, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="CashId" />
                                <TextBlock Margin="16,0,0,0" VerticalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="#047857"
                                           Text="{Binding CurrentSafeBalance, StringFormat='رصيد الخزينة: {0:N2}'}" />
                            </StackPanel>
                        </Border>

                        <!--  ── Tax Section ────────────────────────────────  -->
                        <Border Grid.Row="3" Margin="0,0,0,24" Padding="16,12" Background="#2F3549" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="10"
                                IsEnabled="{Binding IsEditing}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0" VerticalAlignment="Center" Content="فاتورة ضريبية" FontSize="14" FontWeight="SemiBold" Foreground="#1D4ED8"
                                          IsChecked="{Binding FormIsTax, UpdateSourceTrigger=PropertyChanged}" />

                                <Grid Grid.Column="2" Visibility="{Binding FormIsTax, Converter={StaticResource BoolToVis}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!--  Net Before Tax  -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" Foreground="#94A3B8" Text="اجمالي الفاتورة" />
                                    <TextBox Grid.Row="0" Grid.Column="2" MinWidth="160" HorizontalContentAlignment="Center" Background="#FFF9C4" FontSize="14" FontWeight="Bold" IsReadOnly="True"
                                             Style="{StaticResource FormTextBox}"
                                             Text="{Binding NetBeforeTax, Mode=OneWay, StringFormat=\{0:N2\}}" />

                                    <!--  VAT  -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" Foreground="#94A3B8" Text="ض القيمة المضافة" />
                                    <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal">
                                        <TextBox MinWidth="60" HorizontalContentAlignment="Center" FontSize="13"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding VatTaxPercent, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox MinWidth="90" Margin="8,0,0,0" HorizontalContentAlignment="Center" Background="#FFF9C4" FontSize="13" FontWeight="SemiBold" IsReadOnly="True"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding FormItem.VatTax, Mode=OneWay, StringFormat=\{0:N2\}}" />
                                    </StackPanel>

                                    <!--  WHT  -->
                                    <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" Foreground="#94A3B8" Text="ضريبة أ.ت.ص" />
                                    <StackPanel Grid.Row="4" Grid.Column="2" Orientation="Horizontal">
                                        <TextBox MinWidth="60" HorizontalContentAlignment="Center" FontSize="13"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding WhtTaxPercent, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox MinWidth="90" Margin="8,0,0,0" HorizontalContentAlignment="Center" Background="#FFF9C4" FontSize="13" FontWeight="SemiBold" IsReadOnly="True"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding FormItem.Tax, Mode=OneWay, StringFormat=\{0:N2\}}" />
                                    </StackPanel>

                                    <!--  Net After Tax  -->
                                    <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" Foreground="#059669" Text="الصافي بعد الضريبة" />
                                    <TextBox Grid.Row="6" Grid.Column="2" MinWidth="160" HorizontalContentAlignment="Center" Background="#ECFDF5" FontSize="15" FontWeight="Bold" Foreground="#059669"
                                             IsReadOnly="True"
                                             Style="{StaticResource FormTextBox}"
                                             Text="{Binding FormItem.Net, Mode=OneWay, StringFormat=\{0:N2\}}" />
                                </Grid>
                            </Grid>
                        </Border>

                        <!--  ── Payments Section ─────────────────────────────  -->
                        <!--  ══════ PAYMENTS SECTION (TRIGGER) ══════  -->
                        <Border Grid.Row="4" Margin="0,0,0,24" Padding="18" Background="#272C3F" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="12"
                                IsEnabled="{Binding IsEditing}"
                                Visibility="{Binding IsCashPaymentMode, Converter={StaticResource InverseBoolToVis}}">
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                <TextBlock Margin="0,0,16,0" VerticalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="#ECEEF5" Text="💰 المدفوعات وتفاصيل السداد" />
                                <Button Padding="24,12" Command="{Binding OpenPaymentsPopupCommand}" Content="إدارة المدفوعات 💰" Style="{StaticResource PrimaryButton}" />
                                <StackPanel Margin="24,0,0,0" VerticalAlignment="Center" Orientation="Horizontal">
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#7B84A0" Text="إجمالي المدفوع: " />
                                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#5BAE7C" Text="{Binding TotalPayed, StringFormat=\{0:N2\}}" />
                                    <TextBlock Margin="16,0,0,0" FontSize="13" FontWeight="SemiBold" Foreground="#7B84A0" Text="الباقي: " />
                                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#D9534F" Text="{Binding Remaining, StringFormat=\{0:N2\}}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!--  ── Footer Action Buttons ────────────────────────  -->
                        <DockPanel Grid.Row="6">
                            <TextBlock MaxWidth="300" Margin="0,0,16,0" HorizontalAlignment="Right" VerticalAlignment="Center" DockPanel.Dock="Right" FontSize="14" FontWeight="SemiBold" Foreground="#10B981"
                                       Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap" />

                            <WrapPanel MinHeight="45" HorizontalAlignment="Left" Orientation="Horizontal">

                                <Button Margin="0,0,12,12" Padding="16,10" Command="{Binding PrintInvoiceCommand}" Content="🖨️ طباعة الفاتورة">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource SecondaryButton}" TargetType="Button">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Setter Property="Background" Value="#3B82F6" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedInvoice}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Margin="0,0,12,12" Padding="16,10" Command="{Binding EditSelectedCommand}" Content="✏️ تـعـديـل الفاتورة">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource SecondaryButton}" TargetType="Button">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Setter Property="Background" Value="#F59E0B" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedInvoice}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Margin="0,0,12,12" Padding="16,10" Command="{Binding SaveCommand}" Content="💾 حـفـظ الفاتورة">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource PrimaryButton}" TargetType="Button">
                                            <Setter Property="Background" Value="#10B981" />
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Margin="0,0,16,12" Padding="16,10" Command="{Binding CancelEditCommand}" Content="✖ إلـغـاء">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource SecondaryButton}" TargetType="Button">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Margin="0,0,0,12" Padding="16,10" Command="{Binding DeleteCommand}" Content="🗑️ حـذف">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource DangerButton}" TargetType="Button">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedInvoice}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </WrapPanel>
                        </DockPanel>
                    </Grid>
                </Border>
            </ScrollViewer>
        </Grid>

        <!--  ════════════════════════════════════════════════════════════════  -->
        <!--  SEARCH SECTION  -->
        <!--  ════════════════════════════════════════════════════════════════  -->
        <Grid Margin="24" Style="{StaticResource SearchContainerStyle}">
            <Border Padding="24" Background="#272C3F" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="14">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" Direction="270" Opacity="0.04" ShadowDepth="4" Color="#0F172A" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,24">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <Border Margin="0,0,12,0" Padding="10" CornerRadius="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Offset="0" Color="#E8A54B" />
                                        <GradientStop Offset="1" Color="#D4922F" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock FontSize="20" Text="🔎" />
                            </Border>
                            <TextBlock VerticalAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="White" Text="البحث في فواتير بيع الموتوسيكل" />
                        </StackPanel>
                        <Button Padding="16,8" HorizontalAlignment="Right"
                                Command="{Binding HideSearchPanelCommand}"
                                Content="✖ الـرجـوع للـنمـوذج" DockPanel.Dock="Right"
                                Style="{StaticResource SecondaryButton}" />
                    </DockPanel>

                    <Border Grid.Row="1" Margin="0,0,0,20" Padding="16"
                            Background="{StaticResource SectionBg}"
                            BorderBrush="{StaticResource SectionBorder}"
                            BorderThickness="1" CornerRadius="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="White" Text="كلمة البحث (رقم الفاتورة، اسم العميل):" />
                            <TextBox Grid.Column="1" MinWidth="200" MaxWidth="460" Padding="12,8" HorizontalAlignment="Left" Background="LightGray" FontSize="15"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Background="#242940" BorderBrush="#3D4560" BorderThickness="1" ClipToBounds="True" CornerRadius="12">
                        <DataGrid AlternatingRowBackground="#222738" AutoGenerateColumns="False" Background="#242940" BorderThickness="0" CanUserAddRows="False" ColumnHeaderHeight="50" FontSize="13" Foreground="#C8CEE0"
                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column" HorizontalGridLinesBrush="#323848" IsReadOnly="True"
                                  ItemsSource="{Binding FilteredInvoices}"
                                  RowHeight="46"
                                  SelectedItem="{Binding SelectedInvoice, Mode=TwoWay}"
                                  SelectionMode="Single">
                            <DataGrid.ColumnHeaderStyle>
                                <Style BasedOn="{StaticResource DarkColumnHeader}" TargetType="DataGridColumnHeader" />
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style BasedOn="{StaticResource DarkRow}" TargetType="DataGridRow" />
                            </DataGrid.RowStyle>
                            <DataGrid.CellStyle>
                                <Style BasedOn="{StaticResource DarkCell}" TargetType="DataGridCell" />
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Margin="8,6" Padding="4" Background="#10B981"
                                                    Command="{Binding DataContext.HideSearchPanelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    Content="✅ اختيار" FontSize="12" Foreground="White"
                                                    Style="{StaticResource PrimaryButton}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="100" Binding="{Binding SalesId}" Header="رقم الفاتورة" />
                                <DataGridTextColumn Width="100" Binding="{Binding SalesDate, StringFormat=\{0:yyyy/MM/dd\}}" Header="التاريخ" />
                                <DataGridTemplateColumn Width="200" Header="العميل">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Padding="4,0" VerticalAlignment="Center">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="CusId,CusName">
                                                        <Binding Path="CusId" />
                                                        <Binding Path="DataContext.Customers" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="150" Binding="{Binding Net, StringFormat=\{0:N2\}}" Header="الإجمالي" />
                                <DataGridTextColumn Width="120" Binding="{Binding PaidAmount, StringFormat=\{0:N2\}}" Header="المدفوع" Foreground="#10B981" FontWeight="SemiBold" />
                                <DataGridTextColumn Width="120" Binding="{Binding RemainingAmount, StringFormat=\{0:N2\}}" Header="الباقي" Foreground="#EF4444" FontWeight="SemiBold" />
                                <DataGridTextColumn Width="*" Binding="{Binding Notes}" Header="الملاحظات" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        <!--  ████████ PAYMENTS POPUP OVERLAY ████████  -->
        <!--  ████████ PAYMENTS POPUP OVERLAY ████████  -->
        <Grid Panel.ZIndex="100" Background="#B20F172A" Visibility="{Binding IsPaymentsPopupOpen, Converter={StaticResource BoolToVis}}">
            <Border Width="850" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#1E2233" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="32" Direction="270" Opacity="0.3" ShadowDepth="12" Color="#000000" />
                </Border.Effect>
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Header  -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock VerticalAlignment="Center" DockPanel.Dock="Left" FontSize="20" FontWeight="Bold" Foreground="#ECEEF5" Text="💰 المدفوعات" />
                        <Button HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0"
                                Command="{Binding ClosePaymentsPopupCommand}"
                                Content="✖" Cursor="Hand" DockPanel.Dock="Right" FontSize="20" FontWeight="Bold" Foreground="#7B84A0" ToolTip="إغلاق" />
                    </DockPanel>

                    <!--  Quick Add Payment  -->
                    <Border Grid.Row="1" Margin="0,0,0,14" Padding="14" Background="#2F3549" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="100" />
                                <ColumnDefinition Width="*" MinWidth="80" />
                                <ColumnDefinition Width="*" MinWidth="200" />
                                <ColumnDefinition Width="2*" MinWidth="100" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Style="{StaticResource FormLabel}" Text="التاريخ" />
                                <DatePicker IsEnabled="False" SelectedDate="{Binding CurrentPayment.PayDate, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Style="{StaticResource FormLabel}" Text="المبلغ" />
                                <TextBox Style="{StaticResource FormTextBox}" Text="{Binding CurrentPayment.PayMoney, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Grid.Column="2" Margin="0,0,10,0">
                                <TextBlock Style="{StaticResource FormLabel}" Text="الخزينة" />
                                <StackPanel>
                                    <ComboBox DisplayMemberPath="CashName" ItemsSource="{Binding Cashes}" SelectedValue="{Binding SelectedCashId, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="CashId" />
                                    <TextBlock Margin="0,4,0,0" FontSize="12" FontWeight="SemiBold" Foreground="#047857"
                                               Text="{Binding CurrentSafeBalance, StringFormat='رصيد الخزينة: {0:N2}'}" />
                                </StackPanel>
                            </Grid>
                            <Grid Grid.Column="3" Margin="0,0,10,0">
                                <TextBlock Style="{StaticResource FormLabel}" Text="ملاحظات" />
                                <TextBox Style="{StaticResource FormTextBox}" Text="{Binding CurrentPayment.Notes, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Button Grid.Column="4" Padding="16,10"
                                    Command="{Binding AddPaymentCommand}"
                                    Content="➕ إضافة"
                                    Style="{StaticResource SuccessButton}" />
                        </Grid>
                    </Border>

                    <!--  Payments DataGrid  -->
                    <Border Grid.Row="2" MinHeight="150" MaxHeight="300" Background="#242940" BorderBrush="#3D4560" BorderThickness="1" ClipToBounds="True" CornerRadius="10">
                        <DataGrid AlternatingRowBackground="#222738" AutoGenerateColumns="False" Background="#242940" BorderThickness="0" CanUserAddRows="False" ColumnHeaderHeight="40" FontSize="13" Foreground="#C8CEE0"
                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column" HorizontalGridLinesBrush="#323848" IsReadOnly="False"
                                  ItemsSource="{Binding FormPayments}"
                                  RowHeight="36" SelectionMode="Single">
                            <DataGrid.ColumnHeaderStyle>
                                <Style BasedOn="{StaticResource DarkColumnHeader}" TargetType="DataGridColumnHeader" />
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style BasedOn="{StaticResource DarkRow}" TargetType="DataGridRow" />
                            </DataGrid.RowStyle>
                            <DataGrid.CellStyle>
                                <Style BasedOn="{StaticResource DarkCell}" TargetType="DataGridCell" />
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="120" Binding="{Binding PayDate, StringFormat=\{0:yyyy/MM/dd\}}" Header="التاريخ" IsReadOnly="True" />
                                <DataGridTextColumn Width="120"
                                                    Binding="{Binding PayMoney, StringFormat=\{0:N2\}}"
                                                    FontWeight="SemiBold" Foreground="#5BAE7C" Header="المبلغ" />
                                <DataGridTemplateColumn Width="*" Header="الخزينة">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Padding="4,0" VerticalAlignment="Center">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="CashId,CashName">
                                                        <Binding Path="CashId" />
                                                        <Binding Path="DataContext.Cashes" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <ComboBox DisplayMemberPath="CashName" IsDropDownOpen="True"
                                                      ItemsSource="{Binding DataContext.Cashes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      SelectedValue="{Binding CashId, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="CashId" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="*" Binding="{Binding Notes}" Header="ملاحظات" />
                                <DataGridTemplateColumn Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Background="Transparent" BorderThickness="0"
                                                    Command="{Binding DataContext.RemovePaymentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Content="🗑️" Cursor="Hand" FontSize="14" Foreground="#D9534F" ToolTip="حذف الدفعة" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!--  Payment Totals  -->
                    <StackPanel Grid.Row="3" Margin="0,14,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
                        <Border Margin="0,0,24,0" Padding="16,10" Background="#283830" BorderBrush="#3D7A5A" BorderThickness="1" CornerRadius="8">
                            <StackPanel>
                                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#7B84A0" Text="إجمالي المدفوع" />
                                <TextBlock FontSize="18" FontWeight="Bold" Foreground="#5BAE7C" Text="{Binding TotalPayed, StringFormat=\{0:N2\}}" />
                            </StackPanel>
                        </Border>
                        <Border Padding="16,10" Background="#3A2828" BorderBrush="#7A3D3D" BorderThickness="1" CornerRadius="8">
                            <StackPanel>
                                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#7B84A0" Text="الباقي" />
                                <TextBlock FontSize="18" FontWeight="Bold" Foreground="#D9534F" Text="{Binding Remaining, StringFormat=\{0:N2\}}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>