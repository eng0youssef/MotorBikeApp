<UserControl x:Class="MotorBike.Views.ReportsDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1000"
             FlowDirection="RightToLeft">

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.0" To="1.0" Duration="0:0:0.5" />
                    <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,30,0,-30" To="0" Duration="0:0:0.5">
                        <ThicknessAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <UserControl.Resources>
        <Style x:Key="CategoryHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="Margin" Value="0,20,0,15" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="IconBorderStyle" TargetType="Border">
            <Setter Property="Width" Value="64" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Height" Value="64" />
            <Setter Property="CornerRadius" Value="32" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="IconTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="30" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="TitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer MinWidth="600" MinHeight="400" Background="#272C3F" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40">

            <!-- Header section -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="التقارير والإحصائيات" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,0,0,8" />
                <TextBlock Text="استعراض كافة تقارير وحركات النظام والطباعة والتصدير بتنسيقات مختلفة." FontSize="16" Foreground="LightGray" />
            </StackPanel>   

            <!-- تقارير النظام الأساسية -->
            <StackPanel Margin="0,10,0,10" Orientation="Horizontal">
                <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" FontSize="20" Foreground="White" Text="📊" />
                <TextBlock Margin="0" Foreground="White" Style="{StaticResource CategoryHeaderStyle}" Text="التقارير الأساسية" />
            </StackPanel>

            <WrapPanel Margin="0,0,0,30">
                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="StoreReports"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="📦" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="تقارير المخازن" />
                    </StackPanel>
                </Button>

                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="SalesReports"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="📈" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="تقارير المبيعات" />
                    </StackPanel>
                </Button>

                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="PurchasesReports"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="🛒" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="تقارير المشتريات" />
                    </StackPanel>
                </Button>

                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="CashReports"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="💵" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="تقارير الخزينة" />
                    </StackPanel>
                </Button>

                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="ProfitsReports"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="💰" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="تقارير الأرباح" />
                    </StackPanel>
                </Button>

                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="CarsReports"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="🏍️" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="تقارير الموتوسيكلات" />
                    </StackPanel>
                </Button>

                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="ImportReports"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="🌍" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="تقارير الاستيراد" />
                    </StackPanel>
                </Button>
            </WrapPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>