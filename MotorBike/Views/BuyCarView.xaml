<UserControl x:Class="MotorBike.Views.BuyCarView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:conv="clr-namespace:MotorBike.Converters" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" FlowDirection="RightToLeft" Loaded="OnLoaded"
             mc:Ignorable="d">

    <UserControl.Resources>
        <conv:HideZeroConverter x:Key="HideZeroConv" />
        <conv:IdToNameConverter x:Key="IdToNameConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="FormCard" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="Margin" Value="24" />
            <Setter Property="Padding" Value="32" />
        </Style>

        <!--  Car section divider label style  -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#7C3AED" />
        </Style>

        <Style x:Key="FormContainerStyle" TargetType="Grid">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="False">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SearchContainerStyle" TargetType="Grid">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F8FAFC" MinWidth="850" MinHeight="500">

        <!--  ════════════════════════════════════════════════════════════════  -->
        <!--  FORM SECTION  -->
        <!--  ════════════════════════════════════════════════════════════════  -->
        <Grid Style="{StaticResource FormContainerStyle}">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <Border Style="{StaticResource FormCard}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="24" Direction="270" Opacity="0.04" ShadowDepth="4" Color="#0F172A" />
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <!--  Header  -->
                            <RowDefinition Height="Auto" />
                            <!--  Separator  -->
                            <RowDefinition Height="Auto" />
                            <!--  Owner info  -->
                            <RowDefinition Height="Auto" />
                            <!--  Tax section  -->
                            <RowDefinition Height="Auto" />
                            <!--  Car divider  -->
                            <RowDefinition Height="Auto" />
                            <!--  Car info  -->
                            <RowDefinition Height="Auto" />
                            <!--  Payments  -->
                            <RowDefinition Height="Auto" />
                            <!--  Action buttons  -->
                        </Grid.RowDefinitions>

                        <!--  ── Header ───────────────────────────────────────  -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Border Margin="0,0,16,0" Padding="14,12" Background="#F5F3FF" CornerRadius="12">
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="26" Text="🏍️" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock FontSize="22" FontWeight="Bold" Foreground="#1E293B" Text="فاتورة شراء موتوسيكل" />
                                    <TextBlock Margin="0,4,0,0" FontSize="14" Foreground="#64748B" Text="سجل فاتورة شراء موتوسيكل جديدة أو استعلم عن فواتير سابقة" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                                <Button Margin="0,0,12,0" Padding="16,10"
                                        Command="{Binding ShowSearchPanelCommand}"
                                        Content="🔍 بحث عن فاتورة سابقة"
                                        Style="{StaticResource SecondaryButton}" />
                                <Button Padding="16,10" Command="{Binding AddNewCommand}" Content="➕ تـسـجيـل فاتورة جـديـدة" Style="{StaticResource PrimaryButton}" />
                            </StackPanel>
                        </Grid>

                        <!--  Separator  -->
                        <Rectangle Grid.Row="1" Height="1" Margin="0,8,0,24" Fill="#E2E8F0" />

                        <!--  ── Owner / Invoice info grid ────────────────────  -->
                        <Grid Grid.Row="2" Margin="0,0,0,24" IsEnabled="{Binding IsEditing}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <!--  Row 0 : Invoice ID | Date | Owner name  -->
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="20" />
                                <!--  Row 2 : Phone | National ID | Address  -->
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="20" />
                                <!--  Row 4 : Total | Mileage | (empty)  -->
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="20" />
                                <!--  Row 6 : Notes  -->
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Row 0 : Invoice ID, Date, Owner name  -->
                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="رقم الفاتورة" />
                            <TextBox Grid.Row="0" Grid.Column="1" Background="#F8FAFC" FontWeight="Bold" IsReadOnly="True"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding FormItem.BuyId, Converter={StaticResource HideZeroConv}}" />

                            <TextBlock Grid.Row="0" Grid.Column="3" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="التاريخ" />
                            <DatePicker Grid.Row="0" Grid.Column="4" Padding="10,4" FontSize="14"
                                        SelectedDate="{Binding FormItem.BuyDate}" />

                            <TextBlock Grid.Row="0" Grid.Column="6" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="اسم المالك" />
                            <TextBox Grid.Row="0" Grid.Column="7" Style="{StaticResource FormTextBox}" Text="{Binding FormItem.OwnerName, UpdateSourceTrigger=PropertyChanged}" />

                            <!--  Row 2 : Phone, National ID, Address  -->
                            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="التليفون" />
                            <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource FormTextBox}" Text="{Binding FormItem.OwnerTel, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="2" Grid.Column="3" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="الرقم القومي" />
                            <TextBox Grid.Row="2" Grid.Column="4" Style="{StaticResource FormTextBox}" Text="{Binding FormItem.OwnerKawmy, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="2" Grid.Column="6" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="العنوان" />
                            <TextBox Grid.Row="2" Grid.Column="7" Style="{StaticResource FormTextBox}" Text="{Binding FormItem.OwnerAdress, UpdateSourceTrigger=PropertyChanged}" />

                            <!--  Row 4 : Total, Mileage  -->
                            <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold"
                                       Style="{StaticResource FormLabel}"
                                       Text="السعر" />
                            <TextBox Grid.Row="4" Grid.Column="1" FontSize="16" FontWeight="Bold" Foreground="#7C3AED"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding FormTotal, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource HideZeroConv}}" />

                            <TextBlock Grid.Row="4" Grid.Column="3" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="كيلومتر" />
                            <TextBox Grid.Row="4" Grid.Column="4" Style="{StaticResource FormTextBox}" Text="{Binding FormItem.Mileage, UpdateSourceTrigger=PropertyChanged}" />

                            <!--  Row 6 : Notes  -->
                            <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="ملاحظات" />
                            <TextBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="7"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding FormItem.Notes, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <!--  ── Tax Section ────────────────────────────────  -->
                        <Border Grid.Row="3" Margin="0,0,0,16" Padding="16,12" Background="#F0F9FF" BorderBrush="#BFDBFE"
                                BorderThickness="1" CornerRadius="10" IsEnabled="{Binding IsEditing}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0" VerticalAlignment="Center" Content="فاتورة ضريبية"
                                          FontSize="14" FontWeight="SemiBold" Foreground="#1D4ED8"
                                          IsChecked="{Binding FormIsTax, UpdateSourceTrigger=PropertyChanged}" />

                                <Grid Grid.Column="2" Visibility="{Binding FormIsTax, Converter={StaticResource BoolToVis}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                               FontSize="13" FontWeight="Bold" Foreground="#1E293B" Text="اجمالي الفاتورة" />
                                    <TextBox Grid.Row="0" Grid.Column="2" MinWidth="160" HorizontalContentAlignment="Center"
                                             Background="#FFF9C4" FontSize="14" FontWeight="Bold" IsReadOnly="True"
                                             Style="{StaticResource FormTextBox}"
                                             Text="{Binding NetBeforeTax, Mode=OneWay, StringFormat=\{0:N2\}}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                                               FontSize="13" FontWeight="Bold" Foreground="#1E293B" Text="ض القيمة المضافة" />
                                    <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal">
                                        <TextBox MinWidth="60" HorizontalContentAlignment="Center" FontSize="13"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding VatTaxPercent, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox MinWidth="90" Margin="8,0,0,0" HorizontalContentAlignment="Center"
                                                 Background="#FFF9C4" FontSize="13" FontWeight="SemiBold" IsReadOnly="True"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding FormItem.VatTax, Mode=OneWay, StringFormat=\{0:N2\}}" />
                                    </StackPanel>

                                    <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"
                                               FontSize="13" FontWeight="Bold" Foreground="#1E293B" Text="ضريبة أ.ت.ص" />
                                    <StackPanel Grid.Row="4" Grid.Column="2" Orientation="Horizontal">
                                        <TextBox MinWidth="60" HorizontalContentAlignment="Center" FontSize="13"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding WhtTaxPercent, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox MinWidth="90" Margin="8,0,0,0" HorizontalContentAlignment="Center"
                                                 Background="#FFF9C4" FontSize="13" FontWeight="SemiBold" IsReadOnly="True"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding FormItem.Tax, Mode=OneWay, StringFormat=\{0:N2\}}" />
                                    </StackPanel>

                                    <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center"
                                               FontSize="13" FontWeight="Bold" Foreground="#059669" Text="الصافي بعد الضريبة" />
                                    <TextBox Grid.Row="6" Grid.Column="2" MinWidth="160" HorizontalContentAlignment="Center"
                                             Background="#ECFDF5" FontSize="15" FontWeight="Bold" Foreground="#059669"
                                             IsReadOnly="True" Style="{StaticResource FormTextBox}"
                                             Text="{Binding FormItem.Net, Mode=OneWay, StringFormat=\{0:N2\}}" />
                                </Grid>
                            </Grid>
                        </Border>

                        <!--  ── Car section divider ──────────────────────────  -->
                        <Border Grid.Row="4" Margin="0,0,0,16" Padding="16,10" Background="#F5F3FF" BorderBrush="#DDD6FE" BorderThickness="1" CornerRadius="10"
                                IsEnabled="{Binding IsEditing}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Margin="0,0,24,0" VerticalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="#6D28D9" Text="🏍️  بيانات الموتوسيكل" />

                                <!--  Car fields in 2 rows  -->
                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!--  Row 0: Model | Year | Color  -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="3*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="3*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource SectionLabel}" Text="الموديل" />
                                        <ComboBox Grid.Column="1" Padding="8,5" DisplayMemberPath="ModelName" FontSize="13"
                                                  ItemsSource="{Binding CarModels}"
                                                  SelectedValue="{Binding CarModelId}"
                                                  SelectedValuePath="ModelId" />

                                        <TextBlock Grid.Column="3" VerticalAlignment="Center" Style="{StaticResource SectionLabel}" Text="السنة" />
                                        <TextBox Grid.Column="4" FontSize="13" Style="{StaticResource FormTextBox}" Text="{Binding CarYearNo, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Column="6" VerticalAlignment="Center" Style="{StaticResource SectionLabel}" Text="اللون" />
                                        <ComboBox Grid.Column="7" Padding="8,5" DisplayMemberPath="ColorName" FontSize="13"
                                                  ItemsSource="{Binding Colors}"
                                                  SelectedValue="{Binding CarColorId}"
                                                  SelectedValuePath="ColorId" />

                                        <!--<CheckBox Grid.Column="8" HorizontalAlignment="Right" VerticalAlignment="Center" Content="نشط" FontSize="13" FontWeight="SemiBold" Foreground="#6D28D9"
                                                  IsChecked="{Binding CarActive}" />-->
                                    </Grid>

                                    <!--  Row 2: Chassis | Motor | Plate | Notes  -->
                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="1.5*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="2.5*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource SectionLabel}" Text="الشاسيه" />
                                        <TextBox Grid.Column="1" FontSize="13" Style="{StaticResource FormTextBox}" Text="{Binding CarChassisNo, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Column="3" VerticalAlignment="Center" Style="{StaticResource SectionLabel}" Text="الموتور" />
                                        <TextBox Grid.Column="4" FontSize="13" Style="{StaticResource FormTextBox}" Text="{Binding CarMotorNo, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Column="6" VerticalAlignment="Center" Style="{StaticResource SectionLabel}" Text="اللوحة" />
                                        <TextBox Grid.Column="7" FontSize="13" Style="{StaticResource FormTextBox}" Text="{Binding CarPlateNo, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Column="9" VerticalAlignment="Center" Style="{StaticResource SectionLabel}" Text="ملاحظات" />
                                        <TextBox Grid.Column="10" FontSize="13" Style="{StaticResource FormTextBox}" Text="{Binding CarNotes, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                        <!--  ── Payments Section ─────────────────────────────  -->
                        <Border Grid.Row="6" Margin="0,0,0,24" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12"
                                IsEnabled="{Binding IsEditing}">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,12" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Text="💰 المدفوعات" />

                                <!--  Payment input row  -->
                                <Border Margin="0,0,0,12" Padding="12" Background="#F1F5F9" CornerRadius="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.5*" />
                                            <ColumnDefinition Width="1.5*" />
                                            <ColumnDefinition Width="1.5*" />
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Grid Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Margin="2,-16,0,0" FontSize="11" Foreground="#64748B" Text="التاريخ" />
                                            <DatePicker Padding="8,4" Background="White" BorderBrush="#CBD5E1" BorderThickness="1"
                                                        SelectedDate="{Binding CurrentPayment.PayDate}" />
                                        </Grid>

                                        <Grid Grid.Column="1" Margin="0,0,12,0">
                                            <TextBlock Margin="2,-16,0,0" FontSize="11" Foreground="#64748B" Text="المبلغ" />
                                            <TextBox Style="{StaticResource FormTextBox}" Text="{Binding CurrentPayment.PayMoney, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>

                                        <Grid Grid.Column="2" Margin="0,0,12,0">
                                            <TextBlock Margin="2,-16,0,0" FontSize="11" Foreground="#64748B" Text="الخزينة" />
                                            <ComboBox Padding="8,6" Background="White" BorderBrush="#CBD5E1" BorderThickness="1" DisplayMemberPath="CashName"
                                                      ItemsSource="{Binding Cashes}"
                                                      SelectedValue="{Binding CurrentPayment.CashId}"
                                                      SelectedValuePath="CashId" />
                                        </Grid>

                                        <Grid Grid.Column="3" Margin="0,0,12,0">
                                            <TextBlock Margin="2,-16,0,0" FontSize="11" Foreground="#64748B" Text="ملاحظات" />
                                            <TextBox Style="{StaticResource FormTextBox}" Text="{Binding CurrentPayment.Notes, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>

                                        <Button Grid.Column="4" Padding="16,8" Background="#10B981"
                                                Command="{Binding AddPaymentCommand}"
                                                Content="➕ إضافة"
                                                Style="{StaticResource PrimaryButton}" />
                                    </Grid>
                                </Border>

                                <!--  Payments DataGrid  -->
                                <Border MinHeight="150" MaxHeight="250" BorderBrush="#E2E8F0" BorderThickness="1" ClipToBounds="True" CornerRadius="8">
                                    <DataGrid AlternatingRowBackground="#F8FAFC" AutoGenerateColumns="False" Background="White" BorderThickness="0" CanUserAddRows="False" ColumnHeaderHeight="40" FontSize="13" Foreground="#1E293B"
                                              GridLinesVisibility="Horizontal" HeadersVisibility="Column" HorizontalGridLinesBrush="#F1F5F9" IsReadOnly="True"
                                              ItemsSource="{Binding FormPayments}"
                                              RowHeight="36" SelectionMode="Single">
                                        <DataGrid.ColumnHeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#F1F5F9" />
                                                <Setter Property="Foreground" Value="#334155" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                <Setter Property="Padding" Value="10,6" />
                                                <Setter Property="BorderBrush" Value="#E2E8F0" />
                                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                            </Style>
                                        </DataGrid.ColumnHeaderStyle>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Width="120" Binding="{Binding PayDate, StringFormat=\{0:yyyy/MM/dd\}}" Header="التاريخ" />
                                            <DataGridTextColumn Width="120" Binding="{Binding PayMoney, StringFormat=\{0:N2\}}" FontWeight="SemiBold" Header="المبلغ" />
                                            <DataGridTemplateColumn Width="*" Header="الخزينة">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Padding="4,0" VerticalAlignment="Center">
                                                            <TextBlock.Text>
                                                                <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="CashId,CashName">
                                                                    <Binding Path="CashId" />
                                                                    <Binding Path="DataContext.Cashes" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Width="*" Binding="{Binding Notes}" Header="ملاحظات" />
                                            <DataGridTemplateColumn Width="60">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Background="Transparent" BorderThickness="0"
                                                                Command="{Binding DataContext.RemovePaymentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Content="🗑️" FontSize="14" Foreground="Red" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>

                                <!--  Payment totals  -->
                                <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                                    <StackPanel Margin="0,0,32,0">
                                        <TextBlock FontSize="12" Foreground="#64748B" Text="إجمالي المدفوع" />
                                        <TextBlock FontSize="18" FontWeight="Bold" Foreground="#10B981" Text="{Binding TotalPayed, StringFormat=\{0:N2\}}" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock FontSize="12" Foreground="#64748B" Text="الإجمالي الكلي" />
                                        <TextBlock FontSize="18" FontWeight="Bold" Foreground="#EF4444" Text="{Binding FormItem.Net, StringFormat=\{0:N2\}}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!--  ── Action Buttons ────────────────────────────────  -->
                        <DockPanel Grid.Row="7">
                            <TextBlock MaxWidth="300" Margin="0,0,16,0" HorizontalAlignment="Right" VerticalAlignment="Center" DockPanel.Dock="Right" FontSize="14" FontWeight="SemiBold" Foreground="#10B981"
                                       Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap" />

                            <StackPanel MinHeight="45" HorizontalAlignment="Left" Orientation="Horizontal">

                                <!--  Edit button — visible only when an invoice is selected and not editing  -->
                                <Button Margin="0,0,12,0" Padding="16,10" Command="{Binding EditSelectedCommand}" Content="✏️ تـعـديـل الفاتورة">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource SecondaryButton}" TargetType="Button">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Setter Property="Background" Value="#F59E0B" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedInvoice}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!--  Save button — visible only while editing  -->
                                <Button Margin="0,0,12,0" Padding="16,10" Command="{Binding SaveCommand}" Content="💾 حـفـظ الفاتورة">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource PrimaryButton}" TargetType="Button">
                                            <Setter Property="Background" Value="#10B981" />
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!--  Cancel button — visible only while editing  -->
                                <Button Margin="0,0,16,0" Padding="16,10" Command="{Binding CancelEditCommand}" Content="✖ إلـغـاء">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource SecondaryButton}" TargetType="Button">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!--  Delete button  -->
                                <Button Padding="16,10" Command="{Binding DeleteCommand}" Content="🗑️ حـذف">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource DangerButton}" TargetType="Button">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedInvoice}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </Grid>
                </Border>
            </ScrollViewer>
        </Grid>

        <!--  ════════════════════════════════════════════════════════════════  -->
        <!--  SEARCH SECTION  -->
        <!--  ════════════════════════════════════════════════════════════════  -->
        <Grid Margin="24" Style="{StaticResource SearchContainerStyle}">
            <Border Padding="32" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" Direction="270" Opacity="0.04" ShadowDepth="4" Color="#0F172A" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Search header  -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,24">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <Border Margin="0,0,12,0" Padding="10" Background="#F3F4F6" CornerRadius="8">
                                <TextBlock FontSize="20" Text="🔎" />
                            </Border>
                            <TextBlock VerticalAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Text="البحث في فواتير شراء الموتوسيكل" />
                        </StackPanel>
                        <Button Padding="16,8" HorizontalAlignment="Right"
                                Command="{Binding HideSearchPanelCommand}"
                                Content="✖ الـرجـوع للـنمـوذج" DockPanel.Dock="Right"
                                Style="{StaticResource SecondaryButton}" />
                    </DockPanel>

                    <!--  Search bar  -->
                    <Border Grid.Row="1" Margin="0,0,0,24" Padding="16" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569" Text="كلمة البحث (رقم الفاتورة، اسم المالك):" />
                            <TextBox Grid.Column="1" HorizontalAlignment="Stretch" Padding="12,8" Background="White" FontSize="15"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Border>

                    <!--  Search results  -->
                    <Border Grid.Row="2" BorderBrush="#E2E8F0" BorderThickness="1" ClipToBounds="True" CornerRadius="12">
                        <DataGrid AlternatingRowBackground="#F8FAFC" AutoGenerateColumns="False" Background="White" BorderThickness="0" CanUserAddRows="False" ColumnHeaderHeight="54" FontSize="14" Foreground="#1E293B"
                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column" HorizontalGridLinesBrush="#F1F5F9" IsReadOnly="True"
                                  ItemsSource="{Binding FilteredInvoices}"
                                  RowHeight="48"
                                  SelectedItem="{Binding SelectedInvoice, Mode=TwoWay}"
                                  SelectionMode="Single">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F1F5F9" />
                                    <Setter Property="Foreground" Value="#334155" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Padding" Value="16,12" />
                                    <Setter Property="BorderBrush" Value="#E2E8F0" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Cursor" Value="Hand" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#DBEAFE" />
                                            <Setter Property="Foreground" Value="#1D4ED8" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#EFF6FF" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Margin="8,6" Padding="4" Background="#10B981"
                                                    Command="{Binding DataContext.HideSearchPanelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    Content="✅ اختيار" FontSize="12" Foreground="White"
                                                    Style="{StaticResource PrimaryButton}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="100" Binding="{Binding BuyId}" Header="رقم الفاتورة" />
                                <DataGridTextColumn Width="100" Binding="{Binding BuyDate, StringFormat=\{0:yyyy/MM/dd\}}" Header="التاريخ" />
                                <DataGridTextColumn Width="200" Binding="{Binding OwnerName}" Header="المالك" />
                                <DataGridTextColumn Width="150" Binding="{Binding Net, StringFormat=\{0:N2\}}" Header="الإجمالي" />
                                <DataGridTextColumn Width="*" Binding="{Binding Notes}" Header="الملاحظات" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
