<UserControl x:Class="MotorBike.Views.BuyCarView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:conv="clr-namespace:MotorBike.Converters" xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" FlowDirection="RightToLeft" Loaded="OnLoaded" mc:Ignorable="d">

    <UserControl.Resources>
        <conv:HideZeroConverter x:Key="HideZeroConv" />
        <conv:InverseBoolConverter x:Key="InverseBool" />
        <conv:IdToNameConverter x:Key="IdToNameConverter" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="FormCard" TargetType="Border">
            <Setter Property="Background" Value="#272C3F" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#3D4560" />
            <Setter Property="Margin" Value="20" />
            <Setter Property="Padding" Value="28" />
        </Style>

        <Style x:Key="DarkColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2A3040" />
            <Setter Property="Foreground" Value="#9BA4B5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="BorderBrush" Value="#3D4560" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style x:Key="DarkRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#C8CEE0" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#323F58" />
                    <Setter Property="Foreground" Value="#E8A54B" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A3040" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FloatingLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="#7B84A0" />
            <Setter Property="Margin" Value="4,-14,0,0" />
        </Style>

        <Style x:Key="DarkCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Foreground" Value="#C8CEE0" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="#E8A54B" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FormContainerStyle" TargetType="Grid">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}"
                             Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}"
                             Value="False">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SearchContainerStyle" TargetType="Grid">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}"
                             Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}"
                             Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#E8A54B" />
        </Style>
    </UserControl.Resources>

    <Grid MinWidth="850" MinHeight="500" Background="#2F3549">

        <!--  ════════════════════════════════════════════════════════════════  -->
        <!--  FORM SECTION  -->
        <!--  ════════════════════════════════════════════════════════════════  -->
        <Grid Style="{StaticResource FormContainerStyle}">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <Border Style="{StaticResource FormCard}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="24" Direction="270" Opacity="0.04" ShadowDepth="4" Color="#0F172A" />
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <!--  0 Header  -->
                            <RowDefinition Height="Auto" />
                            <!--  1 Separator  -->
                            <RowDefinition Height="Auto" />
                            <!--  2 Owner info  -->
                            <RowDefinition Height="Auto" />
                            <!--  3 Tax section  -->
                            <RowDefinition Height="Auto" />
                            <!--  4 Source  -->
                            <RowDefinition Height="Auto" />
                            <!--  5 Car data  -->
                            <!--  6 Cash treasury  (visible when IsCashPaymentMode = True)  -->
                            <RowDefinition Height="Auto" />
                            <!--  7 Credit payments (visible when IsCashPaymentMode = False)  -->
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <!--  8 Action btns  -->
                        </Grid.RowDefinitions>

                        <!--  ── Header ────────────────────────────────────────  -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Border Margin="0,0,16,0" Padding="14,12" CornerRadius="12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Offset="0" Color="#E8A54B" />
                                            <GradientStop Offset="1" Color="#D4922F" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="26" Text="🏍️" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock FontSize="22" FontWeight="Bold" Foreground="White" Text="فاتورة شراء موتوسيكل" />
                                    <TextBlock Margin="0,4,0,0" FontSize="14" Foreground="#64748B" Text="سجل فاتورة شراء موتوسيكل جديدة أو استعلم عن فواتير سابقة" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                                <Button Margin="0,0,12,0" Padding="16,10"
                                        Command="{Binding ShowSearchPanelCommand}"
                                        Content="🔍 بحث عن فاتورة سابقة"
                                        Style="{StaticResource SecondaryButton}" />
                                <Button Padding="16,10"
                                        Command="{Binding AddNewCommand}"
                                        Content="➕ تـسـجيـل فاتورة جـديـدة"
                                        Style="{StaticResource PrimaryButton}" />
                            </StackPanel>
                        </Grid>

                        <!--  Separator  -->
                        <Rectangle Grid.Row="1" Height="1" Margin="0,8,0,24" Fill="#E2E8F0" />

                        <!--  ── Owner / Invoice info ───────────────────────────  -->
                        <Grid Grid.Row="2" Margin="0,0,0,24"
                              IsEnabled="{Binding IsEditing}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="20" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="20" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="50" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Row 0 : Invoice ID | Date | Owner name  -->
                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="رقم الفاتورة" />
                            <TextBox Grid.Row="0" Grid.Column="1" Background="#F8FAFC" FontWeight="Bold" IsReadOnly="True"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding FormItem.BuyId, Converter={StaticResource HideZeroConv}}" />

                            <TextBlock Grid.Row="0" Grid.Column="3" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="التاريخ" />
                            <DatePicker Grid.Row="0" Grid.Column="4" Padding="10,4" FontSize="14"
                                        SelectedDate="{Binding FormItem.BuyDate}" />

                            <TextBlock Grid.Row="0" Grid.Column="6" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="اسم المالك" />
                            <TextBox Grid.Row="0" Grid.Column="7"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding FormItem.OwnerName, UpdateSourceTrigger=PropertyChanged}" />

                            <!--  Row 2 : Phone | National ID | Address  -->
                            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="التليفون" />
                            <TextBox Grid.Row="2" Grid.Column="1"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding FormItem.OwnerTel, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="2" Grid.Column="3" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="الرقم القومي" />
                            <TextBox Grid.Row="2" Grid.Column="4"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding FormItem.OwnerKawmy, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="2" Grid.Column="6" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="العنوان" />
                            <TextBox Grid.Row="2" Grid.Column="7"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding FormItem.OwnerAdress, UpdateSourceTrigger=PropertyChanged}" />

                            <!--  Row 4 : Total | Mileage  -->
                            <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold"
                                       Style="{StaticResource FormLabel}"
                                       Text="السعر" />
                            <TextBox Grid.Row="4" Grid.Column="1" FontSize="16" FontWeight="Bold" Foreground="#7C3AED"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding FormTotal, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource HideZeroConv}}" />

                            <!--  Row 6 : Notes & Payment Toggle  -->
                            <TextBlock Grid.Row="4" Grid.Column="3" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="ملاحظات" />
                            <TextBox Grid.Row="4" Grid.Column="4" Grid.ColumnSpan="4"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding FormItem.Notes, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="5" Grid.Column="3" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="طريقة السداد  " />
                            <ToggleButton Grid.Row="5" Grid.Column="4" Height="45" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                          Checked="IsCash_Changed" Cursor="Hand"
                                          IsChecked="{Binding FormItem.IsCash, UpdateSourceTrigger=PropertyChanged}"
                                          Unchecked="IsCash_Changed">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="TrackBorder" Height="38" Background="#2F3549" BorderBrush="#3D4560" BorderThickness="1"
                                                CornerRadius="19">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border x:Name="SliderHighlight" Grid.Column="1" Margin="3" Background="#5BAE7C" CornerRadius="16">
                                                    <Border.RenderTransform>
                                                        <TranslateTransform x:Name="SliderTranslate" X="0" />
                                                    </Border.RenderTransform>
                                                </Border>
                                                <TextBlock x:Name="LabelRight" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13"
                                                           FontWeight="SemiBold" Foreground="White" Text="أجل" />
                                                <TextBlock x:Name="LabelLeft" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13"
                                                           FontWeight="SemiBold" Foreground="White" Text="كاش" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="False">
                                                <Setter TargetName="SliderHighlight" Property="Grid.Column" Value="0" />
                                                <Setter TargetName="SliderHighlight" Property="Background" Value="#E8A54B" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TrackBorder" Property="BorderBrush" Value="#E8A54B" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                        </Grid>

                        <!--  ── Tax Section ──────────────────────────────────  -->
                        <Border Grid.Row="3" Margin="0,0,0,24" Padding="16,12" Background="#272C3F" BorderBrush="#3D4560"
                                BorderThickness="1" CornerRadius="10"
                                IsEnabled="{Binding IsEditing}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0" VerticalAlignment="Center" Content="فاتورة ضريبية" FontSize="14" FontWeight="SemiBold"
                                          Foreground="White"
                                          IsChecked="{Binding FormIsTax, UpdateSourceTrigger=PropertyChanged}" />

                                <Grid Grid.Column="2"
                                      Visibility="{Binding FormIsTax, Converter={StaticResource BoolToVis}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontSize="13" FontWeight="Bold"
                                               Foreground="#7B84A0" Text="اجمالي الفاتورة" />
                                    <TextBox Grid.Row="0" Grid.Column="2" MinWidth="160" HorizontalContentAlignment="Center" Background="#FFF9C4"
                                             FontSize="14" FontWeight="Bold" IsReadOnly="True"
                                             Style="{StaticResource FormTextBox}"
                                             Text="{Binding NetBeforeTax, Mode=OneWay, StringFormat=\{0:N2\}}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontSize="13" FontWeight="Bold"
                                               Foreground="#7B84A0" Text="ض القيمة المضافة" />
                                    <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal">
                                        <TextBox MinWidth="60" HorizontalContentAlignment="Center" FontSize="13"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding VatTaxPercent, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox MinWidth="90" Margin="8,0,0,0" HorizontalContentAlignment="Center" Background="#FFF9C4" FontSize="13"
                                                 FontWeight="SemiBold" IsReadOnly="True"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding FormItem.VatTax, Mode=OneWay, StringFormat=\{0:N2\}}" />
                                    </StackPanel>

                                    <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" FontSize="13" FontWeight="Bold"
                                               Foreground="#7B84A0" Text="ضريبة أ.ت.ص" />
                                    <StackPanel Grid.Row="4" Grid.Column="2" Orientation="Horizontal">
                                        <TextBox MinWidth="60" HorizontalContentAlignment="Center" FontSize="13"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding WhtTaxPercent, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox MinWidth="90" Margin="8,0,0,0" HorizontalContentAlignment="Center" Background="#FFF9C4" FontSize="13"
                                                 FontWeight="SemiBold" IsReadOnly="True"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding FormItem.Tax, Mode=OneWay, StringFormat=\{0:N2\}}" />
                                    </StackPanel>

                                    <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" FontSize="13" FontWeight="Bold"
                                               Foreground="#059669" Text="الصافي بعد الضريبة" />
                                    <TextBox Grid.Row="6" Grid.Column="2" MinWidth="160" HorizontalContentAlignment="Center" Background="#ECFDF5"
                                             FontSize="15" FontWeight="Bold" Foreground="#059669" IsReadOnly="True"
                                             Style="{StaticResource FormTextBox}"
                                             Text="{Binding FormItem.Net, Mode=OneWay, StringFormat=\{0:N2\}}" />
                                </Grid>
                            </Grid>
                        </Border>

                        <!--  ── Source Selection ─────────────────────────────  -->
                        <Border Grid.Row="4" Margin="0,0,0,24" Padding="16,12" Background="#272C3F" BorderBrush="#3D4560"
                                BorderThickness="1" CornerRadius="10"
                                IsEnabled="{Binding IsEditing}">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,10" FontSize="15" FontWeight="Bold" Foreground="#E8A54B" Text="📋  مصدر الشراء" />

                                <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                                    <RadioButton Margin="0,0,24,0" Content="شراء من مورد محلي" FontSize="13" FontWeight="SemiBold" Foreground="White"
                                                 GroupName="SourceType"
                                                 IsChecked="{Binding IsFromCustomer, Converter={StaticResource InverseBoolToVis}}" />
                                    <RadioButton Content="شراء من عميل" FontSize="13" FontWeight="SemiBold" Foreground="White" GroupName="SourceType"
                                                 IsChecked="{Binding IsFromCustomer}" />
                                </StackPanel>

                                <!--  Supplier Smart Search  -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFromCustomer}"
                                                             Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="13" Foreground="#9BA4B5"
                                               Text="المورد:" />
                                    <Grid Grid.Column="1">
                                        <StackPanel Orientation="Vertical">
                                            <Grid>
                                                <TextBox FontSize="14"
                                                         Style="{StaticResource FormTextBox}"
                                                         Text="{Binding SupplierSearchText, UpdateSourceTrigger=PropertyChanged}" />
                                                <Popup Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}"
                                                       IsOpen="{Binding IsSupplierSearchPopupOpen}"
                                                       Placement="Bottom"
                                                       PlacementTarget="{Binding RelativeSource={RelativeSource AncestorType=Grid}}"
                                                       StaysOpen="False">
                                                    <Border MaxHeight="200" Background="#242940" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="8">
                                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                            <ItemsControl ItemsSource="{Binding FilteredSuppliersList}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Button Padding="12,8" HorizontalContentAlignment="Right" Background="Transparent" BorderThickness="0"
                                                                                Command="{Binding DataContext.SelectSupplierCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                CommandParameter="{Binding}"
                                                                                Content="{Binding SuppName}"
                                                                                Cursor="Hand" FontSize="13" Foreground="#C8CEE0" />
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </ScrollViewer>
                                                    </Border>
                                                </Popup>
                                            </Grid>
                                            <TextBlock Margin="0,4,0,0" FontSize="12" FontWeight="SemiBold" Foreground="#E8A54B"
                                                       Text="{Binding CurrentSupplierBalance, StringFormat='الرصيد الحالي: {0:N2}'}" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>

                                <!--  Customer Smart Search  -->
                                <Grid Margin="0,0,0,8"
                                      Visibility="{Binding IsFromCustomer, Converter={StaticResource BoolToVis}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="13" Foreground="#9BA4B5"
                                               Text="العميل:" />
                                    <Grid Grid.Column="1">
                                        <StackPanel Orientation="Vertical">
                                            <Grid>
                                                <TextBox FontSize="14"
                                                         Style="{StaticResource FormTextBox}"
                                                         Text="{Binding CustomerSearchText, UpdateSourceTrigger=PropertyChanged}" />
                                                <Popup Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}"
                                                       IsOpen="{Binding IsCustomerSearchPopupOpen}"
                                                       Placement="Bottom"
                                                       PlacementTarget="{Binding RelativeSource={RelativeSource AncestorType=Grid}}"
                                                       StaysOpen="False">
                                                    <Border MaxHeight="200" Background="#242940" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="8">
                                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                            <ItemsControl ItemsSource="{Binding FilteredCustomersList}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Button Padding="12,8" HorizontalContentAlignment="Right" Background="Transparent" BorderThickness="0"
                                                                                Command="{Binding DataContext.SelectCustomerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                CommandParameter="{Binding}"
                                                                                Content="{Binding CusName}"
                                                                                Cursor="Hand" FontSize="13" Foreground="#C8CEE0" />
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </ScrollViewer>
                                                    </Border>
                                                </Popup>
                                            </Grid>
                                            <TextBlock Margin="0,4,0,0" FontSize="12" FontWeight="SemiBold" Foreground="#E8A54B"
                                                       Text="{Binding CurrentCustomerBalance, StringFormat='الرصيد الحالي: {0:N2}'}" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>

                                <!--  New / Existing Car Toggle  -->
                                <StackPanel Margin="0,8,0,4" Orientation="Horizontal"
                                            Visibility="{Binding IsFromCustomer, Converter={StaticResource BoolToVis}}">
                                    <RadioButton Margin="0,0,24,0" Content="موتوسيكل جديد" FontSize="13" FontWeight="SemiBold" Foreground="White"
                                                 GroupName="CarType"
                                                 IsChecked="{Binding IsExistingCar, Converter={StaticResource InverseBoolToVis}}" />
                                    <RadioButton Content="موتوسيكل موجود" FontSize="13" FontWeight="SemiBold" Foreground="White" GroupName="CarType"
                                                 IsChecked="{Binding IsExistingCar}" />
                                </StackPanel>

                                <!--  Existing Car ComboBox  -->
                                <Grid Margin="0,8,0,0"
                                      Visibility="{Binding IsExistingCar, Converter={StaticResource BoolToVis}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="13" Foreground="#9BA4B5"
                                               Text="اختر الموتوسيكل:" />
                                    <ComboBox Grid.Column="1" Padding="8,5" FontSize="13"
                                              ItemsSource="{Binding SourceCars}"
                                              SelectedValue="{Binding SelectedExistingCarId}"
                                              SelectedValuePath="CarId">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <Run Text="{Binding ChassisNo, Mode=OneWay}" />
                                                    <Run Foreground="#7B84A0" Text=" — " />
                                                    <Run Foreground="#9BA4B5"
                                                         Text="{Binding MotorNo, Mode=OneWay}" />
                                                </TextBlock>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!--  ── Car Data ─────────────────────────────────────  -->
                        <Border Grid.Row="5" Margin="0,0,0,24" Padding="16,10" Background="#272C3F" BorderBrush="#3D4560"
                                BorderThickness="1" CornerRadius="10"
                                IsEnabled="{Binding IsEditing}"
                                Visibility="{Binding IsExistingCar, Converter={StaticResource InverseBoolToVis}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Margin="0,0,24,0" VerticalAlignment="Center" FontSize="15" FontWeight="Bold"
                                           Foreground="#E8A54B" Text="🏍️  بيانات الموتوسيكل" />

                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!--  Row 0: Brand | Model | Year | Color  -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="2.5*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="2.5*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="1.5*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                                   Style="{StaticResource SectionLabel}"
                                                   Text="الماركة" />
                                        <TextBox Grid.Column="1" FontSize="13"
                                                 IsEnabled="{Binding IsBrandEnabled}"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding CarBrandName, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Column="3" VerticalAlignment="Center"
                                                   Style="{StaticResource SectionLabel}"
                                                   Text="الموديل" />
                                        <TextBox Grid.Column="4" FontSize="13"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding CarModelName, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Column="6" VerticalAlignment="Center"
                                                   Style="{StaticResource SectionLabel}"
                                                   Text="السنة" />
                                        <TextBox Grid.Column="7" FontSize="13"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding CarYearNo, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Column="9" VerticalAlignment="Center"
                                                   Style="{StaticResource SectionLabel}"
                                                   Text="اللون" />
                                        <TextBox Grid.Column="10" FontSize="13"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding CarColorName, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>

                                    <!--  Row 2: Chassis | Motor | Plate | Notes  -->
                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="1.5*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="2.5*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                                   Style="{StaticResource SectionLabel}"
                                                   Text="الشاسيه" />
                                        <TextBox Grid.Column="1" FontSize="13"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding CarChassisNo, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Column="3" VerticalAlignment="Center"
                                                   Style="{StaticResource SectionLabel}"
                                                   Text="الموتور" />
                                        <TextBox Grid.Column="4" FontSize="13"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding CarMotorNo, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Column="6" VerticalAlignment="Center"
                                                   Style="{StaticResource SectionLabel}"
                                                   Text="اللوحة" />
                                        <TextBox Grid.Column="7" FontSize="13"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding CarPlateNo, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                    <Grid Grid.Row="3" Margin="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="2*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                                   Style="{StaticResource SectionLabel}"
                                                   Text="عداد (كم)" />
                                        <TextBox Grid.Column="1" FontSize="13"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding FormItem.Mileage, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                   Style="{StaticResource SectionLabel}"
                                                   Text="ملاحظات" />
                                        <TextBox Grid.Column="3" FontSize="13"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding CarNotes, UpdateSourceTrigger=PropertyChanged}" />

                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                        <!--  ══════════════════════════════════════════════════  -->
                        <!--  ROW 6 — كاش: اختيار الخزينة  -->
                        <!--  ══════════════════════════════════════════════════  -->
                        <Border Grid.Row="6" Margin="0,0,0,24" Padding="22" Background="#283830" BorderBrush="#3D7A5A"
                                BorderThickness="1" CornerRadius="12"
                                IsEnabled="{Binding IsEditing}"
                                Visibility="{Binding IsCashPaymentMode, Converter={StaticResource BoolToVis}}">
                            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                <TextBlock Margin="0,0,16,0" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="#5BAE7C"
                                           Text="💰 سداد كاش — اختر الخزينة:" />
                                <ComboBox MinWidth="250" BorderBrush="#5BAE7C" DisplayMemberPath="CashName" FontSize="14" FontWeight="SemiBold"
                                          ItemsSource="{Binding Cashes}"
                                          SelectedValue="{Binding SelectedCashId, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="CashId" />
                                <TextBlock Margin="16,0,0,0" VerticalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="#5BAE7C"
                                           Text="{Binding CurrentSafeBalance, StringFormat='رصيد الخزينة: {0:N2}'}" />
                                <StackPanel Margin="32,0,0,0" VerticalAlignment="Center" Orientation="Horizontal">
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#7B84A0" Text="المبلغ المطلوب: " />
                                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#5BAE7C"
                                               Text="{Binding FormItem.Net, StringFormat=\{0:N2\}}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!--  ══════════════════════════════════════════════════  -->
                        <!--  ROW 7 — أجل: إدارة المدفوعات  -->
                        <!--  ══════════════════════════════════════════════════  -->
                        <Border Grid.Row="7" Margin="0,0,0,24" Padding="18" Background="#272C3F" BorderBrush="#3D4560"
                                BorderThickness="1" CornerRadius="12"
                                IsEnabled="{Binding IsEditing}"
                                Visibility="{Binding IsCashPaymentMode, Converter={StaticResource InverseBoolToVis}}">
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                <TextBlock Margin="0,0,16,0" VerticalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="#ECEEF5"
                                           Text="💰 المدفوعات وتفاصيل السداد" />
                                <Button Padding="24,12"
                                        Command="{Binding OpenPaymentsPopupCommand}"
                                        Content="إدارة المدفوعات 💰"
                                        Style="{StaticResource PrimaryButton}" />
                                <StackPanel Margin="24,0,0,0" VerticalAlignment="Center" Orientation="Horizontal">
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#7B84A0" Text="إجمالي المدفوع: " />
                                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#5BAE7C"
                                               Text="{Binding TotalPayed, StringFormat=\{0:N2\}}" />
                                    <TextBlock Margin="16,0,0,0" FontSize="13" FontWeight="SemiBold" Foreground="#7B84A0" Text="الباقي: " />
                                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#D9534F"
                                               Text="{Binding Remaining, StringFormat=\{0:N2\}}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!--  ── Action Buttons ──────────────────────────────  -->
                        <DockPanel Grid.Row="8">
                            <TextBlock MaxWidth="300" Margin="0,0,16,0" HorizontalAlignment="Right" VerticalAlignment="Center" DockPanel.Dock="Right"
                                       FontSize="14" FontWeight="SemiBold" Foreground="#10B981"
                                       Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap" />

                                <WrapPanel MinHeight="45" HorizontalAlignment="Left" Orientation="Horizontal">

                                    <!--  Print button  -->
                                    <Button Margin="0,0,12,12" Padding="16,10"
                                            Command="{Binding PrintInvoiceCommand}"
                                            Content="🖨️ طباعة الفاتورة">
                                        <Button.Style>
                                            <Style BasedOn="{StaticResource SecondaryButton}"
                                                   TargetType="Button">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Setter Property="Background" Value="#3B82F6" />
                                                <Setter Property="Foreground" Value="White" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}"
                                                                 Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedInvoice}"
                                                                 Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <!--  Edit button  -->
                                    <Button Margin="0,0,12,12" Padding="16,10"
                                            Command="{Binding EditSelectedCommand}"
                                            Content="✏️ تـعـديـل الفاتورة">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource SecondaryButton}"
                                               TargetType="Button">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Setter Property="Background" Value="#F59E0B" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}"
                                                             Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedInvoice}"
                                                             Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!--  Save button  -->
                                <Button Margin="0,0,12,12" Padding="16,10"
                                        Command="{Binding SaveCommand}"
                                        Content="💾 حـفـظ الفاتورة">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource PrimaryButton}"
                                               TargetType="Button">
                                            <Setter Property="Background" Value="#10B981" />
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}"
                                                             Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!--  Cancel button  -->
                                <Button Margin="0,0,16,12" Padding="16,10"
                                        Command="{Binding CancelEditCommand}"
                                        Content="✖ إلـغـاء">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource SecondaryButton}"
                                               TargetType="Button">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}"
                                                             Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!--  Delete button  -->
                                <Button Margin="0,0,0,12" Padding="16,10"
                                        Command="{Binding DeleteCommand}"
                                        Content="🗑️ حـذف">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource DangerButton}"
                                               TargetType="Button">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedInvoice}"
                                                             Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsEditing}"
                                                             Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </WrapPanel>
                        </DockPanel>
                    </Grid>
                </Border>
            </ScrollViewer>
        </Grid>

        <!--  ════════════════════════════════════════════════════════════════  -->
        <!--  SEARCH SECTION  -->
        <!--  ════════════════════════════════════════════════════════════════  -->
        <Grid Margin="24"
              Style="{StaticResource SearchContainerStyle}">
            <Border Padding="24" Background="#272C3F" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="14">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" Direction="270" Opacity="0.04" ShadowDepth="4" Color="#0F172A" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,24">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <Border Margin="0,0,12,0" Padding="10" CornerRadius="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Offset="0" Color="#E8A54B" />
                                        <GradientStop Offset="1" Color="#D4922F" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock FontSize="20" Text="🔎" />
                            </Border>
                            <TextBlock VerticalAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="White" Text="البحث في فواتير شراء الموتوسيكل" />
                        </StackPanel>
                        <Button Padding="16,8" HorizontalAlignment="Right"
                                Command="{Binding HideSearchPanelCommand}"
                                Content="✖ الـرجـوع للـنمـوذج" DockPanel.Dock="Right"
                                Style="{StaticResource SecondaryButton}" />
                    </DockPanel>

                    <Border Grid.Row="1" Margin="0,0,0,20" Padding="16"
                            Background="{StaticResource SectionBg}"
                            BorderBrush="{StaticResource SectionBorder}"
                            BorderThickness="1" CornerRadius="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="White"
                                       Text="كلمة البحث (رقم الفاتورة، اسم المالك):" />
                            <TextBox Grid.Column="1" Padding="12,8" HorizontalAlignment="Stretch" Background="LightGray" FontSize="15"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Background="#242940" BorderBrush="#3D4560" BorderThickness="1" ClipToBounds="True"
                            CornerRadius="12">
                        <DataGrid AlternatingRowBackground="#222738" AutoGenerateColumns="False" Background="#242940" BorderThickness="0" CanUserAddRows="False"
                                  ColumnHeaderHeight="50" FontSize="13" Foreground="#C8CEE0" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                  HorizontalGridLinesBrush="#323848" IsReadOnly="True"
                                  ItemsSource="{Binding FilteredInvoices}"
                                  RowHeight="46"
                                  SelectedItem="{Binding SelectedInvoice, Mode=TwoWay}"
                                  SelectionMode="Single">
                            <DataGrid.ColumnHeaderStyle>
                                <Style BasedOn="{StaticResource DarkColumnHeader}"
                                       TargetType="DataGridColumnHeader" />
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style BasedOn="{StaticResource DarkRow}"
                                       TargetType="DataGridRow" />
                            </DataGrid.RowStyle>
                            <DataGrid.CellStyle>
                                <Style BasedOn="{StaticResource DarkCell}"
                                       TargetType="DataGridCell" />
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Margin="8,6" Padding="4" Background="#10B981"
                                                    Command="{Binding DataContext.HideSearchPanelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    Content="✅ اختيار" FontSize="12" Foreground="White"
                                                    Style="{StaticResource PrimaryButton}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="100"
                                                    Binding="{Binding BuyId}"
                                                    Header="رقم الفاتورة" />
                                <DataGridTextColumn Width="100"
                                                    Binding="{Binding BuyDate, StringFormat=\{0:yyyy/MM/dd\}}"
                                                    Header="التاريخ" />
                                <DataGridTextColumn Width="200"
                                                    Binding="{Binding OwnerName}"
                                                    Header="المالك" />
                                <DataGridTextColumn Width="150"
                                                    Binding="{Binding Net, StringFormat=\{0:N2\}}"
                                                    Header="الإجمالي" />
                                <DataGridTextColumn Width="*"
                                                    Binding="{Binding Notes}"
                                                    Header="الملاحظات" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!--  ████████ PAYMENTS POPUP OVERLAY ████████  -->
        <Grid Panel.ZIndex="100" Background="#B20F172A"
              Visibility="{Binding IsPaymentsPopupOpen, Converter={StaticResource BoolToVis}}">
            <Border Width="850" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#1E2233" BorderBrush="#3D4560"
                    BorderThickness="1" CornerRadius="16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="32" Direction="270" Opacity="0.3" ShadowDepth="12" Color="#000000" />
                </Border.Effect>
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Header  -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock VerticalAlignment="Center" DockPanel.Dock="Left" FontSize="20" FontWeight="Bold" Foreground="#ECEEF5"
                                   Text="💰 المدفوعات" />
                        <Button HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0"
                                Command="{Binding ClosePaymentsPopupCommand}"
                                Content="✖" Cursor="Hand" DockPanel.Dock="Right" FontSize="20" FontWeight="Bold"
                                Foreground="#7B84A0" ToolTip="إغلاق" />
                    </DockPanel>

                    <!--  Quick Add Payment  -->
                    <Border Grid.Row="1" Margin="0,0,0,14" Padding="14" Background="#2F3549" BorderBrush="#3D4560"
                            BorderThickness="1" CornerRadius="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="100" />
                                <ColumnDefinition Width="*" MinWidth="80" />
                                <ColumnDefinition Width="*" MinWidth="200" />
                                <ColumnDefinition Width="2*" MinWidth="100" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Style="{StaticResource FormLabel}"
                                           Text="التاريخ" />
                                <DatePicker SelectedDate="{Binding CurrentPayment.PayDate, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Style="{StaticResource FormLabel}"
                                           Text="المبلغ" />
                                <TextBox Style="{StaticResource FormTextBox}"
                                         Text="{Binding CurrentPayment.PayMoney, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Grid.Column="2" Margin="0,0,10,0">
                                <TextBlock Style="{StaticResource FormLabel}"
                                           Text="الخزينة" />
                                <StackPanel>
                                    <ComboBox DisplayMemberPath="CashName"
                                              ItemsSource="{Binding Cashes}"
                                              SelectedValue="{Binding SelectedCashId, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedValuePath="CashId" />
                                    <TextBlock Margin="0,4,0,0" FontSize="12" FontWeight="SemiBold" Foreground="#047857"
                                               Text="{Binding CurrentSafeBalance, StringFormat='رصيد الخزينة: {0:N2}'}" />
                                </StackPanel>
                            </Grid>
                            <Grid Grid.Column="3" Margin="0,0,10,0">
                                <TextBlock Style="{StaticResource FormLabel}"
                                           Text="ملاحظات" />
                                <TextBox Style="{StaticResource FormTextBox}"
                                         Text="{Binding CurrentPayment.Notes, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Button Grid.Column="4" Padding="16,10"
                                    Command="{Binding AddPaymentCommand}"
                                    Content="➕ إضافة"
                                    Style="{StaticResource SuccessButton}" />
                        </Grid>
                    </Border>

                    <!--  Payments DataGrid  -->
                    <Border Grid.Row="2" MinHeight="150" MaxHeight="300" Background="#242940" BorderBrush="#3D4560"
                            BorderThickness="1" ClipToBounds="True" CornerRadius="10">
                        <DataGrid AlternatingRowBackground="#222738" AutoGenerateColumns="False" Background="#242940" BorderThickness="0" CanUserAddRows="False"
                                  ColumnHeaderHeight="40" FontSize="13" Foreground="#C8CEE0" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                  HorizontalGridLinesBrush="#323848" IsReadOnly="False"
                                  ItemsSource="{Binding FormPayments}"
                                  RowHeight="36" SelectionMode="Single">
                            <DataGrid.ColumnHeaderStyle>
                                <Style BasedOn="{StaticResource DarkColumnHeader}"
                                       TargetType="DataGridColumnHeader" />
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style BasedOn="{StaticResource DarkRow}"
                                       TargetType="DataGridRow" />
                            </DataGrid.RowStyle>
                            <DataGrid.CellStyle>
                                <Style BasedOn="{StaticResource DarkCell}"
                                       TargetType="DataGridCell" />
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="120"
                                                    Binding="{Binding PayDate, StringFormat=\{0:yyyy/MM/dd\}}"
                                                    Header="التاريخ" />
                                <DataGridTextColumn Width="120"
                                                    Binding="{Binding PayMoney, StringFormat=\{0:N2\}}"
                                                    FontWeight="SemiBold" Foreground="#5BAE7C" Header="المبلغ" />
                                <DataGridTemplateColumn Width="*" Header="الخزينة">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Padding="4,0" VerticalAlignment="Center">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource IdToNameConverter}"
                                                                  ConverterParameter="CashId,CashName">
                                                        <Binding Path="CashId" />
                                                        <Binding Path="DataContext.Cashes"
                                                                 RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <ComboBox DisplayMemberPath="CashName" IsDropDownOpen="True"
                                                      ItemsSource="{Binding DataContext.Cashes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      SelectedValue="{Binding CashId, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="CashId" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="*"
                                                    Binding="{Binding Notes}"
                                                    Header="ملاحظات" />
                                <DataGridTemplateColumn Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Background="Transparent" BorderThickness="0"
                                                    Command="{Binding DataContext.RemovePaymentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Content="🗑️" Cursor="Hand" FontSize="14" Foreground="#D9534F" ToolTip="حذف الدفعة" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!--  Payment Totals  -->
                    <StackPanel Grid.Row="3" Margin="0,14,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
                        <Border Margin="0,0,24,0" Padding="16,10" Background="#283830" BorderBrush="#3D7A5A" BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#7B84A0" Text="إجمالي المدفوع" />
                                <TextBlock FontSize="18" FontWeight="Bold" Foreground="#5BAE7C"
                                           Text="{Binding TotalPayed, StringFormat=\{0:N2\}}" />
                            </StackPanel>
                        </Border>
                        <Border Padding="16,10" Background="#3A2828" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="8">
                            <StackPanel>
                                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#7B84A0" Text="الباقي" />
                                <TextBlock FontSize="18" FontWeight="Bold" Foreground="#D9534F"
                                           Text="{Binding Remaining, StringFormat=\{0:N2\}}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
