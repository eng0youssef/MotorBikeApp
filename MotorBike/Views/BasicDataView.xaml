<UserControl x:Class="MotorBike.Views.BasicDataView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" d:DesignHeight="800" d:DesignWidth="1000" FlowDirection="RightToLeft"
             mc:Ignorable="d">
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.0" To="1.0" Duration="0:0:0.5" />
                    <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,30,0,-30" To="0" Duration="0:0:0.5">
                        <ThicknessAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
    <UserControl.Resources>

        <!--  Style for Category Header  -->
        <Style x:Key="CategoryHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="Margin" Value="0,20,0,15" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!--  Style for the Icon Circle  -->
        <Style x:Key="IconBorderStyle" TargetType="Border">
            <Setter Property="Width" Value="64" />
            <Setter Property="Height" Value="64" />
            <Setter Property="CornerRadius" Value="32" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <!--  Style for the Icon Text  -->
        <Style x:Key="IconTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="30" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!--  Style for the Title Text  -->
        <Style x:Key="TitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer MinWidth="600" MinHeight="400" Background="#272C3F" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <!--  Header section  -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Margin="0,0,0,8" FontSize="32" FontWeight="Bold" Foreground="White" Text="البيانات الأساسية" />
                <TextBlock FontSize="16" Foreground="LightGray" Text="إدارة كافة البيانات الأساسية للنظام من مكان واحد." />
            </StackPanel>

            <!--  بيانات عامة  -->
            <StackPanel Margin="0,10,0,10" Orientation="Horizontal">
                <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" FontSize="20" Foreground="White" Text="📄" />
                <TextBlock Margin="0" Foreground="White" Style="{StaticResource CategoryHeaderStyle}" Text="بيانات عامة" />
            </StackPanel>
            <WrapPanel Margin="0,0,0,30">
                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="Company"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Background="#EFF6FF" Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="🏢" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="بيانات الشركة" />
                    </StackPanel>
                </Button>
                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="Users"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Background="#F5F3FF" Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="👤" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="المستخدمين" />
                    </StackPanel>
                </Button>
                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="Cities"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Background="#ECFEFF" Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="🌆" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="المدن" />
                    </StackPanel>
                </Button>
                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="Customers"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Background="#FDF2F8" Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="👥" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="العملاء" />
                    </StackPanel>
                </Button>
                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="Suppliers"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Background="#FEF3C7" Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="🚚" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="الموردين" />
                    </StackPanel>
                </Button>
            </WrapPanel>

            <!--  المخازن والأصناف  -->
            <StackPanel Margin="0,10,0,10" Orientation="Horizontal">
                <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" FontSize="20" Foreground="White" Text="📦" />
                <TextBlock Margin="0" Foreground="White" Style="{StaticResource CategoryHeaderStyle}" Text="المخازن والأصناف" />
            </StackPanel>
            <WrapPanel Margin="0,0,0,30">
                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="Units"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Background="#F0FDF4" Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="📏" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="وحدات الأصناف" />
                    </StackPanel>
                </Button>
                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="ItemCategories"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Background="#F0FDF4" Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="📂" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="مجموعات الأصناف" />
                    </StackPanel>
                </Button>
                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="Items"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Background="#F0FDF4" Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="🛍️" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="الأصناف" />
                    </StackPanel>
                </Button>
                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="Stores"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Background="#F0FDF4" Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="🏪" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="المخازن" />
                    </StackPanel>
                </Button>
                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="OpenStock"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Background="#F0FDF4" Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="📦" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="أرصدة أول المدة" />
                    </StackPanel>
                </Button>
            </WrapPanel>

            <!--  بيانات المركبات  -->
            <StackPanel Margin="0,10,0,10" Orientation="Horizontal">
                <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" FontSize="20" Foreground="White" Text="🏍️" />
                <TextBlock Margin="0" Foreground="White" Style="{StaticResource CategoryHeaderStyle}" Text="بيانات المركبات" />
            </StackPanel>
            <WrapPanel Margin="0,0,0,30">
                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="CarBrands"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Background="#FFFBEB" Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="🏭" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="ماركات الموتوسيكلات" />
                    </StackPanel>
                </Button>
                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="CarModels"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Background="#FFFBEB" Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="🏍️" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="موديلات الماركة" />
                    </StackPanel>
                </Button>
                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="Colors"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Background="#FFFBEB" Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="🎨" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="الألوان" />
                    </StackPanel>
                </Button>
            </WrapPanel>

            <!--  البيانات المالية  -->
            <StackPanel Margin="0,10,0,10" Orientation="Horizontal">
                <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" FontSize="20" Foreground="White" Text="💵" />
                <TextBlock Margin="0" Foreground="White" Style="{StaticResource CategoryHeaderStyle}" Text="البيانات المالية" />
            </StackPanel>
            <WrapPanel Margin="0,0,0,30">
                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="Cash"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Background="#FEF2F2" Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="💰" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="الخزائن" />
                    </StackPanel>
                </Button>
                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="Omla"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Background="#FEF2F2" Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="💱" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="العملات" />
                    </StackPanel>
                </Button>
                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="ExpGroups"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Background="#FEF2F2" Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="📋" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="مجموعات المصروفات" />
                    </StackPanel>
                </Button>
                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="Expenses"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Background="#FEF2F2" Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="🧾" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="المصروفات" />
                    </StackPanel>
                </Button>
            </WrapPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
