<UserControl x:Class="MotorBike.Views.CompanyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:MotorBike.Converters"
             mc:Ignorable="d"
             Loaded="OnLoaded"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <conv:ByteArrayToImageConverter x:Key="ByteToImageConverter" />
    </UserControl.Resources>

    <Border Background="White" CornerRadius="8" Padding="24"
            BorderBrush="#E2E8F0" BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel MaxWidth="600">

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="بيانات الشركة" FontSize="18" FontWeight="Bold"
                           Foreground="#1E293B" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Border Width="120" Height="120" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Background="#F8FAFC" Margin="0,0,12,0" ClipToBounds="True">
                        <Image Source="{Binding Company.Logo, Converter={StaticResource ByteToImageConverter}}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Button Content="📷 اختيار شعار" Command="{Binding SelectLogoCommand}" Style="{StaticResource SecondaryButton}" VerticalAlignment="Center" Padding="12,8"/>
                </StackPanel>
            </Grid>

            <!-- الاسم عربي -->
            <TextBlock Text="اسم الشركة (عربي)" Style="{StaticResource FormLabel}"/>
            <TextBox Text="{Binding Company.NameAr, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource FormTextBox}" Margin="0,0,0,12"/>

            <!-- الاسم انجليزي -->
            <TextBlock Text="اسم الشركة (إنجليزي)" Style="{StaticResource FormLabel}"/>
            <TextBox Text="{Binding Company.NameEn, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource FormTextBox}" Margin="0,0,0,12"
                     FlowDirection="LeftToRight"/>

            <!-- العنوان عربي -->
            <TextBlock Text="العنوان (عربي)" Style="{StaticResource FormLabel}"/>
            <TextBox Text="{Binding Company.AdressAr, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource FormTextBox}" Margin="0,0,0,12"/>

            <!-- العنوان انجليزي -->
            <TextBlock Text="العنوان (إنجليزي)" Style="{StaticResource FormLabel}"/>
            <TextBox Text="{Binding Company.AdressEn, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource FormTextBox}" Margin="0,0,0,12"
                     FlowDirection="LeftToRight"/>

            <!-- صف مزدوج: تليفون + واتساب -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="التليفون" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding Company.Tel, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="واتساب" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding Company.Whatsapp, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}"/>
                </StackPanel>
            </Grid>

            <!-- صف مزدوج: فيسبوك + موقع الكتروني -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="فيسبوك" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding Company.Facebook, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="الموقع الإلكتروني" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding Company.Website, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}" FlowDirection="LeftToRight"/>
                </StackPanel>
            </Grid>

            <!-- صف مزدوج: سجل تجاري + ضريبة -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="السجل التجاري" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding Company.Segl, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="الرقم الضريبي" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding Company.Dariba, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}"/>
                </StackPanel>
            </Grid>

            <!-- صف مزدوج: عملة رئيسية + عملة فرعية -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="العملة الرئيسية" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding Company.CurMain, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="العملة الفرعية" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding Company.CurSub, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}"/>
                </StackPanel>
            </Grid>

            <!-- زر الحفظ -->
            <Button Content="💾 حفظ البيانات" Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveCommand}" HorizontalAlignment="Left" Padding="30,10"/>

            <!-- رسالة الحالة -->
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#64748B"
                       Margin="0,12,0,0"/>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
