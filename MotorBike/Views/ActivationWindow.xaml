<Window x:Class="MotorBike.Views.ActivationWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="تفعيل البرنامج" Width="750" Height="500" AllowsTransparency="True" Background="Transparent"
        FlowDirection="RightToLeft" MouseDown="Window_MouseDown" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" WindowStyle="None">

    <Border Background="#1E2233" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Right Accent Panel (Column 0 = Right in RTL)  -->
            <Border Grid.Column="0" CornerRadius="12,0,0,12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#E8A54B" />
                        <GradientStop Offset="1" Color="#D4922F" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Ellipse Width="280" Height="280" Margin="-100,-60,0,0" HorizontalAlignment="Right" VerticalAlignment="Top" Fill="White" Opacity="0.06" />
                    <StackPanel Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="80" Height="80" Margin="0,0,0,20" HorizontalAlignment="Center" Background="White" CornerRadius="18" Opacity="0.92">
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="40" Text="🛡️" />
                        </Border>
                        <TextBlock Margin="0,0,0,10" HorizontalAlignment="Center" FontSize="19" FontWeight="Bold" Foreground="White" Text="نظام التفعيل" />
                        <TextBlock Margin="0,0,0,0" FontSize="13" Foreground="White" Opacity="0.82" Text="حماية بياناتك تبدأ بالتفعيل" TextAlignment="Center" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <!--  Left Form Area (Column 1 = Left in RTL)  -->
            <Border Grid.Column="1" Padding="36,28">
                <Grid>
                    <!--  Close Button Top-Left (appears top-right visually in RTL)  -->
                    <Button Margin="0,0,0,0" Padding="4" HorizontalAlignment="Left" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Click="Close_Click" Content="✕"
                            FontSize="16" Foreground="#7B84A0" />

                    <StackPanel Margin="0,30,0,0" VerticalAlignment="Center">

                        <TextBlock Margin="0,0,0,4" FontSize="24" FontWeight="ExtraBold" Foreground="White" Text="تفعيل المنتج" />
                        <TextBlock Margin="0,0,0,20" FontSize="12" Foreground="#7B84A0" Text="يرجى إرسال كود الجهاز للدعم أو طلب التفعيل" />

                        <!--  HWID  -->
                        <TextBlock Margin="0,0,0,5" FontSize="11" Foreground="#9BA4B5" Text="كود الجهاز (GUID)" />
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Height="38" Padding="10,0" VerticalContentAlignment="Center" Background="#272C3F" BorderBrush="#3D4560" BorderThickness="1" FontSize="12"
                                     FontWeight="Bold" Foreground="#E8A54B" IsReadOnly="True"
                                     Text="{Binding Hwid, Mode=OneWay}" />
                            <Button Grid.Column="1" Width="56" Height="38" Margin="6,0,0,0" Background="#272C3F" BorderBrush="#3D4560" BorderThickness="1"
                                    Command="{Binding CopyHwidCommand}"
                                    Content="نسخ" FontSize="12" Foreground="White" />
                        </Grid>

                        <!--  Hardware Details  -->
                        <Border Margin="0,0,0,14" Padding="12,10" Background="#272C3F" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="8">
                            <StackPanel>
                                <Grid Margin="0,0,0,5">
                                    <TextBlock HorizontalAlignment="Right" FontSize="11" Foreground="#7B84A0" Text=":المعالج" />
                                    <TextBlock MaxWidth="200" HorizontalAlignment="Left" FontSize="11" Foreground="White"
                                               Text="{Binding Cpu}"
                                               TextWrapping="Wrap" />
                                </Grid>
                                <Grid Margin="0,0,0,5">
                                    <TextBlock HorizontalAlignment="Right" FontSize="11" Foreground="#7B84A0" Text=":النظام" />
                                    <TextBlock HorizontalAlignment="Left" FontSize="11" Foreground="White" Text="{Binding Os}" />
                                </Grid>
                                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                    <TextBlock Margin="16,0,4,0" FontSize="11" Foreground="#7B84A0" Text=":التخزين" />
                                    <TextBlock Margin="0,0,20,0" FontSize="11" Foreground="White" Text="{Binding Storage}" />
                                    <TextBlock Margin="0,0,4,0" FontSize="11" Foreground="#7B84A0" Text=":الرام" />
                                    <TextBlock FontSize="11" Foreground="White" Text="{Binding Ram}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!--  Name Input  -->
                        <TextBlock Margin="0,0,0,6" FontSize="12" Foreground="#9BA4B5" Text="اسم المستخدم / المحل" />
                        <TextBox Height="42" Margin="0,0,0,12" Padding="10,0" VerticalContentAlignment="Center" Background="#272C3F" BorderBrush="#3D4560" BorderThickness="1" Foreground="White"
                                 Text="{Binding ReferenceName, UpdateSourceTrigger=PropertyChanged}" />

                        <!--  Status  -->
                        <TextBlock Margin="0,0,0,12" FontSize="12"
                                   Foreground="{Binding IsSuccess, Converter={StaticResource BooleanToColorConverter}}"
                                   Text="{Binding StatusMessage}"
                                   TextAlignment="Center" TextWrapping="Wrap" />

                        <!--  Buttons  -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Height="42" Background="#272C3F" BorderBrush="#E8A54B" BorderThickness="1"
                                    Command="{Binding RegisterCommand}"
                                    Content="ارسال طلب التفعيل" FontSize="13" Foreground="White"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                            <Button Grid.Column="2" Height="42" Background="#E8A54B" BorderThickness="0"
                                    Command="{Binding CheckActivationCommand}"
                                    Content="التحقق من التفعيل" FontSize="13" FontWeight="Bold" Foreground="Black"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                        </Grid>

                        <!--  Close Link  -->
                        <Button HorizontalAlignment="Center" Background="Transparent" BorderThickness="0" Click="Close_Click" Content="إغلاق البرنامج" FontSize="12" Foreground="#7B84A0" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>