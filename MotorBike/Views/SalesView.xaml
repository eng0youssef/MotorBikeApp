<UserControl x:Class="MotorBike.Views.SalesView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:conv="clr-namespace:MotorBike.Converters" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" FlowDirection="RightToLeft" Loaded="OnLoaded"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:HideZeroConverter x:Key="HideZeroConv" />
        <conv:IdToNameConverter x:Key="IdToNameConverter" />
        <conv:InverseBoolConverter x:Key="InverseBool" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />

        <Style x:Key="FormCard" TargetType="Border">
            <Setter Property="Background" Value="#272C3F" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#3D4560" />
            <Setter Property="Margin" Value="20" />
            <Setter Property="Padding" Value="28" />
        </Style>

        <Style x:Key="FormContainerStyle" TargetType="Grid">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="False">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SearchContainerStyle" TargetType="Grid">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <!--  Floating label  -->
        <Style x:Key="FloatingLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="#7B84A0" />
            <Setter Property="Margin" Value="4,-14,0,0" />
        </Style>

        <!--  Dark Column Header  -->
        <Style x:Key="DarkColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2A3040" />
            <Setter Property="Foreground" Value="#9BA4B5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="BorderBrush" Value="#3D4560" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <!--  Dark Row  -->
        <Style x:Key="DarkRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#C8CEE0" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#323F58" />
                    <Setter Property="Foreground" Value="#E8A54B" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A3040" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  Dark Cell  -->
        <Style x:Key="DarkCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Foreground" Value="#C8CEE0" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="#E8A54B" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  Section surface  -->
        <SolidColorBrush x:Key="SectionBg" Color="#2F3549" />
        <SolidColorBrush x:Key="SectionBorder" Color="#3D4560" />
    </UserControl.Resources>

    <Grid Background="#2F3549">

        <!--  FORM Section  -->
        <Grid Style="{StaticResource FormContainerStyle}">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" ScrollChanged="ScrollViewer_ScrollChanged" VerticalScrollBarVisibility="Auto">
                <Border Style="{StaticResource FormCard}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="24" Direction="270" Opacity="0.04" ShadowDepth="4" Color="#0F172A" />
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <!--  Header  -->
                            <RowDefinition Height="Auto" />
                            <!--  Separator  -->
                            <RowDefinition Height="Auto" />
                            <!--  Main Info  -->
                            <RowDefinition Height="Auto" />
                            <!--  Smart Item Search & Add  -->
                            <RowDefinition Height="Auto" />
                            <!--  DataGrid SubItems  -->
                            <RowDefinition Height="Auto" />
                            <!--  Totals & Footer  -->
                            <RowDefinition Height="Auto" />
                            <!--  Cash Mode Treasury  -->
                            <RowDefinition Height="Auto" />
                            <!--  Payments Section  -->
                            <RowDefinition Height="Auto" />
                            <!--  Actions  -->
                        </Grid.RowDefinitions>

                        <!--  Header  -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Border Margin="0,0,16,0" Padding="14,12" CornerRadius="12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Offset="0" Color="#E8A54B" />
                                            <GradientStop Offset="1" Color="#D4922F" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="26" Text="🧾" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock FontSize="22" FontWeight="Bold" Foreground="White" Text="فاتورة المبيعات" />
                                    <TextBlock Margin="0,4,0,0" FontSize="14" Foreground="#64748B" Text="سجل فاتورة بيع جديدة أو استعلم عن فواتير سابقة" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                                <Button Margin="0,0,12,0" Padding="16,10"
                                        Command="{Binding ShowSearchPanelCommand}"
                                        Content="🔍 بحث عن فاتورة سابقة"
                                        Style="{StaticResource SecondaryButton}" />
                                <Button Padding="16,10" Command="{Binding AddNewCommand}" Content="➕ تـسـجيـل فاتورة جـديـدة" Style="{StaticResource PrimaryButton}" />
                            </StackPanel>
                        </Grid>

                        <Rectangle Grid.Row="1" Height="1" Margin="0,8,0,24" Fill="#E2E8F0" />

                        <!--  Form Matrix: Main Info (Responsive)  -->
                        <Grid Grid.Row="2" IsEnabled="{Binding IsEditing}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="80" />
                                <ColumnDefinition Width="*" MinWidth="120" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="Auto" MinWidth="80" />
                                <ColumnDefinition Width="*" MinWidth="120" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="Auto" MinWidth="80" />
                                <ColumnDefinition Width="*" MinWidth="120" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Row 0: ID, Date, Customer  -->
                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="رقم الفاتورة" />
                            <TextBox Grid.Row="0" Grid.Column="1" Background="#F8FAFC" FontWeight="Bold" Foreground="#1E293B" IsReadOnly="True"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding FormItem.SalesId, Converter={StaticResource HideZeroConv}}" />
                            <TextBlock Grid.Row="0" Grid.Column="3" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="التاريخ" />
                            <DatePicker Grid.Row="0" Grid.Column="4" Padding="10,4" FontSize="14"
                                        SelectedDate="{Binding FormItem.SalesDate}" />
                            <TextBlock Grid.Row="0" Grid.Column="6" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="العميل" />
                            <!--  Customer Smart Search  -->
                            <StackPanel Grid.Row="0" Grid.Column="7" VerticalAlignment="Center">
                                <Grid>
                                    <TextBox x:Name="CustomerSearchBox" Padding="8,6" GotFocus="CustomerSearch_GotFocus"
                                             Style="{StaticResource FormTextBox}"
                                             Text="{Binding CustomerSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="ابحث عن العميل بالاسم" />
                                    <Popup x:Name="CustomerSearchPopup"
                                           Width="{Binding ActualWidth, ElementName=CustomerSearchBox}"
                                           AllowsTransparency="True"
                                           IsOpen="{Binding IsCustomerSearchPopupOpen}"
                                           Placement="Bottom"
                                           PlacementTarget="{Binding ElementName=CustomerSearchBox}"
                                           StaysOpen="False">
                                        <Border MaxHeight="250" Background="White" BorderBrush="#2F3549" BorderThickness="1" CornerRadius="8">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="16" Direction="270" Opacity="0.1" ShadowDepth="4" Color="#0F172A" />
                                            </Border.Effect>
                                            <ListBox Background="Transparent" BorderThickness="0" ItemsSource="{Binding FilteredCustomersList}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="8,6" Cursor="Hand">
                                                            <TextBlock FontSize="13" Foreground="#334155">
                                                                <Run Text="{Binding CusName, Mode=OneWay}" />
                                                            </TextBlock>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                        <Setter Property="Padding" Value="0" />
                                                        <EventSetter Event="PreviewMouseLeftButtonDown" Handler="SearchCustomer_Click" />
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#EFF6FF" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>
                                <TextBlock Margin="0,4,0,0" FontSize="12" FontWeight="SemiBold" Foreground="#E8A54B"
                                           Text="{Binding CurrentCustomerBalance, StringFormat='الرصيد الحالي: {0:N2}'}" />
                            </StackPanel>

                            <!--  Row 2: Motorcycle Selection (optional)  -->
                            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="الموتوسيكل" />
                            <ComboBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Padding="8,5" FontSize="13"
                                      ItemsSource="{Binding CustomerCars}"
                                      SelectedValue="{Binding FormItem.CarId}"
                                      SelectedValuePath="CarId">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <Run Text="{Binding ChassisNo, Mode=OneWay}" />
                                            <Run Foreground="#64748B" Text=" — " />
                                            <Run Foreground="#94A3B8" Text="{Binding MotorNo, Mode=OneWay}" />
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <!--  Row 4: Toggle, Notes  -->
                            <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="طريقة السداد" />
                            <!--  Slide Toggle: أجل / كاش  -->
                            <ToggleButton Grid.Row="4" Grid.Column="1" Height="38" HorizontalAlignment="Stretch" VerticalAlignment="Center" Checked="IsCash_Changed" Cursor="Hand"
                                          IsChecked="{Binding FormItem.IsCash, UpdateSourceTrigger=PropertyChanged}"
                                          Unchecked="IsCash_Changed">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="TrackBorder" Height="36" Background="#2F3549" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="18">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border x:Name="SliderHighlight" Grid.Column="1" Margin="2" Background="#10B981" CornerRadius="16" />
                                                <TextBlock x:Name="LabelRight" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="#475569" Text="أجل" />
                                                <TextBlock x:Name="LabelLeft" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="White" Text="كاش" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="False">
                                                <Setter TargetName="SliderHighlight" Property="Grid.Column" Value="0" />
                                                <Setter TargetName="SliderHighlight" Property="Background" Value="#F59E0B" />
                                                <Setter TargetName="LabelRight" Property="Foreground" Value="White" />
                                                <Setter TargetName="LabelLeft" Property="Foreground" Value="White" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TrackBorder" Property="BorderBrush" Value="#94A3B8" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <TextBlock Grid.Row="4" Grid.Column="3" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="ملاحظات" />
                            <TextBox Grid.Row="4" Grid.Column="4" Grid.ColumnSpan="4"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding FormItem.Notes, UpdateSourceTrigger=PropertyChanged}" />

                            <!--  Row 4: Tax Checkbox and Tax Details  -->
                            <CheckBox Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Checked="IsTax_Changed" Content="فاتورة ضريبية" FontSize="14" FontWeight="SemiBold"
                                      Foreground="White"
                                      IsChecked="{Binding FormItem.IsTax, UpdateSourceTrigger=PropertyChanged}"
                                      Style="{StaticResource DarkCheckBox}"
                                      Unchecked="IsTax_Changed" />
                        </Grid>

                        <!--  Smart Item Search & Add Row (Responsive)  -->
                        <Border Grid.Row="3" Margin="0,24,0,16" Padding="16" Background="#2F3549" BorderBrush="#2F3549" BorderThickness="1" CornerRadius="12"
                                IsEnabled="{Binding IsEditing}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" MinWidth="150" />
                                    <!--  Smart Search  -->
                                    <ColumnDefinition Width="*" MinWidth="80" />
                                    <!--  Store  -->
                                    <ColumnDefinition Width="0.9*" MinWidth="70" />
                                    <!--  Unit  -->
                                    <ColumnDefinition Width="0.7*" MinWidth="60" />
                                    <!--  Qty  -->
                                    <ColumnDefinition Width="0.8*" MinWidth="70" />
                                    <!--  Price  -->
                                    <ColumnDefinition Width="0.8*" MinWidth="70" />
                                    <!--  DiscPer  -->
                                    <ColumnDefinition Width="0.8*" MinWidth="70" />
                                    <!--  Disc  -->
                                    <ColumnDefinition Width="1*" MinWidth="80" />
                                    <!--  Total  -->
                                    <ColumnDefinition Width="Auto" />
                                    <!--  Add btn  -->
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Margin="2,-16,0,0" VerticalAlignment="Top" FontSize="13" Foreground="White" Text="بحث الصنف" />
                                    <TextBox x:Name="ItemSearchBox" GotFocus="ItemSearch_GotFocus" Style="{StaticResource FormTextBox}" Text="{Binding ItemSearchText, UpdateSourceTrigger=PropertyChanged}" />
                                    <Popup x:Name="ItemSearchPopup"
                                           Width="{Binding ActualWidth, ElementName=ItemSearchBox}"
                                           AllowsTransparency="True"
                                           IsOpen="{Binding IsItemSearchPopupOpen}"
                                           Placement="Bottom"
                                           PlacementTarget="{Binding ElementName=ItemSearchBox}"
                                           StaysOpen="False">
                                        <Border MaxHeight="250" Background="#2F3549" BorderBrush="#4A5270" BorderThickness="1" CornerRadius="10">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="16" Direction="270" Opacity="0.1" ShadowDepth="4" Color="#0F172A" />
                                            </Border.Effect>
                                            <ListBox Background="Transparent" BorderThickness="0" ItemsSource="{Binding FilteredItemsList}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="8,6" Cursor="Hand">
                                                            <TextBlock FontSize="13" Foreground="#334155">
                                                                <Run Foreground="White" Text="{Binding ItemName, Mode=OneWay}" /><Run Foreground="White" Text=" — " /><Run FontSize="11" Foreground="#64748B" Text="سعر بيع: " /><Run FontWeight="SemiBold" Foreground="#1D4ED8" Text="{Binding Price1, StringFormat=\{0:N2\}, Mode=OneWay}" />
                                                            </TextBlock>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                        <Setter Property="Padding" Value="0" />
                                                        <EventSetter Event="PreviewMouseLeftButtonDown" Handler="SearchItem_Click" />
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="White" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>
                                <Grid Grid.Column="1" Margin="0,0,12,0">
                                    <TextBlock Margin="2,-16,0,0" FontSize="13" Foreground="White" Text="المخزن" />
                                    <ComboBox Padding="8,6" DisplayMemberPath="StoreName" FontSize="13"
                                              ItemsSource="{Binding Stores}"
                                              SelectedValue="{Binding CurrentSubItem.StoreId}"
                                              SelectedValuePath="StoreId" />
                                </Grid>
                                <Grid Grid.Column="2" Margin="0,0,12,0">
                                    <TextBlock Margin="2,-16,0,0" FontSize="13" Foreground="White" Text="الوحدة" />
                                    <ComboBox Padding="8,6" DisplayMemberPath="UnitName" FontSize="13"
                                              ItemsSource="{Binding CurrentItemUnits}"
                                              SelectedValue="{Binding CurrentSubItem.UnitId}"
                                              SelectedValuePath="UnitId" />
                                </Grid>
                                <Grid Grid.Column="3" Margin="0,0,12,0">
                                    <TextBlock Margin="2,-16,0,0" FontSize="13" Foreground="White" Text="الكمية" />
                                    <TextBox FontSize="13" Style="{StaticResource FormTextBox}" Text="{Binding SubItemQty, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                                <Grid Grid.Column="4" Margin="0,0,0,0">
                                    <TextBlock Margin="2,-16,0,0" FontSize="13" Foreground="White" Text="السعر" />
                                    <TextBox FontSize="13" Style="{StaticResource FormTextBox}" Text="{Binding SubItemPrice, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                                <Grid Grid.Column="5" Margin="0,0,12,0">
                                    <RadioButton Content="خصم %" Margin="2,-16,0,0" FontSize="13" Foreground="White" VerticalAlignment="Top" IsChecked="{Binding IsSubItemDiscountPer}" />
                                    <TextBox FontSize="13" Style="{StaticResource FormTextBox}" Text="{Binding SubItemDiscountPercent, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsSubItemDiscountPer}" />
                                </Grid>
                                <Grid Grid.Column="6" Margin="0,0,12,0">
                                    <RadioButton Content="خصم" Margin="2,-16,0,0" FontSize="13" Foreground="White" VerticalAlignment="Top" IsChecked="{Binding IsSubItemDiscountPer, Converter={StaticResource InverseBool}}" />
                                    <TextBox FontSize="13" Style="{StaticResource FormTextBox}" Text="{Binding SubItemDiscountValue, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsSubItemDiscountPer, Converter={StaticResource InverseBool}}" />
                                </Grid>
                                <Grid Grid.Column="7" Margin="0,0,12,0">
                                    <TextBlock Margin="2,-16,0,0" FontSize="13" Foreground="White" Text="اجمالي" />
                                    <TextBox Background="#F1F5F9" FontSize="13" FontWeight="Bold" Foreground="#DC2626" IsEnabled="False"
                                             Style="{StaticResource FormTextBox}"
                                             Text="{Binding SubItemTotal, Mode=OneWay, StringFormat=\{0:N2\}}" />
                                </Grid>
                                <Button Grid.Column="8" Padding="16,8"
                                        Command="{Binding AddSubItemCommand}"
                                        Content="➕ إضافة"
                                        Style="{StaticResource PrimaryButton}" />
                            </Grid>
                        </Border>

                        <!--  DataGrid SubItems  -->
                        <Border Grid.Row="4" MinHeight="100" MaxHeight="250" Margin="0,0,0,16" BorderBrush="#2F3549" BorderThickness="1" ClipToBounds="True" CornerRadius="12">
                            <DataGrid AlternatingRowBackground="#2F3549" AutoGenerateColumns="False" Background="#2F3549" BorderThickness="0" CanUserAddRows="False" CellEditEnding="DataGrid_CellEditEnding" ColumnHeaderHeight="44" FontSize="13"
                                      Foreground="#1E293B" GridLinesVisibility="Horizontal" HeadersVisibility="Column" HorizontalGridLinesBrush="#F1F5F9" IsReadOnly="False"
                                      ItemsSource="{Binding FormSubItems}"
                                      RowHeight="40"
                                      SelectedItem="{Binding SelectedSubItem, Mode=TwoWay}"
                                      SelectionMode="Single">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style BasedOn="{StaticResource DarkColumnHeader}" TargetType="DataGridColumnHeader" />
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.RowStyle>
                                    <Style BasedOn="{StaticResource DarkRow}" TargetType="DataGridRow" />
                                </DataGrid.RowStyle>
                                <DataGrid.CellStyle>
                                    <Style BasedOn="{StaticResource DarkCell}" TargetType="DataGridCell" />
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Width="2*" Header="الصنف" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Padding="4,0" VerticalAlignment="Center">
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="ItemId,ItemName">
                                                            <Binding Path="ItemId" />
                                                            <Binding Path="DataContext.Items" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="*" Header="المخزن" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Padding="4,0" VerticalAlignment="Center">
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="StoreId,StoreName">
                                                            <Binding Path="StoreId" />
                                                            <Binding Path="DataContext.Stores" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Width="80" Binding="{Binding Qty, UpdateSourceTrigger=PropertyChanged}" Header="الكمية" />
                                    <DataGridTextColumn Width="100" Binding="{Binding Price, UpdateSourceTrigger=PropertyChanged}" Header="السعر" />
                                    <DataGridTextColumn Width="80" Binding="{Binding Disc, UpdateSourceTrigger=PropertyChanged}" Header="الخصم" />
                                    <DataGridTextColumn Width="100"
                                                        Binding="{Binding Total, StringFormat=\{0:N2\}}"
                                                        FontWeight="SemiBold" Header="الإجمالي" IsReadOnly="True" />
                                    <DataGridTemplateColumn Width="50" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Background="Transparent" BorderThickness="0"
                                                        Command="{Binding DataContext.RemoveSubItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="🗑️" FontSize="14" Foreground="Red" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!--  Totals & Footer (Responsive Layout)  -->
                        <Border Grid.Row="5" Margin="0,0,0,24" Padding="20"
                                Background="{StaticResource SectionBg}"
                                BorderBrush="#2F3549" BorderThickness="1" CornerRadius="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <!--  separator  -->
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  Left Side: Net, Add, Discounts  -->
                                <WrapPanel Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Horizontal">
                                    <StackPanel Margin="0,0,24,12">
                                        <TextBlock Margin="0,0,0,4" FontSize="13" FontWeight="Bold" Foreground="#64748B" Text="صافي الفاتورة" />
                                        <TextBox MinWidth="110" HorizontalContentAlignment="Center" Background="#FFF9C4" FontSize="15" FontWeight="Bold" IsReadOnly="True"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding FormItem.Total, Mode=OneWay, StringFormat=\{0:N2\}}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,24,12">
                                        <TextBlock Margin="0,0,0,4" HorizontalAlignment="Center" FontSize="13" FontWeight="Bold" Foreground="#64748B" Text="اضافة" />
                                        <TextBox MinWidth="90" HorizontalContentAlignment="Center" FontSize="14"
                                                 IsEnabled="{Binding IsEditing}"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding FormItem.AddMony, UpdateSourceTrigger=PropertyChanged}"
                                                 TextChanged="Totals_TextChanged" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,28,8">
                                        <RadioButton Margin="0,0,0,4" FontSize="11" Foreground="#7B84A0" Content="خصم إجمالي (%)" IsChecked="{Binding IsInvoiceDiscountPer}" />
                                        <TextBox Width="70" Style="{StaticResource FormTextBox}" Text="{Binding DiscountPercentInput, UpdateSourceTrigger=PropertyChanged}" TextChanged="Totals_TextChanged" IsEnabled="{Binding IsInvoiceDiscountPer}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,24,8">
                                        <RadioButton Margin="0,0,0,4" FontSize="12" FontWeight="Bold" Foreground="#64748B" Content="خصم مبلغ" IsChecked="{Binding IsInvoiceDiscountPer, Converter={StaticResource InverseBool}}" />
                                        <TextBox MinWidth="80" FontSize="13"
                                                 IsEnabled="{Binding IsInvoiceDiscountPer, Converter={StaticResource InverseBool}}"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding DiscountValueInput, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}"
                                                 TextChanged="Totals_TextChanged" />
                                    </StackPanel>
                                </WrapPanel>

                                <!--  Right Side: Totals & Tax, only shown when Tax is visible or always shown?  -->
                                <!--  We will show it arranged like the image  -->
                                <Grid Grid.Column="2" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!--  Total Before Tax  -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,0,12" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="#7B84A0" Text="اجمالي الفاتورة" />
                                    <TextBox Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2" MinWidth="180" Margin="0,0,8,8" HorizontalContentAlignment="Center" Background="#FFF9C4" FontSize="15"
                                             FontWeight="Bold" IsReadOnly="True"
                                             Style="{StaticResource FormTextBox}"
                                             Text="{Binding NetBeforeTax, Mode=OneWay, StringFormat=\{0:N2\}}" />

                                    <!--  VAT  -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,0,8" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="#7B84A0" Text="ض القيمة المضافة"
                                               Visibility="{Binding FormItem.IsTax, Converter={StaticResource BoolToVis}}" />
                                    <StackPanel Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Margin="0,0,8,8" HorizontalAlignment="Right" Orientation="Horizontal"
                                                Visibility="{Binding FormItem.IsTax, Converter={StaticResource BoolToVis}}">
                                        <TextBox MinWidth="70" HorizontalContentAlignment="Center" FontSize="14"
                                                 IsEnabled="{Binding IsEditing}"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding VatTaxPercent, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox MinWidth="100" Margin="0,0,8,0" HorizontalContentAlignment="Center" Background="#FFF9C4" FontSize="14" FontWeight="SemiBold" IsReadOnly="True"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding FormItem.VatTax, Mode=OneWay, StringFormat=\{0:N2\}}" />
                                    </StackPanel>

                                    <!--  WHT  -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,0,8" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="#7B84A0" Text="ضريبة أ.ت.ص"
                                               Visibility="{Binding FormItem.IsTax, Converter={StaticResource BoolToVis}}" />
                                    <StackPanel Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Margin="0,0,8,8" HorizontalAlignment="Right" Orientation="Horizontal"
                                                Visibility="{Binding FormItem.IsTax, Converter={StaticResource BoolToVis}}">
                                        <TextBox MinWidth="70" HorizontalContentAlignment="Center" FontSize="14"
                                                 IsEnabled="{Binding IsEditing}"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding WhtTaxPercent, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox MinWidth="100" Margin="0,0,8,0" HorizontalContentAlignment="Center" Background="#FFF9C4" FontSize="14" FontWeight="SemiBold" IsReadOnly="True"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding FormItem.Tax, Mode=OneWay, StringFormat=\{0:N2\}}" />
                                    </StackPanel>

                                    <!--  Total After Tax  -->
                                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="#7B84A0" Text="اجمالي بعد الضريبة"
                                               Visibility="{Binding FormItem.IsTax, Converter={StaticResource BoolToVis}}" />
                                    <TextBox Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" MinWidth="180" Margin="0,0,8,0" HorizontalContentAlignment="Center" Background="#FFF9C4" FontSize="15"
                                             FontWeight="Bold" IsReadOnly="True"
                                             Style="{StaticResource FormTextBox}"
                                             Text="{Binding FormItem.Net, Mode=OneWay, StringFormat=\{0:N2\}}"
                                             Visibility="{Binding FormItem.IsTax, Converter={StaticResource BoolToVis}}" />
                                </Grid>
                            </Grid>
                        </Border>

                        <!--  Cash Mode Treasury Selector (Only visible in Cash mode)  -->
                        <Border Grid.Row="6" Margin="0,0,0,24" Padding="24" Background="#283830" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="12"
                                IsEnabled="{Binding IsEditing}"
                                Visibility="{Binding IsCashPaymentMode, Converter={StaticResource BoolToVis}}">
                            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                <TextBlock Margin="0,0,16,0" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="#065F46" Text="💳 اختر الخزينة التي سيتم إيداع المبلغ (كاش) فيها:" />
                                <ComboBox MinWidth="250" Padding="16,10" Background="White" BorderBrush="#34D399" BorderThickness="1" DisplayMemberPath="CashName" FontSize="15" FontWeight="SemiBold"
                                          ItemsSource="{Binding Cashes}"
                                          SelectedValue="{Binding SelectedCashId, UpdateSourceTrigger=PropertyChanged, FallbackValue=0}"
                                          SelectedValuePath="CashId" />
                                <TextBlock Margin="16,0,0,0" VerticalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="#047857"
                                           Text="{Binding CurrentSafeBalance, StringFormat='رصيد الخزينة: {0:N2}'}" />
                            </StackPanel>
                        </Border>

                        <!--  Payments Section Trigger Button (Only visible in Credit mode)  -->
                        <Border Grid.Row="7" Margin="0,0,0,20" Padding="18" Background="#272C3F" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="12"
                                IsEnabled="{Binding IsEditing}"
                                Visibility="{Binding IsCashPaymentMode, Converter={StaticResource InverseBoolToVis}}">
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                <TextBlock Margin="0,0,16,0" VerticalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="#ECEEF5" Text="💰 المدفوعات وتفاصيل السداد" />
                                <Button Padding="24,12" Command="{Binding OpenPaymentsPopupCommand}" Content="إدارة المدفوعات 💰" Style="{StaticResource PrimaryButton}" />
                                <StackPanel Margin="24,0,0,0" VerticalAlignment="Center" Orientation="Horizontal">
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#7B84A0" Text="إجمالي المدفوع: " />
                                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#5BAE7C" Text="{Binding TotalPayed, StringFormat=\{0:N2\}}" />
                                    <TextBlock Margin="16,0,0,0" FontSize="13" FontWeight="SemiBold" Foreground="#7B84A0" Text="الباقي: " />
                                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#EF4444" Text="{Binding Remaining, StringFormat=\{0:N2\}}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!--  Footer Action Buttons  -->
                        <DockPanel Grid.Row="8">
                            <TextBlock MaxWidth="300" Margin="0,0,16,0" HorizontalAlignment="Right" VerticalAlignment="Center" DockPanel.Dock="Right" FontSize="14" FontWeight="SemiBold" Foreground="#10B981"
                                       Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap" />
                            <WrapPanel MinHeight="45" HorizontalAlignment="Left" Orientation="Horizontal">
                                <Button Margin="0,0,12,12" Padding="16,10" Command="{Binding PrintInvoiceCommand}" Content="🖨️ طـبـاعـة الفاتورة">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource SecondaryButton}" TargetType="Button">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Setter Property="Background" Value="#3B82F6" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedInvoice}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Margin="0,0,12,12" Padding="16,10" Command="{Binding EditSelectedCommand}" Content="✏️ تـعـديـل الفاتورة">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource SecondaryButton}" TargetType="Button">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Setter Property="Background" Value="#F59E0B" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedInvoice}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Margin="0,0,12,12" Padding="16,10" Command="{Binding SaveCommand}" Content="💾 حـفـظ الفاتورة">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource PrimaryButton}" TargetType="Button">
                                            <Setter Property="Background" Value="#10B981" />
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Margin="0,0,16,12" Padding="16,10" Command="{Binding CancelEditCommand}" Content="✖ إلـغـاء">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource SecondaryButton}" TargetType="Button">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Margin="0,0,0,12" Padding="16,10" Command="{Binding DeleteCommand}" Content="🗑️ حـذف">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource DangerButton}" TargetType="Button">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedInvoice}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </WrapPanel>
                        </DockPanel>
                    </Grid>
                </Border>
            </ScrollViewer>
        </Grid>

        <!--  SEARCH Section  -->
        <Grid Margin="20" Style="{StaticResource SearchContainerStyle}">
            <Border Padding="24" Background="#272C3F" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="14">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" Direction="270" Opacity="0.04" ShadowDepth="4" Color="#0F172A" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,24">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <Border Margin="0,0,12,0" Padding="10" CornerRadius="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Offset="0" Color="#E8A54B" />
                                        <GradientStop Offset="1" Color="#D4922F" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock FontSize="20" Text="🔎" />
                            </Border>
                            <TextBlock VerticalAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="White" Text="البحث في فواتير المبيعات السابقة" />
                        </StackPanel>
                        <Button Padding="16,8" HorizontalAlignment="Right"
                                Command="{Binding HideSearchPanelCommand}"
                                Content="✖ الـرجـوع للـنمـوذج" DockPanel.Dock="Right"
                                Style="{StaticResource SecondaryButton}" />
                    </DockPanel>
                    <Border Grid.Row="1" Margin="0,0,0,24" Padding="16" Background="#3D4560" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="White" Text="كلمة البحث (رقم الفاتورة، اسم العميل):" />
                            <TextBox Grid.Column="1" MinWidth="200" MaxWidth="460" Padding="12,8" HorizontalAlignment="Left" Background="LightGray" FontSize="15"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Border>
                    <Border Grid.Row="2" Background="#242940" BorderBrush="#3D4560" BorderThickness="1" ClipToBounds="True" CornerRadius="12">
                        <DataGrid AlternatingRowBackground="#222738" AutoGenerateColumns="False" Background="#242940" BorderThickness="0" CanUserAddRows="False" ColumnHeaderHeight="50" FontSize="13" Foreground="#C8CEE0"
                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column" HorizontalGridLinesBrush="#323848" IsReadOnly="True"
                                  ItemsSource="{Binding FilteredInvoices}"
                                  RowHeight="46"
                                  SelectedItem="{Binding SelectedInvoice, Mode=TwoWay}"
                                  SelectionMode="Single">
                            <DataGrid.ColumnHeaderStyle>
                                <Style BasedOn="{StaticResource DarkColumnHeader}" TargetType="DataGridColumnHeader" />
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style BasedOn="{StaticResource DarkRow}" TargetType="DataGridRow" />
                            </DataGrid.RowStyle>
                            <DataGrid.CellStyle>
                                <Style BasedOn="{StaticResource DarkCell}" TargetType="DataGridCell" />
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Margin="8,6" Padding="4" Background="#10B981"
                                                    Command="{Binding DataContext.HideSearchPanelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    Content="✅ اختيار" FontSize="12" Foreground="White"
                                                    Style="{StaticResource PrimaryButton}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="100" Binding="{Binding SalesId}" Header="رقم الفاتورة" />
                                <DataGridTextColumn Width="100" Binding="{Binding SalesDate, StringFormat=\{0:yyyy/MM/dd\}}" Header="التاريخ" />
                                <DataGridTemplateColumn Width="200" Header="العميل">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Padding="4,0" VerticalAlignment="Center">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="CusId,CusName">
                                                        <Binding Path="CusId" />
                                                        <Binding Path="DataContext.Customers" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="150" Binding="{Binding Net, StringFormat=\{0:N2\}}" Header="الصافي" />
                                <DataGridTextColumn Width="*" Binding="{Binding Notes}" Header="الملاحظات" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!--  ████████ PAYMENTS POPUP OVERLAY ████████  -->
        <Grid Panel.ZIndex="100" Background="#B20F172A" Visibility="{Binding IsPaymentsPopupOpen, Converter={StaticResource BoolToVis}}">
            <Border Width="850" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#1E2233" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="32" Direction="270" Opacity="0.3" ShadowDepth="12" Color="#000000" />
                </Border.Effect>
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock VerticalAlignment="Center" DockPanel.Dock="Left" FontSize="20" FontWeight="Bold" Foreground="#ECEEF5" Text="💰 المدفوعات" />
                        <Button HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0"
                                Command="{Binding ClosePaymentsPopupCommand}"
                                Content="✖" Cursor="Hand" DockPanel.Dock="Right" FontSize="20" FontWeight="Bold" Foreground="#7B84A0" ToolTip="إغلاق" />
                    </DockPanel>

                    <!--  Quick Add Payment  -->
                    <Border Grid.Row="1" Margin="0,0,0,16" Padding="16" Background="#242940" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="110" />
                                <ColumnDefinition Width="*" MinWidth="90" />
                                <ColumnDefinition Width="*" MinWidth="200" />
                                <ColumnDefinition Width="2*" MinWidth="120" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Margin="0,0,0,6" FontSize="13" Foreground="#7B84A0" Text="التاريخ" />
                                <DatePicker Padding="10,6" Background="#161925" BorderBrush="#3D4560" BorderThickness="1" FontSize="14" Foreground="#ECEEF5"
                                            SelectedDate="{Binding CurrentPayment.PayDate}" IsEnabled="False" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Margin="0,0,0,6" FontSize="13" Foreground="#7B84A0" Text="المبلغ" />
                                <TextBox Background="#161925" BorderBrush="#3D4560" Foreground="#ECEEF5"
                                         Style="{StaticResource FormTextBox}"
                                         Text="{Binding CurrentPayment.PayMoney, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                <TextBlock Margin="0,0,0,6" FontSize="13" Foreground="#7B84A0" Text="الخزينة" />
                                <ComboBox Padding="10,6" Background="#161925" BorderBrush="#3D4560" DisplayMemberPath="CashName" FontSize="14" Foreground="#ECEEF5"
                                          ItemsSource="{Binding Cashes}"
                                          SelectedValue="{Binding SelectedCashId, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="CashId" />
                                <TextBlock Margin="0,4,0,4" FontSize="12" FontWeight="SemiBold" Foreground="#047857"
                                           Text="{Binding CurrentSafeBalance, StringFormat='رصيد الخزينة: {0:N2}'}" />
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="0,0,12,0">
                                <TextBlock Margin="0,0,0,6" FontSize="13" Foreground="#7B84A0" Text="ملاحظات" />
                                <TextBox Background="#161925" BorderBrush="#3D4560" Foreground="#ECEEF5"
                                         Style="{StaticResource FormTextBox}"
                                         Text="{Binding CurrentPayment.Notes, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <Button Grid.Column="4" Margin="0,22,0,0" Padding="20,10" VerticalAlignment="Bottom"
                                    Command="{Binding AddPaymentCommand}"
                                    Content="➕ إضافة دفعة"
                                    Style="{StaticResource PrimaryButton}" />
                        </Grid>
                    </Border>

                    <!--  Payments DataGrid  -->
                    <Border Grid.Row="2" MinHeight="150" MaxHeight="300" Background="#242940" BorderBrush="#3D4560" BorderThickness="1" ClipToBounds="True" CornerRadius="10">
                        <DataGrid AlternatingRowBackground="#222738" AutoGenerateColumns="False" Background="#242940" BorderThickness="0" CanUserAddRows="False" ColumnHeaderHeight="40" FontSize="13" Foreground="#C8CEE0"
                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column" HorizontalGridLinesBrush="#323848" IsReadOnly="False"
                                  ItemsSource="{Binding FormPayments}"
                                  RowHeight="36" SelectionMode="Single">
                            <DataGrid.ColumnHeaderStyle>
                                <Style BasedOn="{StaticResource DarkColumnHeader}" TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#1E2233" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding" Value="14,12" />
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style BasedOn="{StaticResource DarkRow}" TargetType="DataGridRow" />
                            </DataGrid.RowStyle>
                            <DataGrid.CellStyle>
                                <Style BasedOn="{StaticResource DarkCell}" TargetType="DataGridCell" />
                            </DataGrid.CellStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Width="120" Binding="{Binding PayDate, StringFormat=\{0:yyyy/MM/dd\}}" Header="التاريخ" IsReadOnly="True" />
                                <DataGridTextColumn Width="120" Binding="{Binding PayMoney, StringFormat=\{0:N2\}}" FontWeight="SemiBold" Header="المبلغ" />
                                <DataGridTemplateColumn Width="*" Header="الخزينة">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Padding="4,0" VerticalAlignment="Center">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="CashId,CashName">
                                                        <Binding Path="CashId" />
                                                        <Binding Path="DataContext.Cashes" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <ComboBox DisplayMemberPath="CashName" IsDropDownOpen="True"
                                                      ItemsSource="{Binding DataContext.Cashes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      SelectedValue="{Binding CashId, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="CashId" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="*" Binding="{Binding Notes}" Header="ملاحظات" />
                                <DataGridTemplateColumn Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Background="Transparent" BorderThickness="0"
                                                    Command="{Binding DataContext.RemovePaymentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Content="🗑️" FontSize="14" Foreground="#EF4444" ToolTip="حذف" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!--  Payment Totals  -->
                    <StackPanel Grid.Row="3" Margin="0,14,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
                        <Border Margin="0,0,24,0" Padding="16,10" Background="#283830" BorderBrush="#3D7A5A" BorderThickness="1" CornerRadius="8">
                            <StackPanel>
                                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#7B84A0" Text="إجمالي المدفوع" />
                                <TextBlock FontSize="18" FontWeight="Bold" Foreground="#5BAE7C" Text="{Binding TotalPayed, StringFormat=\{0:N2\}}" />
                            </StackPanel>
                        </Border>
                        <Border Padding="16,10" Background="#3D2929" BorderBrush="#7A3D3D" BorderThickness="1" CornerRadius="8">
                            <StackPanel>
                                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#7B84A0" Text="الباقي" />
                                <TextBlock FontSize="18" FontWeight="Bold" Foreground="#F87171" Text="{Binding Remaining, StringFormat=\{0:N2\}}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
