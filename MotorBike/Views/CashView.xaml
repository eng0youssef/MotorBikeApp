<UserControl x:Class="MotorBike.Views.CashView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d" xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:MotorBike.Converters"
             Loaded="OnLoaded" FlowDirection="RightToLeft">
    <UserControl.Resources>
        <conv:CashTypeConverter x:Key="TypeConverter" />
        <conv:HideZeroConverter x:Key="HideZeroConv"/>
    </UserControl.Resources>
    <Grid MinWidth="800" MinHeight="500" Background="#1E2233">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Search Bar  -->
        <Border Grid.Row="0" Margin="0,0,0,12" Padding="12,8" Background="#272C3F" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="10">
            <Border.Effect><DropShadowEffect BlurRadius="8" Direction="270" Opacity="0.04" ShadowDepth="2" Color="#0F172A" /></Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" FontSize="16" Text="🔍" />
                <TextBox Grid.Column="1" FontSize="14" Style="{StaticResource FormTextBox}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Tag="ابحث عن خزينة..." />
                <Button Grid.Column="2" Margin="8,0,0,0" Padding="8,4" VerticalAlignment="Center"
                        Command="{Binding ClearSearchCommand}" Content="✖" FontSize="12" Style="{StaticResource SecondaryButton}"
                        Visibility="{Binding SearchText, Converter={StaticResource StringToVisibilityConverter}}" />
            </Grid>
        </Border>
        <Border Grid.Row="1" Background="#242940" CornerRadius="12" Margin="0,0,0,16" BorderBrush="#3D4560" BorderThickness="1" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" Direction="270" Opacity="0.08" ShadowDepth="4" Color="#000000" />
            </Border.Effect>
            <DataGrid ItemsSource="{Binding FilteredItems}" SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column" BorderThickness="0" RowHeight="44"
                      ColumnHeaderHeight="48" AlternatingRowBackground="#222738" Background="#242940" Foreground="#C8CEE0" FontSize="13" HorizontalGridLinesBrush="#323848">
                <DataGrid.ColumnHeaderStyle>
                    <Style BasedOn="{StaticResource DarkColumnHeader}" TargetType="DataGridColumnHeader" />
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style BasedOn="{StaticResource DarkRow}" TargetType="DataGridRow" />
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <Style BasedOn="{StaticResource DarkCell}" TargetType="DataGridCell" />
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="الكود" Binding="{Binding CashId}" Width="100"/>
                    <DataGridTextColumn Header="اسم الخزينة" Binding="{Binding CashName}" Width="*"/>
                    <DataGridTextColumn Header="النوع" Binding="{Binding TypeId, Converter={StaticResource TypeConverter}}" Width="100"/>
                    <DataGridTextColumn Header="مدين" Binding="{Binding Debit}" Width="120"/>
                    <DataGridTextColumn Header="دائن" Binding="{Binding Credit}" Width="120"/>
                    <DataGridTextColumn Header="الرصيد" Binding="{Binding Bal}" Width="120"/>
                    <DataGridTemplateColumn Header="نشط" Width="100"><DataGridTemplateColumn.CellTemplate><DataTemplate><CheckBox IsChecked="{Binding Active, Mode=OneWay}" Style="{StaticResource ToggleSwitchStyle}" IsEnabled="False" HorizontalAlignment="Center"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        <Border Grid.Row="2" Background="#272C3F" CornerRadius="12" Padding="24" BorderBrush="#3D4560" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" Direction="270" Opacity="0.08" ShadowDepth="6" Color="#000000" />
            </Border.Effect>
            <StackPanel>
                <Grid Margin="0,0,0,24" IsEnabled="{Binding IsEditing}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition/><RowDefinition Height="16"/><RowDefinition/><RowDefinition Height="16"/><RowDefinition/><RowDefinition Height="16"/><RowDefinition/></Grid.RowDefinitions>

                    <!-- Row 0 -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="الكود" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding FormItem.CashId , Converter={StaticResource HideZeroConv}}" Style="{StaticResource FormTextBox}" IsReadOnly="True"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="اسم الخزينة" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding FormItem.CashName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                    <TextBlock Grid.Row="0" Grid.Column="6" Text="النوع" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="0" Grid.Column="7" x:Name="CashTypeCombo" SelectionChanged="CashTypeChanged" Padding="10,8" FontSize="14" BorderBrush="#CBD5E1" FocusVisualStyle="{x:Null}">
                        <ComboBoxItem Content="خزينة"/><ComboBoxItem Content="بنك"/>
                    </ComboBox>
                    <CheckBox Style="{StaticResource ToggleSwitchStyle}" Grid.Row="0" Grid.Column="9" Content="نشط" IsChecked="{Binding FormItem.Active}" VerticalAlignment="Center" FontSize="14"/>

                    <!-- Row 2 -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="العملة" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding Currencies}" SelectedValuePath="OmlaId" DisplayMemberPath="OmlaName"
                              SelectedValue="{Binding FormItem.OmlaId, Mode=TwoWay}" Padding="10,8" FontSize="14" BorderBrush="#CBD5E1" FocusVisualStyle="{x:Null}" SelectionChanged="CurrencyChanged"/>
                    <TextBlock Grid.Row="2" Grid.Column="3" Text="سعر الصرف" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="2" Grid.Column="4" Text="{Binding FormItem.OmlaRate, UpdateSourceTrigger=PropertyChanged}" x:Name="txtOmlaRate" Style="{StaticResource FormTextBox}"/>

                    <!-- Row 4: Financials -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="مدين" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding FormItem.Debit, UpdateSourceTrigger=PropertyChanged}" x:Name="txtDebit" TextChanged="CalculateBalance" Style="{StaticResource FormTextBox}"/>
                    <TextBlock Grid.Row="4" Grid.Column="3" Text="دائن" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="4" Grid.Column="4" Text="{Binding FormItem.Credit, UpdateSourceTrigger=PropertyChanged}" x:Name="txtCredit" TextChanged="CalculateBalance" Style="{StaticResource FormTextBox}"/>
                    <TextBlock Grid.Row="4" Grid.Column="6" Text="الرصيد" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="4" Grid.Column="7" Text="{Binding FormItem.Bal, Mode=TwoWay}" x:Name="txtBal" IsReadOnly="True" Background="#F1F5F9" Style="{StaticResource FormTextBox}"/>

                    <!-- Row 6 -->
                    <TextBlock Grid.Row="6" Grid.Column="0" Text="ملاحظات" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="7" Text="{Binding FormItem.Notes, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                </Grid>
                <DockPanel Margin="0,8,0,0">
                    <WrapPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Button Content="➕ جديد" Style="{StaticResource PrimaryButton}" Margin="0,0,8,8" Command="{Binding AddNewCommand}"/>
                        <Button Content="✏️ تعديل" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8" Command="{Binding EditSelectedCommand}"/>
                        <Button Content="💾 حفظ" Style="{StaticResource PrimaryButton}" Margin="0,0,8,8" Command="{Binding SaveCommand}" IsEnabled="{Binding IsEditing}"/>
                        <Button Content="🗑️ حذف" Style="{StaticResource DangerButton}" Margin="0,0,8,8" Command="{Binding DeleteCommand}"/>
                        <Button Content="✖ إلغاء" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8" Command="{Binding CancelEditCommand}" IsEnabled="{Binding IsEditing}"/>
                    </WrapPanel>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#5BAE7C" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="24,0,0,0"/>
                </DockPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
