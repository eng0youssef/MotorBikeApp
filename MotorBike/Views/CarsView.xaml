<UserControl x:Class="MotorBike.Views.CarsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MotorBike.Converters"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Loaded="OnLoaded" FlowDirection="RightToLeft">

    <UserControl.Resources>
        <conv:IdToNameConverter x:Key="IdToNameConverter"/>
    </UserControl.Resources>

    <Grid Background="#2F3549" MinWidth="800" MinHeight="500">
        <Border Background="#2F3549"  CornerRadius="16" Margin="24"
                BorderBrush="#2F3549" BorderThickness="1" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect Color="#0F172A" Opacity="0.04"
                                  BlurRadius="24" ShadowDepth="4" Direction="270"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- header / search bar -->
                    <RowDefinition Height="Auto"/>
                    <!-- separator -->
                    <RowDefinition Height="*"/>
                    <!-- DataGrid -->
                    <RowDefinition Height="Auto"/>
                    <!-- status strip -->
                </Grid.RowDefinitions>

                <!-- ═══ HEADER ══════════════════════════════════════════════ -->
                <Grid Grid.Row="0" Margin="24,20,24,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icon + title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border  CornerRadius="12"
                                Padding="14,12" Margin="0,0,16,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Offset="0" Color="#E8A54B" />
                                    <GradientStop Offset="1" Color="#D4922F" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="🏍️" FontSize="26"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="قائمة الموتوسيكلات"
                                       
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="{Binding FilteredCars.Count,
                                               StringFormat='إجمالي \{0\} موتوسيكل في النتائج'}"
                                       FontSize="13" Foreground="LightGray"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Filter and Search -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="الحالة:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <ComboBox Width="140" Margin="0,0,16,0" 
                                  SelectedIndex="{Binding ActiveFilter}"
                                  Padding="8,6" VerticalAlignment="Center"
                                  Background="White">
                            <ComboBoxItem Content="الكل" FontWeight="SemiBold"/>
                            <ComboBoxItem Content="في المخزن" Foreground="#10B981" FontWeight="Bold"/>
                            <ComboBoxItem Content="مباع لعميل" Foreground="#EF4444" FontWeight="Bold"/>
                            <ComboBoxItem Content="صيانة خارجية" Foreground="#F59E0B" FontWeight="Bold"/>
                        </ComboBox>

                        <Border Background="LightGray"
                                CornerRadius="10" BorderBrush="#E2E8F0"
                                BorderThickness="1" Padding="12,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🔍" FontSize="15"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0" Foreground="#94A3B8"/>
                                <TextBox Width="300"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0" Background="Transparent"
                                         FontSize="14" Foreground="#1E293B"
                                         VerticalAlignment="Center" Padding="0,8">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Grid>
                                                            <TextBlock Text="ابحث..."
                                                                       Foreground="#CBD5E1" FontSize="13"
                                                                       VerticalAlignment="Center"
                                                                       Margin="2,0,0,0">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Separator -->
                <Rectangle Grid.Row="1" Height="1" Fill="#E2E8F0"/>

                <!-- ═══ DATA GRID ════════════════════════════════════════════ -->
                <DataGrid Grid.Row="2"
                          BorderBrush="#E2E8F0"
                          ItemsSource="{Binding FilteredCars}"
                          SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          BorderThickness="0" RowHeight="46"
                          ColumnHeaderHeight="50"
                          Background="#2F3549" Foreground="#1E293B"
                          FontSize="14" HorizontalGridLinesBrush="#F1F5F9">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"   Value="#2F3549"/>
                            <Setter Property="Foreground"   Value="White"/>
                            <Setter Property="FontWeight"   Value="SemiBold"/>
                            <Setter Property="Padding"      Value="16,12"/>
                            <Setter Property="BorderBrush"  Value="#E2E8F0"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="#2F3549"/>
                            <!-- normal row -->
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Cursor" Value="Hand"/>

                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1E40AF"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>

                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3B425A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="كود"
                                            Binding="{Binding CarId}"
                                            Width="70"/>

                        <DataGridTemplateColumn Header="الطراز" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center" Padding="6,0">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource IdToNameConverter}"
                                                          ConverterParameter="ModelId,ModelName">
                                                <Binding Path="ModelId"/>
                                                <Binding Path="DataContext.CarModels"                                                       
                                                         RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="السنة"
                                            Binding="{Binding YearNo}"
                                            Width="70"/>

                        <DataGridTextColumn Header="الشاسيه"
                                            Binding="{Binding ChassisNo}"
                                            Width="130"/>

                        <DataGridTextColumn Header="الموتور"
                                            Binding="{Binding MotorNo}"
                                            Width="130"/>

                        <DataGridTextColumn Header="اللوحة"
                                            Binding="{Binding PlateNo}"
                                            Width="100"/>

                        <DataGridTemplateColumn Header="اللون" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center" Padding="6,0">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource IdToNameConverter}"
                                                          ConverterParameter="ColorId,ColorName">
                                                <Binding Path="ColorId"/>
                                                <Binding Path="DataContext.Colors"
                                                         RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- المالك -->
                        <DataGridTemplateColumn Header="المالك" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center" Padding="6,0">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource IdToNameConverter}"
                                                          ConverterParameter="CusId,CusName">
                                                <Binding Path="OwnerId"/>
                                                <Binding Path="DataContext.Customers"
                                                         RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- سعر الشراء -->
                        <DataGridTextColumn Header="سعر الشراء"
                                            Binding="{Binding PurchasePrice, StringFormat=\{0:N2\}}"
                                            Width="110"/>

                        <!-- الحالة -->
                        <DataGridTemplateColumn Header="الحالة" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="6,3" HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#6B7280"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusId}" Value="1">
                                                        <Setter Property="Background" Value="#059669"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusId}" Value="2">
                                                        <Setter Property="Background" Value="#DC2626"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusId}" Value="3">
                                                        <Setter Property="Background" Value="#D97706"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Foreground="White" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="—"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatusId}" Value="1">
                                                            <Setter Property="Text" Value="مخزن"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusId}" Value="2">
                                                            <Setter Property="Text" Value="مباع"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusId}" Value="3">
                                                            <Setter Property="Text" Value="صيانة"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="ملاحظات"
                                            Binding="{Binding Notes}"
                                            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- ═══ STATUS STRIP ════════════════════════════════════════ -->
                <Border Grid.Row="3" Background="#2F3549"
                        BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                        Padding="24,10">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="#10B981" FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
