<UserControl x:Class="MotorBike.Views.SalesReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Background="#F8FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Status Message -->
        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Foreground="#6366F1" FontSize="14" FontWeight="SemiBold" Margin="25,0,25,5"/>

        <!-- Filters Section -->
        <Border Grid.Row="0" Margin="20" Background="White" CornerRadius="12" Padding="20">
            <Border.Effect>
                <DropShadowEffect Color="#0F172A" Opacity="0.05" BlurRadius="10" ShadowDepth="2" Direction="270"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,20,15">
                    <TextBlock Text="نوع التقرير" Foreground="#64748B" FontSize="13" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding ReportTypes}" 
                              SelectedItem="{Binding SelectedReportType}" 
                              Width="220" Padding="8" FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,20,15">
                    <TextBlock Text="من تاريخ" Foreground="#64748B" FontSize="13" Margin="0,0,0,4"/>
                    <DatePicker SelectedDate="{Binding FromDate}" Width="150" Padding="6" FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,20,15">
                    <TextBlock Text="إلى تاريخ" Foreground="#64748B" FontSize="13" Margin="0,0,0,4"/>
                    <DatePicker SelectedDate="{Binding ToDate}" Width="150" Padding="6" FontSize="14"/>
                </StackPanel>

                <!-- Dynamic elements based on selection -->
                <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,20,15" Visibility="{Binding IsCustomerVisible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="اختيار العميل" Foreground="#64748B" FontSize="13" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Customers}" 
                              SelectedItem="{Binding SelectedCustomer}" 
                              DisplayMemberPath="CusName" 
                              Width="200" Padding="8" FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,20,15" Visibility="{Binding IsItemVisible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="اختيار الصنف" Foreground="#64748B" FontSize="13" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Items}" 
                              SelectedItem="{Binding SelectedItem}" 
                              DisplayMemberPath="ItemName" 
                              Width="200" Padding="8" FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.ColumnSpan="5" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="🔍 بحث" Command="{Binding GenerateReportCommand}" 
                            Width="120" Height="40" Background="#3B82F6" Foreground="White" 
                            FontSize="15" FontWeight="SemiBold" BorderThickness="0" Margin="10,0,0,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="🖨️ طباعة التقرير" Command="{Binding PrintPdfCommand}" 
                            Width="140" Height="40" Background="#10B981" Foreground="White" 
                            FontSize="15" FontWeight="SemiBold" BorderThickness="0" Margin="10,0,0,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="📄 تصدير PDF" Command="{Binding ExportPdfCommand}" 
                            Width="140" Height="40" Background="#F59E0B" Foreground="White" 
                            FontSize="15" FontWeight="SemiBold" BorderThickness="0" Margin="10,0,0,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Data Grid -->
        <Border Grid.Row="2" Margin="20,0,20,20" Background="White" CornerRadius="12" Padding="15">
            <Border.Effect>
                <DropShadowEffect Color="#0F172A" Opacity="0.05" BlurRadius="10" ShadowDepth="2" Direction="270"/>
            </Border.Effect>
            <!-- AutoGenerateColumns=True is perfect here because we generate dynamic dynamic shape data per report type -->
            <DataGrid ItemsSource="{Binding ReportData}" 
                      AutoGenerateColumns="True"
                      IsReadOnly="True" 
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#E2E8F0"
                      BorderThickness="0"
                      Background="White"
                      RowBackground="White"
                      AlternatingRowBackground="#F8FAFC">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F1F5F9"/>
                        <Setter Property="Foreground" Value="#334155"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="12,10"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="12,10"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E0E7FF"/>
                                <Setter Property="Foreground" Value="#1E293B"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
