<UserControl x:Class="MotorBike.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MotorBike.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
             mc:Ignorable="d"
             FlowDirection="RightToLeft"
             Background="#1E2233">

    <UserControl.Resources>

        <!-- Label Style -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9CA3C2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="SettingsTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#252A3C"/>
            <Setter Property="Foreground" Value="#ECEEF5"/>
            <Setter Property="BorderBrush" Value="#3A4060"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="CaretBrush" Value="#E8A54B"/>
            <Setter Property="SelectionBrush" Value="#E8A54B"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#E8A54B"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#5A6080"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#E8A54B"/>
            <Setter Property="Foreground" Value="#1A1E2C"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="22,11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F0B65A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D4923C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#3A4060"/>
                                <Setter Property="Foreground" Value="#6B7490"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3C2"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#3A4060"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A3050"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#5A6080"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E2435"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Test / Green Button -->
        <Style x:Key="TestBtn" TargetType="Button" BasedOn="{StaticResource SecondaryBtn}">
            <Setter Property="Foreground" Value="#4ADE80"/>
            <Setter Property="BorderBrush" Value="#2E5040"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A3028"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4ADE80"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#1A2030"/>
                                <Setter Property="Foreground" Value="#3A5048"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══ Header Banner ══ -->
            <Border Grid.Row="0" Padding="40,32,40,28" Background="#222738"
                    BorderBrush="#323848" BorderThickness="0,0,0,1">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="44" Height="44" CornerRadius="12"
                                Background="#2A2F45" Margin="0,0,14,0">
                            <TextBlock Text="⚙️" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="الإعدادات" FontSize="22" FontWeight="Bold" Foreground="#ECEEF5"/>
                            <TextBlock Text="إدارة اتصال قاعدة البيانات والإعدادات العامة"
                                       FontSize="12" Foreground="#6B7490" Margin="0,3,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ══ Content ══ -->
            <StackPanel Grid.Row="1" Margin="40,32,40,40" MaxWidth="860" HorizontalAlignment="Center">

                <!-- Card: Connection String -->
                <Border Background="#222738" CornerRadius="14" Padding="32,28"
                        BorderBrush="#323848" BorderThickness="1" Margin="0,0,0,24">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="20" ShadowDepth="4"/>
                    </Border.Effect>
                    <StackPanel>

                        <!-- Card Title -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Width="4" Height="22" CornerRadius="2" Background="#E8A54B" Margin="0,0,12,0"/>
                            <TextBlock Text="إعدادات الاتصال بقاعدة البيانات"
                                       FontSize="15" FontWeight="Bold" Foreground="#ECEEF5"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Field Label -->
                        <TextBlock Text="نص الاتصال (Connection String)" Style="{StaticResource FieldLabel}"/>

                        <!-- TextBox -->
                        <TextBox x:Name="ConnStringBox"
                                 Text="{Binding ConnectionString, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SettingsTextBox}"
                                 Height="80"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="False"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,8"/>

                        <!-- Separator -->
                        <Border Height="1" Background="#2A3050" Margin="0,0,0,22"/>

                        <!-- Buttons Row -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">

                            <!-- Save -->
                            <Button Command="{Binding SaveCommand}" Margin="0,0,10,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
                                        <Setter Property="Content" Value="💾  حفظ وتشفير"/>
                                        <Setter Property="IsEnabled" Value="True"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSaving}" Value="True">
                                                <Setter Property="Content" Value="⏳  جاري الحفظ..."/>
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- Test -->
                            <Button Command="{Binding TestConnectionCommand}" Margin="0,0,10,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource TestBtn}">
                                        <Setter Property="Content" Value="🔌  اختبار الاتصال"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTesting}" Value="True">
                                                <Setter Property="Content" Value="⏳  جاري الاختبار..."/>
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- Reset -->
                            <Button Content="↩️  استعادة"
                                    Style="{StaticResource SecondaryBtn}"
                                    Command="{Binding ResetCommand}"/>

                        </StackPanel>

                        <!-- Status Message -->
                        <Border Margin="0,18,0,0"
                                Padding="16,12" CornerRadius="8"
                                Visibility="{Binding IsStatusVisible, Converter={StaticResource BoolToVis}}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStatusSuccess}" Value="True">
                                            <Setter Property="Background" Value="#1A3028"/>
                                            <Setter Property="BorderBrush" Value="#2E5040"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsStatusSuccess}" Value="False">
                                            <Setter Property="Background" Value="#321820"/>
                                            <Setter Property="BorderBrush" Value="#5A2030"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap"
                                       FontSize="13" LineHeight="20">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStatusSuccess}" Value="True">
                                                <Setter Property="Foreground" Value="#4ADE80"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsStatusSuccess}" Value="False">
                                                <Setter Property="Foreground" Value="#F87171"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
