<UserControl x:Class="MotorBike.Views.BuysView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:conv="clr-namespace:MotorBike.Converters" FlowDirection="RightToLeft" Loaded="OnLoaded">
    <UserControl.Resources>
        <conv:HideZeroConverter x:Key="HideZeroConv" />
        <conv:IdToNameConverter x:Key="IdToNameConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolConverter x:Key="InverseBool" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />

        <!--  Card style  -->
        <Style x:Key="FormCard" TargetType="Border">
            <Setter Property="Background" Value="#272C3F" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#3D4560" />
            <Setter Property="Margin" Value="20" />
            <Setter Property="Padding" Value="28" />
        </Style>

        <Style x:Key="FormContainerStyle" TargetType="Grid">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="False">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SearchContainerStyle" TargetType="Grid">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!--  Floating label  -->
        <Style x:Key="FloatingLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Margin" Value="4,-14,0,0" />
        </Style>

        <!--  Dark Column Header  -->
        <Style x:Key="DarkColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2A3040" />
            <Setter Property="Foreground" Value="#9BA4B5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="BorderBrush" Value="#3D4560" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <!--  Dark Row  -->
        <Style x:Key="DarkRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#C8CEE0" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#323F58" />
                    <Setter Property="Foreground" Value="#E8A54B" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A3040" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  Dark Cell  -->
        <Style x:Key="DarkCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Foreground" Value="#C8CEE0" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="#E8A54B" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  Section surface  -->
        <SolidColorBrush x:Key="SectionBg" Color="#2F3549" />
        <SolidColorBrush x:Key="SectionBorder" Color="#3D4560" />

    </UserControl.Resources>

    <Grid MinWidth="900" MinHeight="600" Background="#1E2233">

        <!--  ████████ FORM Section ████████  -->
        <Grid Style="{StaticResource FormContainerStyle}">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" ScrollChanged="ScrollViewer_ScrollChanged" VerticalScrollBarVisibility="Auto">
                <Border Style="{StaticResource FormCard}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="24" Direction="270" Opacity="0.08" ShadowDepth="6" Color="#000000" />
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <!--  Header  -->
                            <RowDefinition Height="Auto" />
                            <!--  Separator  -->
                            <RowDefinition Height="Auto" />
                            <!--  Main Info  -->
                            <RowDefinition Height="Auto" />
                            <!--  Smart Item Search & Add  -->
                            <RowDefinition Height="Auto" />
                            <!--  DataGrid SubItems  -->
                            <RowDefinition Height="Auto" />
                            <!--  Totals & Footer  -->
                            <RowDefinition Height="Auto" />
                            <!--  Cash Mode Treasury  -->
                            <RowDefinition Height="Auto" />
                            <!--  Payments Section  -->
                            <RowDefinition Height="Auto" />
                            <!--  Actions  -->
                        </Grid.RowDefinitions>

                        <!--  ══════ HEADER ══════  -->
                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Border Width="48" Height="48" Margin="0,0,14,0" CornerRadius="12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Offset="0" Color="#E8A54B" />
                                            <GradientStop Offset="1" Color="#D4922F" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" Text="📄" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock FontSize="20" FontWeight="Bold" Foreground="#ECEEF5" Text="فاتورة الشراء" />
                                    <TextBlock Margin="0,3,0,0" FontSize="12" Foreground="#7B84A0" Text="سجل فاتورة شراء جديدة أو استعلم عن فواتير سابقة" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                                <Button Margin="0,0,10,0" Padding="16,10"
                                        Command="{Binding ShowSearchPanelCommand}"
                                        Content="🔍 بحث عن فاتورة"
                                        Style="{StaticResource SecondaryButton}" />
                                <Button Padding="16,10" Command="{Binding AddNewCommand}" Content="➕ فاتورة جديدة" Style="{StaticResource PrimaryButton}" />
                            </StackPanel>
                        </Grid>

                        <!--  Gradient separator  -->
                        <Border Grid.Row="1" Height="1" Margin="0,4,0,20">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Offset="0" Color="#E8A54B" />
                                    <GradientStop Offset="0.35" Color="#3D4560" />
                                    <GradientStop Offset="1" Color="#3D4560" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <!--  ══════ MAIN INFO FORM ══════  -->
                        <Grid Grid.Row="2" IsEnabled="{Binding IsEditing}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="85" />
                                <ColumnDefinition Width="*" MinWidth="120" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="Auto" MinWidth="65" />
                                <ColumnDefinition Width="*" MinWidth="120" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="Auto" MinWidth="65" />
                                <ColumnDefinition Width="*" MinWidth="120" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="14" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Row 0: ID, Date, Supplier  -->
                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="رقم الفاتورة" />
                            <TextBox Grid.Row="0" Grid.Column="1" FontWeight="SemiBold" Foreground="#E8A54B" IsReadOnly="True"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding FormItem.BuyId, Converter={StaticResource HideZeroConv}}" />

                            <TextBlock Grid.Row="0" Grid.Column="3" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="التاريخ" />
                            <DatePicker Grid.Row="0" Grid.Column="4" SelectedDate="{Binding FormItem.BuyDate, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="0" Grid.Column="6" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="المورد" />
                            <!--  Supplier Smart Search  -->
                            <StackPanel Grid.Row="0" Grid.Column="7" VerticalAlignment="Center">
                                <Grid>
                                    <TextBox x:Name="SupplierSearchBox" Padding="8,6" GotFocus="SupplierSearch_GotFocus"
                                             Style="{StaticResource FormTextBox}"
                                             Text="{Binding SupplierSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="ابحث عن المورد بالاسم" />
                                    <Popup x:Name="SupplierSearchPopup"
                                           Width="{Binding ActualWidth, ElementName=SupplierSearchBox}"
                                           AllowsTransparency="True"
                                           IsOpen="{Binding IsSupplierSearchPopupOpen}"
                                           Placement="Bottom"
                                           PlacementTarget="{Binding ElementName=SupplierSearchBox}"
                                           StaysOpen="False">
                                        <Border MaxHeight="250" Background="#2F3549" BorderBrush="#4A5270" BorderThickness="1" CornerRadius="10">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="16" Direction="270" Opacity="0.2" ShadowDepth="4" Color="#000000" />
                                            </Border.Effect>
                                            <ListBox Background="Transparent" BorderThickness="0" ItemsSource="{Binding FilteredSuppliersList}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="10,8" Cursor="Hand">
                                                            <TextBlock FontSize="13" Foreground="#C8CEE0">
                                                                <Run Text="{Binding SuppName, Mode=OneWay}" />
                                                            </TextBlock>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                        <Setter Property="Padding" Value="0" />
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <EventSetter Event="PreviewMouseLeftButtonDown" Handler="SearchSupplier_Click" />
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#323F58" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>
                                <TextBlock Margin="0,4,0,0" FontSize="12" FontWeight="SemiBold" Foreground="#E8A54B"
                                           Text="{Binding CurrentSupplierBalance, StringFormat='الرصيد الحالي: {0:N2}'}" />
                            </StackPanel>

                            <!--  Row 2: Notes + Payment Toggle  -->
                            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="ملاحظات" />
                            <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding FormItem.Notes, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="2" Grid.Column="6" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="طريقة السداد" />
                            <!--  Toggle: أجل / كاش  -->
                            <ToggleButton Grid.Row="2" Grid.Column="7" Height="38" HorizontalAlignment="Stretch" VerticalAlignment="Center" Checked="IsCash_Changed" Cursor="Hand"
                                          IsChecked="{Binding FormItem.IsCash, UpdateSourceTrigger=PropertyChanged}"
                                          Unchecked="IsCash_Changed">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="TrackBorder" Height="38" Background="#2F3549" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="19">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border x:Name="SliderHighlight" Grid.Column="1" Margin="3" Background="#5BAE7C" CornerRadius="16">
                                                    <Border.RenderTransform>
                                                        <TranslateTransform x:Name="SliderTranslate" X="0" />
                                                    </Border.RenderTransform>
                                                </Border>
                                                <TextBlock x:Name="LabelRight" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="#6B7490" Text="أجل" />
                                                <TextBlock x:Name="LabelLeft" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="White" Text="كاش" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="False">
                                                <Setter TargetName="SliderHighlight" Property="Grid.Column" Value="0" />
                                                <Setter TargetName="SliderHighlight" Property="Background" Value="#E8A54B" />
                                                <Setter TargetName="LabelRight" Property="Foreground" Value="White" />
                                                <Setter TargetName="LabelLeft" Property="Foreground" Value="White" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TrackBorder" Property="BorderBrush" Value="#E8A54B" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                        </Grid>

                        <!--  ══════ QUICK ADD ITEM BAR ══════  -->
                        <Border Grid.Row="3" Margin="0,22,0,16" Padding="16,18,16,14"
                                Background="{StaticResource SectionBg}"
                                BorderBrush="{StaticResource SectionBorder}"
                                BorderThickness="1" CornerRadius="12"
                                IsEnabled="{Binding IsEditing}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" MinWidth="120" />
                                    <ColumnDefinition Width="*" MinWidth="80" />
                                    <ColumnDefinition Width="0.9*" MinWidth="70" />
                                    <ColumnDefinition Width="0.7*" MinWidth="60" />
                                    <ColumnDefinition Width="0.8*" MinWidth="70" />
                                    <ColumnDefinition Width="0.8*" MinWidth="70" />
                                    <ColumnDefinition Width="0.8*" MinWidth="70" />
                                    <ColumnDefinition Width="0.9*" MinWidth="70" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Margin="2,-16,0,0" FontSize="13" Foreground="White" Text="بحث الصنف" />
                                    <TextBox x:Name="ItemSearchBox" Padding="8,6" GotFocus="ItemSearch_GotFocus"
                                             Style="{StaticResource FormTextBox}"
                                             Text="{Binding ItemSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="ابحث هنا عن الأصناف" />
                                    <Popup x:Name="ItemSearchPopup"
                                           Width="{Binding ActualWidth, ElementName=ItemSearchBox}"
                                           AllowsTransparency="True"
                                           IsOpen="{Binding IsItemSearchPopupOpen}"
                                           Placement="Bottom"
                                           PlacementTarget="{Binding ElementName=ItemSearchBox}"
                                           StaysOpen="False">
                                        <Border MaxHeight="250" Background="#2F3549" BorderBrush="#4A5270" BorderThickness="1" CornerRadius="10">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="16" Direction="270" Opacity="0.2" ShadowDepth="4" Color="#000000" />
                                            </Border.Effect>
                                            <ListBox Background="Transparent" BorderThickness="0" ItemsSource="{Binding FilteredItemsList}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="10,8" Cursor="Hand">
                                                            <TextBlock FontSize="13" Foreground="#C8CEE0">
                                                                <Run Text="{Binding ItemName, Mode=OneWay}" /><Run Foreground="#6B7490" Text=" — " /><Run FontSize="11" Foreground="#7B84A0" Text="سعر شراء: " /><Run FontWeight="SemiBold" Foreground="#E8A54B" Text="{Binding Price0, StringFormat=\{0:N2\}, Mode=OneWay}" />
                                                            </TextBlock>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                        <Setter Property="Padding" Value="0" />
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <EventSetter Event="PreviewMouseLeftButtonDown" Handler="SearchItem_Click" />
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#323F58" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>

                                <Grid Grid.Column="1" Margin="0,0,10,0">
                                    <TextBlock Margin="2,-16,0,0" FontSize="13" Foreground="#fff" Text="المخزن" />
                                    <ComboBox DisplayMemberPath="StoreName" ItemsSource="{Binding Stores}" SelectedValue="{Binding CurrentSubItem.StoreId, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="StoreId" />
                                </Grid>

                                <Grid Grid.Column="2" Margin="0,0,10,0">
                                    <TextBlock Margin="2,-16,0,0" FontSize="13" Foreground="#fff" Text="الوحدة" />
                                    <ComboBox DisplayMemberPath="UnitName" ItemsSource="{Binding CurrentItemUnits}" SelectedValue="{Binding SubItemUnitId, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="UnitId" />
                                </Grid>

                                <Grid Grid.Column="3" Margin="0,0,10,0">
                                    <TextBlock Margin="2,-16,0,0" FontSize="13" Foreground="#fff" Text="الكمية" />
                                    <TextBox Style="{StaticResource FormTextBox}" Text="{Binding SubItemQty, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <Grid Grid.Column="4" Margin="0,0,10,0">
                                    <TextBlock Margin="2,-16,0,0" FontSize="13" Foreground="#fff" Text="السعر" />
                                    <TextBox Style="{StaticResource FormTextBox}" Text="{Binding SubItemPrice, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <Grid Grid.Column="5" Margin="0,0,10,0">
                                    <RadioButton Content="خصم %" Margin="2,-16,0,0" FontSize="13" Foreground="#fff" VerticalAlignment="Top" IsChecked="{Binding IsSubItemDiscountPer}" />
                                    <TextBox Style="{StaticResource FormTextBox}" Text="{Binding SubItemDiscountPercent, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsSubItemDiscountPer}" />
                                </Grid>

                                <Grid Grid.Column="6" Margin="0,0,10,0">
                                    <RadioButton Content="خصم" Margin="2,-16,0,0" FontSize="13" Foreground="#fff" VerticalAlignment="Top" IsChecked="{Binding IsSubItemDiscountPer, Converter={StaticResource InverseBool}}" />
                                    <TextBox Style="{StaticResource FormTextBox}" Text="{Binding SubItemDiscountValue, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsSubItemDiscountPer, Converter={StaticResource InverseBool}}" />
                                </Grid>

                                <Grid Grid.Column="7" Margin="0,0,10,0">    
                                    <TextBlock Margin="2,-16,0,0" FontSize="13" Foreground="#fff" Text="اجمالي" />
                                    <TextBox FontWeight="Bold" Foreground="#5BAE7C" IsEnabled="False"
                                             Style="{StaticResource FormTextBox}"
                                             Text="{Binding SubItemTotal, Mode=OneWay, StringFormat=\{0:N2\}}" />
                                </Grid>

                                <Button Grid.Column="8" Padding="16,10"
                                        Command="{Binding AddSubItemCommand}"
                                        Content="➕ إضافة"
                                        Style="{StaticResource PrimaryButton}" />
                            </Grid>
                        </Border>

                        <!--  ══════ SUBITEMS DATAGRID ══════  -->
                        <Border Grid.Row="4" MinHeight="100" MaxHeight="250" Margin="0,0,0,20" Background="#242940" BorderBrush="#3D4560" BorderThickness="1" ClipToBounds="True"
                                CornerRadius="12">
                            <DataGrid AlternatingRowBackground="#222738" AutoGenerateColumns="False" Background="#242940" BorderThickness="0" CanUserAddRows="False" CellEditEnding="DataGrid_CellEditEnding" ColumnHeaderHeight="44" FontSize="13"
                                      Foreground="#C8CEE0" GridLinesVisibility="Horizontal" HeadersVisibility="Column" HorizontalGridLinesBrush="#323848" IsReadOnly="False"
                                      ItemsSource="{Binding FormSubItems}"
                                      RowHeight="42" SelectionMode="Single">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style BasedOn="{StaticResource DarkColumnHeader}" TargetType="DataGridColumnHeader" />
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.RowStyle>
                                    <Style BasedOn="{StaticResource DarkRow}" TargetType="DataGridRow" />
                                </DataGrid.RowStyle>
                                <DataGrid.CellStyle>
                                    <Style BasedOn="{StaticResource DarkCell}" TargetType="DataGridCell" />
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Width="2*" Header="الصنف" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Padding="4,0" VerticalAlignment="Center">
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="ItemId,ItemName">
                                                            <Binding Path="ItemId" />
                                                            <Binding Path="DataContext.Items" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="100" Header="الوحدة" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Padding="4,0" VerticalAlignment="Center">
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="UnitId,UnitName">
                                                            <Binding Path="UnitId" />
                                                            <Binding Path="DataContext.Units" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Width="80" Binding="{Binding Qty, UpdateSourceTrigger=PropertyChanged}" Header="الكمية" />
                                    <DataGridTextColumn Width="100" Binding="{Binding Price, UpdateSourceTrigger=PropertyChanged}" Header="السعر" />
                                    <DataGridTextColumn Width="80" Binding="{Binding DiscPer, UpdateSourceTrigger=PropertyChanged}" Header="الخصم (%)" />
                                    <DataGridTextColumn Width="90"
                                                        Binding="{Binding Disc, StringFormat=\{0:N2\}}"
                                                        Foreground="#E8A54B" Header="قيمة الخصم" IsReadOnly="True" />
                                    <DataGridTextColumn Width="110"
                                                        Binding="{Binding Total, StringFormat=\{0:N2\}}"
                                                        FontWeight="SemiBold" Foreground="#5BAE7C" Header="الإجمالي" IsReadOnly="True" />
                                    <DataGridTemplateColumn Width="60" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Background="Transparent" BorderThickness="0"
                                                        Command="{Binding DataContext.RemoveSubItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="🗑️" Cursor="Hand" FontSize="15" Foreground="#D9534F" ToolTip="حذف الصنف" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!--  ══════ TOTALS ══════  -->
                        <Border Grid.Row="5" Margin="0,0,0,20" Padding="24,18"
                                Background="{StaticResource SectionBg}"
                                BorderBrush="{StaticResource SectionBorder}"
                                BorderThickness="1" CornerRadius="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  Left Side: Totals, Discounts, Add  -->
                                <WrapPanel Grid.Column="0" HorizontalAlignment="Left" Orientation="Horizontal">
                                    <StackPanel Margin="0,0,28,8">
                                        <TextBlock FontSize="11" FontWeight="Bold" Foreground="#7B84A0" Text="اجمالي" />
                                        <TextBox MinWidth="100" FontSize="15" FontWeight="Bold" Foreground="#82B1FF" IsReadOnly="True"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding FormItem.Total, Mode=OneWay, StringFormat=\{0:N2\}}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,28,8">
                                        <RadioButton Margin="0,0,0,4" FontSize="11" Foreground="#7B84A0" Content="خصم إجمالي (%)" IsChecked="{Binding IsInvoiceDiscountPer}" />
                                        <TextBox Width="70" Style="{StaticResource FormTextBox}" Text="{Binding DiscountPercentInput, UpdateSourceTrigger=PropertyChanged}" TextChanged="Totals_TextChanged" IsEnabled="{Binding IsInvoiceDiscountPer}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,28,8">
                                        <RadioButton Margin="0,0,0,4" FontSize="12" FontWeight="Bold" Foreground="#7B84A0" Content="خصم مبلغ" IsChecked="{Binding IsInvoiceDiscountPer, Converter={StaticResource InverseBool}}" />
                                        <TextBox Width="100" Style="{StaticResource FormTextBox}" Text="{Binding DiscountValueInput, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" TextChanged="Totals_TextChanged" IsEnabled="{Binding IsInvoiceDiscountPer, Converter={StaticResource InverseBool}}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,28,8">
                                        <TextBlock FontSize="11" Foreground="#7B84A0" Text="خدمة/إضافة" />
                                        <TextBox Width="100" Style="{StaticResource FormTextBox}" Text="{Binding FormItem.AddMoney, UpdateSourceTrigger=PropertyChanged}" TextChanged="Totals_TextChanged" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,28,8">
                                        <CheckBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Background="White" Checked="IsTax_Changed" Content="فاتورة ضريبية" FontSize="14"
                                                  FontWeight="SemiBold" Foreground="White"
                                                  IsChecked="{Binding FormItem.IsTax, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource DarkCheckBox}"
                                                  Unchecked="IsTax_Changed" />
                                    </StackPanel>
                                </WrapPanel>

                                <!--  Right Side: Tax Details & Net  -->
                                <Grid Grid.Column="2" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!--  Net Before Tax  -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,8" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" Foreground="#7B84A0" Text="اجمالي الفاتورة" />
                                    <TextBox Grid.Row="0" Grid.Column="1" MinWidth="140" Margin="0,0,0,8" HorizontalContentAlignment="Center" Background="#243832" FontSize="14" FontWeight="Bold"
                                             Foreground="#82B1FF" IsReadOnly="True"
                                             Style="{StaticResource FormTextBox}"
                                             Text="{Binding NetBeforeTax, Mode=OneWay, StringFormat=\{0:N2\}}" />

                                    <!--  VAT  -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,8" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" Foreground="#7B84A0" Text="ض القيمة المضافة"
                                               Visibility="{Binding FormItem.IsTax, Converter={StaticResource BoolToVis}}" />
                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" Orientation="Horizontal"
                                                Visibility="{Binding FormItem.IsTax, Converter={StaticResource BoolToVis}}">
                                        <TextBox MinWidth="60" HorizontalContentAlignment="Center" FontSize="13"
                                                 IsEnabled="{Binding IsEditing}"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding VatTaxPercent, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox MinWidth="80" Margin="8,0,0,0" HorizontalContentAlignment="Center" Background="#243832" FontSize="13" FontWeight="SemiBold" Foreground="#82B1FF" IsReadOnly="True"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding FormItem.VatTax, Mode=OneWay, StringFormat=\{0:N2\}}" />
                                    </StackPanel>

                                    <!--  WHT  -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,12,8" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" Foreground="#7B84A0" Text="ضريبة أ.ت.ص"
                                               Visibility="{Binding FormItem.IsTax, Converter={StaticResource BoolToVis}}" />
                                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" Orientation="Horizontal"
                                                Visibility="{Binding FormItem.IsTax, Converter={StaticResource BoolToVis}}">
                                        <TextBox MinWidth="60" HorizontalContentAlignment="Center" FontSize="13"
                                                 IsEnabled="{Binding IsEditing}"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding WhtTaxPercent, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox MinWidth="80" Margin="8,0,0,0" HorizontalContentAlignment="Center" Background="#243832" FontSize="13" FontWeight="SemiBold" Foreground="#82B1FF" IsReadOnly="True"
                                                 Style="{StaticResource FormTextBox}"
                                                 Text="{Binding FormItem.Tax, Mode=OneWay, StringFormat=\{0:N2\}}" />
                                    </StackPanel>

                                    <!--  Net After Tax  -->
                                    <TextBlock Grid.Row="3"  Grid.Column="0" Margin="0,0,12,0" FontSize="13" FontWeight="Bold" Foreground="#5BAE7C" Text="الصافي بعد الضريبة"
                                               Visibility="{Binding FormItem.IsTax, Converter={StaticResource BoolToVis}}" />
                                    <Border Visibility="{Binding FormItem.IsTax, Converter={StaticResource BoolToVis}}"  Grid.Row="3" Grid.Column="1" Padding="16,8" BorderThickness="1.5" CornerRadius="10">
                                        <Border.BorderBrush>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Offset="0" Color="#5BAE7C" />
                                                <GradientStop Offset="1" Color="#4A9D6B" />
                                            </LinearGradientBrush>
                                        </Border.BorderBrush>
                                        <Border.Background>
                                            <SolidColorBrush Color="#243832" />
                                        </Border.Background>
                                        <TextBlock FontSize="15"  FontWeight="Bold" Foreground="#5BAE7C" Text="{Binding FormItem.Net, StringFormat=\{0:N2\}}" />
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <!--  ══════ CASH MODE TREASURY ══════  -->
                        <Border Grid.Row="6" Margin="0,0,0,20" Padding="22" Background="#283830" BorderBrush="#3D7A5A" BorderThickness="1" CornerRadius="12"
                                IsEnabled="{Binding IsEditing}"
                                Visibility="{Binding IsCashPaymentMode, Converter={StaticResource BoolToVis}}">
                            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                <TextBlock Margin="0,0,16,0" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="#5BAE7C" Text="💳 اختر الخزينة (كاش):" />
                                <ComboBox MinWidth="250" BorderBrush="#5BAE7C" DisplayMemberPath="CashName" FontSize="14" FontWeight="SemiBold"
                                          ItemsSource="{Binding Cashes}"
                                          SelectedValue="{Binding SelectedCashId, UpdateSourceTrigger=PropertyChanged, FallbackValue=0}"
                                          SelectedValuePath="CashId" />
                                <TextBlock Margin="16,0,0,0" VerticalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="#047857"
                                           Text="{Binding CurrentSafeBalance, StringFormat='رصيد الخزينة: {0:N2}'}" />
                            </StackPanel>
                        </Border>

                        <!--  ══════ PAYMENTS SECTION (TRIGGER) ══════  -->
                        <Border Grid.Row="7" Margin="0,0,0,20" Padding="18" Background="#272C3F" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="12"
                                IsEnabled="{Binding IsEditing}"
                                Visibility="{Binding IsCashPaymentMode, Converter={StaticResource InverseBoolToVis}}">
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                <TextBlock Margin="0,0,16,0" VerticalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="#ECEEF5" Text="💰 المدفوعات وتفاصيل السداد" />
                                <Button Padding="24,12" Command="{Binding OpenPaymentsPopupCommand}" Content="إدارة المدفوعات 💰" Style="{StaticResource PrimaryButton}" />
                                <StackPanel Margin="24,0,0,0" VerticalAlignment="Center" Orientation="Horizontal">
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#7B84A0" Text="إجمالي المدفوع: " />
                                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#5BAE7C" Text="{Binding TotalPayed, StringFormat=\{0:N2\}}" />
                                    <TextBlock Margin="16,0,0,0" FontSize="13" FontWeight="SemiBold" Foreground="#7B84A0" Text="الباقي: " />
                                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#D9534F" Text="{Binding Remaining, StringFormat=\{0:N2\}}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!--  ══════ FOOTER ACTIONS ══════  -->
                        <DockPanel Grid.Row="8" Margin="0,8,0,0">
                            <TextBlock MaxWidth="300" Margin="0,0,16,0" HorizontalAlignment="Right" VerticalAlignment="Center" DockPanel.Dock="Right" FontSize="14" FontWeight="SemiBold" Foreground="#5BAE7C"
                                       Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap" />
                            <StackPanel MinHeight="48" HorizontalAlignment="Left" Orientation="Horizontal">
                                <!--  Print button  -->
                                <Button Margin="0,0,10,0" Padding="16,10"
                                        Command="{Binding PrintInvoiceCommand}"
                                        Content="🖨️ طباعة الفاتورة">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource SecondaryButton}"
                                               TargetType="Button">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Setter Property="Background" Value="#3B82F6" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedInvoice}"
                                                             Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <!--  Edit  -->
                                <Button Margin="0,0,10,0" Padding="16,10" Command="{Binding EditSelectedCommand}" Content="✏️ تعديل">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource WarningButton}" TargetType="Button">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedInvoice}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <!--  Save  -->
                                <Button Margin="0,0,10,0" Padding="16,10" Command="{Binding SaveCommand}" Content="💾 حفظ">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource SuccessButton}" TargetType="Button">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <!--  Cancel  -->
                                <Button Margin="0,0,14,0" Padding="16,10" Command="{Binding CancelEditCommand}" Content="✖ إلغاء">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource SecondaryButton}" TargetType="Button">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <!--  Delete  -->
                                <Button Margin="0,0,10,0" Padding="16,10" Command="{Binding DeleteCommand}" Content="🗑️ حذف">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource DangerButton}" TargetType="Button">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedInvoice}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </Grid>
                </Border>
            </ScrollViewer>
        </Grid>

        <!--  ████████ SEARCH Section ████████  -->
        <Grid Margin="20" Style="{StaticResource SearchContainerStyle}">
            <Border Padding="24" Background="#272C3F" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="14">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" Direction="270" Opacity="0.08" ShadowDepth="6" Color="#000000" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Search Header  -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,20">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <Border Width="40" Height="40" Margin="0,0,12,0" CornerRadius="10">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Offset="0" Color="#E8A54B" />
                                        <GradientStop Offset="1" Color="#D4922F" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" Text="🔎" />
                            </Border>
                            <TextBlock VerticalAlignment="Center" FontSize="18" FontWeight="Bold" Foreground="#ECEEF5" Text="البحث في فواتير الشراء" />
                        </StackPanel>
                        <Button Padding="16,8" HorizontalAlignment="Right"
                                Command="{Binding HideSearchPanelCommand}"
                                Content="✖ رجوع" DockPanel.Dock="Right"
                                Style="{StaticResource SecondaryButton}" />
                    </DockPanel>

                    <!--  Search Bar  -->
                    <Border Grid.Row="1" Margin="0,0,0,20" Padding="16"
                            Background="{StaticResource SectionBg}"
                            BorderBrush="{StaticResource SectionBorder}"
                            BorderThickness="1" CornerRadius="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Margin="0,0,14,0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#9BA4B5" Text="بحث:" />
                            <TextBox Grid.Column="1" Padding="12,8" HorizontalAlignment="Stretch" FontSize="15"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Border>

                    <!--  Search Results Grid  -->
                    <Border Grid.Row="2" Background="#242940" BorderBrush="#3D4560" BorderThickness="1" ClipToBounds="True" CornerRadius="12">
                        <DataGrid AlternatingRowBackground="#222738" AutoGenerateColumns="False" Background="#242940" BorderThickness="0" CanUserAddRows="False" ColumnHeaderHeight="50" FontSize="13" Foreground="#C8CEE0"
                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column" HorizontalGridLinesBrush="#323848" IsReadOnly="True"
                                  ItemsSource="{Binding FilteredInvoices}"
                                  RowHeight="46"
                                  SelectedItem="{Binding SelectedInvoice, Mode=TwoWay}"
                                  SelectionMode="Single">
                            <DataGrid.ColumnHeaderStyle>
                                <Style BasedOn="{StaticResource DarkColumnHeader}" TargetType="DataGridColumnHeader">
                                    <Setter Property="Padding" Value="14,12" />
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Cursor" Value="Hand" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="#C8CEE0" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#323F58" />
                                            <Setter Property="Foreground" Value="#E8A54B" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2A3040" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.CellStyle>
                                <Style BasedOn="{StaticResource DarkCell}" TargetType="DataGridCell" />
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Margin="6,4" Padding="6,4"
                                                    Command="{Binding DataContext.HideSearchPanelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    Content="✅ اختيار" FontSize="12"
                                                    Style="{StaticResource SuccessButton}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="100" Binding="{Binding BuyId}" Header="رقم الفاتورة" />
                                <DataGridTextColumn Width="100" Binding="{Binding BuyDate, StringFormat=\{0:yyyy/MM/dd\}}" Header="التاريخ" />
                                <DataGridTemplateColumn Width="200" Header="المورد">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Padding="4,0" VerticalAlignment="Center">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="SuppId,SuppName">
                                                        <Binding Path="SuppId" />
                                                        <Binding Path="DataContext.Suppliers" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="150" Binding="{Binding Net, StringFormat=\{0:N2\}}" Foreground="#5BAE7C" Header="الإجمالي" />
                                <DataGridTextColumn Width="*" Binding="{Binding Notes}" Header="الملاحظات" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!--  ████████ PAYMENTS POPUP OVERLAY ████████  -->
        <Grid Panel.ZIndex="100" Background="#B20F172A" Visibility="{Binding IsPaymentsPopupOpen, Converter={StaticResource BoolToVis}}">
            <Border Width="850" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#1E2233" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="32" Direction="270" Opacity="0.3" ShadowDepth="12" Color="#000000" />
                </Border.Effect>
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock VerticalAlignment="Center" DockPanel.Dock="Left" FontSize="20" FontWeight="Bold" Foreground="#ECEEF5" Text="💰 المدفوعات" />
                        <Button HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0"
                                Command="{Binding ClosePaymentsPopupCommand}"
                                Content="✖" Cursor="Hand" DockPanel.Dock="Right" FontSize="20" FontWeight="Bold" Foreground="#7B84A0" ToolTip="إغلاق" />
                    </DockPanel>

                    <!--  Quick Add Payment  -->
                    <Border Grid.Row="1" Margin="0,0,0,14" Padding="14"
                            Background="{StaticResource SectionBg}"
                            BorderBrush="{StaticResource SectionBorder}"
                            BorderThickness="1" CornerRadius="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="100" />
                                <ColumnDefinition Width="*" MinWidth="80" />
                                <ColumnDefinition Width="*" MinWidth="200" />
                                <ColumnDefinition Width="2*" MinWidth="100" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Style="{StaticResource FloatingLabel}" Text="التاريخ" />
                                <DatePicker SelectedDate="{Binding CurrentPayment.PayDate, UpdateSourceTrigger=PropertyChanged}" IsEnabled="False" />
                            </Grid>
                            <Grid Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Style="{StaticResource FloatingLabel}" Text="المبلغ" />
                                <TextBox Style="{StaticResource FormTextBox}" Text="{Binding CurrentPayment.PayMoney, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Grid.Column="2" Margin="0,0,10,0">
                                <TextBlock Style="{StaticResource FloatingLabel}" Text="الخزينة" />
                                <StackPanel>
                                    <ComboBox DisplayMemberPath="CashName" ItemsSource="{Binding Cashes}" SelectedValue="{Binding SelectedCashId, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="CashId" />
                                    <TextBlock Margin="0,4,0,0" FontSize="12" FontWeight="SemiBold" Foreground="#047857"
                                               Text="{Binding CurrentSafeBalance, StringFormat='رصيد الخزينة: {0:N2}'}" />
                                </StackPanel>
                            </Grid>
                            <Grid Grid.Column="3" Margin="0,0,10,0">
                                <TextBlock Style="{StaticResource FloatingLabel}" Text="ملاحظات" />
                                <TextBox Style="{StaticResource FormTextBox}" Text="{Binding CurrentPayment.Notes, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Button Grid.Column="4" Padding="16,10"
                                    Command="{Binding AddPaymentCommand}"
                                    Content="➕ إضافة"
                                    Style="{StaticResource SuccessButton}" />
                        </Grid>
                    </Border>

                    <!--  Payments DataGrid  -->
                    <Border Grid.Row="2" MinHeight="150" MaxHeight="300" Background="#242940" BorderBrush="#3D4560" BorderThickness="1" ClipToBounds="True" CornerRadius="10">
                        <DataGrid AlternatingRowBackground="#222738" AutoGenerateColumns="False" Background="#242940" BorderThickness="0" CanUserAddRows="False" ColumnHeaderHeight="40" FontSize="13" Foreground="#C8CEE0"
                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column" HorizontalGridLinesBrush="#323848" IsReadOnly="False"
                                  ItemsSource="{Binding FormPayments}"
                                  RowHeight="36" SelectionMode="Single">
                            <DataGrid.ColumnHeaderStyle>
                                <Style BasedOn="{StaticResource DarkColumnHeader}" TargetType="DataGridColumnHeader" />
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style BasedOn="{StaticResource DarkRow}" TargetType="DataGridRow" />
                            </DataGrid.RowStyle>
                            <DataGrid.CellStyle>
                                <Style BasedOn="{StaticResource DarkCell}" TargetType="DataGridCell" />
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="120" Binding="{Binding PayDate, StringFormat=\{0:yyyy/MM/dd\}}" Header="التاريخ" IsReadOnly="True" />
                                <DataGridTextColumn Width="120"
                                                    Binding="{Binding PayMoney, StringFormat=\{0:N2\}}"
                                                    FontWeight="SemiBold" Foreground="#5BAE7C" Header="المبلغ" />
                                <DataGridTemplateColumn Width="*" Header="الخزينة">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Padding="4,0" VerticalAlignment="Center">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="CashId,CashName">
                                                        <Binding Path="CashId" />
                                                        <Binding Path="DataContext.Cashes" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <ComboBox DisplayMemberPath="CashName" IsDropDownOpen="True"
                                                      ItemsSource="{Binding DataContext.Cashes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      SelectedValue="{Binding CashId, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="CashId" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="*" Binding="{Binding Notes}" Header="ملاحظات" />
                                <DataGridTemplateColumn Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Background="Transparent" BorderThickness="0"
                                                    Command="{Binding DataContext.RemovePaymentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Content="🗑️" Cursor="Hand" FontSize="14" Foreground="#D9534F" ToolTip="حذف الدفعة" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!--  Payment Totals  -->
                    <StackPanel Grid.Row="3" Margin="0,14,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
                        <Border Margin="0,0,24,0" Padding="16,10" Background="#283830" BorderBrush="#3D7A5A" BorderThickness="1" CornerRadius="8">
                            <StackPanel>
                                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#7B84A0" Text="إجمالي المدفوع" />
                                <TextBlock FontSize="18" FontWeight="Bold" Foreground="#5BAE7C" Text="{Binding TotalPayed, StringFormat=\{0:N2\}}" />
                            </StackPanel>
                        </Border>
                        <Border Padding="16,10" Background="#3A2828" BorderBrush="#7A3D3D" BorderThickness="1" CornerRadius="8">
                            <StackPanel>
                                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#7B84A0" Text="الباقي" />
                                <TextBlock FontSize="18" FontWeight="Bold" Foreground="#D9534F" Text="{Binding Remaining, StringFormat=\{0:N2\}}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </Grid>
            </Border>
        </Grid>

    </Grid>
