<UserControl x:Class="MotorBike.Views.BuysView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MotorBike.Converters"
             Loaded="OnLoaded" FlowDirection="RightToLeft">
    <UserControl.Resources>
        <conv:HideZeroConverter x:Key="HideZeroConv"/>
        <conv:IdToNameConverter x:Key="IdToNameConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolConverter x:Key="InverseBool" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />

        <Style x:Key="FormCard" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="Margin" Value="16" />
            <Setter Property="Padding" Value="24" />
        </Style>

        <Style x:Key="FormContainerStyle" TargetType="Grid">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="False">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SearchContainerStyle" TargetType="Grid">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F8FAFC">

        <!-- FORM Section -->
        <Grid Style="{StaticResource FormContainerStyle}">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" ScrollChanged="ScrollViewer_ScrollChanged">
                <Border Style="{StaticResource FormCard}">
                    <Border.Effect>
                        <DropShadowEffect Color="#0F172A" Opacity="0.04" BlurRadius="24" ShadowDepth="4" Direction="270" />
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Header -->
                            <RowDefinition Height="Auto"/> <!-- Separator -->
                            <RowDefinition Height="Auto"/> <!-- Main Info -->
                            <RowDefinition Height="Auto"/> <!-- Smart Item Search & Add -->
                            <RowDefinition Height="Auto"/> <!-- DataGrid SubItems -->
                            <RowDefinition Height="Auto"/> <!-- Totals & Footer -->
                            <RowDefinition Height="Auto"/> <!-- Cash Mode Treasury -->
                            <RowDefinition Height="Auto"/> <!-- Payments Section -->
                            <RowDefinition Height="Auto"/> <!-- Actions -->
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Orientation="Horizontal" Grid.Column="0">
                                <Border Background="#EEF2FF" CornerRadius="12" Padding="14,12" Margin="0,0,16,0">
                                    <TextBlock Text="📄" FontSize="26" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="فاتورة الشراء" FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
                                    <TextBlock Text="سجل فاتورة شراء جديدة أو استعلم عن فواتير سابقة" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="🔍 بحث عن فاتورة سابقة" Style="{StaticResource SecondaryButton}" Command="{Binding ShowSearchPanelCommand}" Margin="0,0,12,0" Padding="16,10"/>
                                <Button Content="➕ تـسـجيـل فاتورة جـديـدة" Style="{StaticResource PrimaryButton}" Command="{Binding AddNewCommand}" Padding="16,10"/>
                            </StackPanel>
                        </Grid>

                        <Rectangle Grid.Row="1" Height="1" Fill="#E2E8F0" Margin="0,8,0,24"/>

                        <!-- Form Matrix: Main Info (Responsive) -->
                        <Grid Grid.Row="2" IsEnabled="{Binding IsEditing}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="80"/>
                                <ColumnDefinition Width="*" MinWidth="120"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="Auto" MinWidth="80"/>
                                <ColumnDefinition Width="*" MinWidth="120"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="Auto" MinWidth="80"/>
                                <ColumnDefinition Width="*" MinWidth="120"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/> <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 0: ID, Date, Supplier -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="رقم الفاتورة" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding FormItem.BuyId, Converter={StaticResource HideZeroConv}}" Style="{StaticResource FormTextBox}"
                                     IsReadOnly="True" Background="#F8FAFC" Foreground="#1E293B" FontWeight="Bold"/>                            
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="التاريخ" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <DatePicker Grid.Row="0" Grid.Column="4" SelectedDate="{Binding FormItem.BuyDate, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource {x:Type DatePicker}}" BorderBrush="#CBD5E1" BorderThickness="1" Padding="8,6" Background="White"/>

                            <TextBlock Grid.Row="0" Grid.Column="6" Text="المورد" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <!-- Supplier Smart Search -->
                            <Grid Grid.Row="0" Grid.Column="7">
                                <TextBox x:Name="SupplierSearchBox" Text="{Binding SupplierSearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" Padding="8,6" ToolTip="ابحث عن المورد بالاسم" GotFocus="SupplierSearch_GotFocus"/>
                                <Popup x:Name="SupplierSearchPopup" IsOpen="{Binding IsSupplierSearchPopupOpen}" StaysOpen="False" Placement="Bottom" PlacementTarget="{Binding ElementName=SupplierSearchBox}" Width="{Binding ActualWidth, ElementName=SupplierSearchBox}" AllowsTransparency="True">
                                    <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" MaxHeight="250">
                                        <Border.Effect><DropShadowEffect Color="#0F172A" Opacity="0.1" BlurRadius="16" ShadowDepth="4" Direction="270"/></Border.Effect>
                                        <ListBox ItemsSource="{Binding FilteredSuppliersList}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemTemplate><DataTemplate>
                                                <Border Padding="8,6" Cursor="Hand"><TextBlock FontSize="13" Foreground="#334155">
                                                    <Run Text="{Binding SuppName, Mode=OneWay}"/>
                                                </TextBlock></Border>
                                            </DataTemplate></ListBox.ItemTemplate>
                                            <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="Padding" Value="0"/>
                                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="SearchSupplier_Click"/>
                                                <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#EFF6FF"/></Trigger></Style.Triggers>
                                            </Style></ListBox.ItemContainerStyle>
                                        </ListBox>
                                    </Border>
                                </Popup>
                            </Grid>

                            <!-- Row 2: Notes, Payment Toggle -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="ملاحظات" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4" Text="{Binding FormItem.Notes, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="6" Text="طريقة السداد" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <!-- Slide Toggle: أجل / كاش -->
                            <ToggleButton Grid.Row="2" Grid.Column="7" IsChecked="{Binding FormItem.IsCash, UpdateSourceTrigger=PropertyChanged}" Cursor="Hand" Checked="IsCash_Changed" Unchecked="IsCash_Changed" VerticalAlignment="Center" HorizontalAlignment="Stretch" Height="36">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="TrackBorder" CornerRadius="18" Height="36" Background="#F1F5F9" BorderThickness="1" BorderBrush="#CBD5E1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Sliding highlight -->
                                                <Border x:Name="SliderHighlight" Grid.Column="1" CornerRadius="16" Margin="2" Background="#10B981">
                                                    <Border.RenderTransform>
                                                        <TranslateTransform x:Name="SliderTranslate" X="0"/>
                                                    </Border.RenderTransform>
                                                </Border>
                                                <!-- Labels -->
                                                <TextBlock x:Name="LabelRight" Grid.Column="0" Text="أجل" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#475569"/>
                                                <TextBlock x:Name="LabelLeft" Grid.Column="1" Text="كاش" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="False">
                                                <Setter TargetName="SliderHighlight" Property="Grid.Column" Value="0"/>
                                                <Setter TargetName="SliderHighlight" Property="Background" Value="#F59E0B"/>
                                                <Setter TargetName="LabelRight" Property="Foreground" Value="White"/>
                                                <Setter TargetName="LabelLeft" Property="Foreground" Value="#475569"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TrackBorder" Property="BorderBrush" Value="#94A3B8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                        </Grid>

                        <!-- Smart Search & Quick Add item (Responsive) -->
                        <Border Grid.Row="3" Background="#F1F5F9" CornerRadius="12" Padding="16" Margin="0,24,0,16" IsEnabled="{Binding IsEditing}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*" MinWidth="150"/> <!-- Smart Search -->
                                    <ColumnDefinition Width="*" MinWidth="80"/>   <!-- Store -->
                                    <ColumnDefinition Width="0.9*" MinWidth="70"/> <!-- Unit -->
                                    <ColumnDefinition Width="0.7*" MinWidth="60"/>  <!-- Qty -->
                                    <ColumnDefinition Width="0.8*" MinWidth="70"/>  <!-- Price -->
                                    <ColumnDefinition Width="0.8*" MinWidth="70"/>  <!-- DiscPer -->
                                    <ColumnDefinition Width="0.8*" MinWidth="70"/>  <!-- Disc -->
                                    <ColumnDefinition Width="0.8*" MinWidth="70"/>  <!-- Total -->
                                    <ColumnDefinition Width="Auto"/>              <!-- Add btn -->
                                </Grid.ColumnDefinitions>
                                
                                <Grid Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="✍️ بحث ذكي (بالاسم أو الباركود)" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                    <TextBox x:Name="ItemSearchBox" Text="{Binding ItemSearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" Padding="8,6" ToolTip="ابحث هنا عن الأصناف" GotFocus="ItemSearch_GotFocus"/>
                                    <Popup x:Name="ItemSearchPopup" IsOpen="{Binding IsItemSearchPopupOpen}" StaysOpen="False" Placement="Bottom" PlacementTarget="{Binding ElementName=ItemSearchBox}" Width="{Binding ActualWidth, ElementName=ItemSearchBox}" AllowsTransparency="True">
                                        <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" MaxHeight="250">
                                            <Border.Effect><DropShadowEffect Color="#0F172A" Opacity="0.1" BlurRadius="16" ShadowDepth="4" Direction="270"/></Border.Effect>
                                            <ListBox ItemsSource="{Binding FilteredItemsList}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <ListBox.ItemTemplate><DataTemplate>
                                                    <Border Padding="8,6" Cursor="Hand"><TextBlock FontSize="13" Foreground="#334155">
                                                        <Run Text="{Binding ItemName, Mode=OneWay}"/><Run Text=" — " Foreground="#94A3B8"/><Run Text="سعر شراء: " Foreground="#64748B" FontSize="11"/><Run Text="{Binding Price0, StringFormat=\{0:N2\}, Mode=OneWay}" Foreground="#1D4ED8" FontWeight="SemiBold"/>
                                                    </TextBlock></Border>
                                                </DataTemplate></ListBox.ItemTemplate>
                                                <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem">
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="Padding" Value="0"/>
                                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="SearchItem_Click"/>
                                                    <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#EFF6FF"/></Trigger></Style.Triggers>
                                                </Style></ListBox.ItemContainerStyle>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>
                                
                                <Grid Grid.Column="1" Margin="0,0,12,0">
                                    <TextBlock Text="المخزن" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                    <ComboBox ItemsSource="{Binding Stores}" DisplayMemberPath="StoreName" SelectedValuePath="StoreId" SelectedValue="{Binding CurrentSubItem.StoreId, UpdateSourceTrigger=PropertyChanged}" Padding="8,6" BorderBrush="#CBD5E1" BorderThickness="1" Background="White"/>
                                </Grid>
                                
                                <Grid Grid.Column="2" Margin="0,0,12,0">
                                    <TextBlock Text="الوحدة" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                    <ComboBox ItemsSource="{Binding CurrentItemUnits}" DisplayMemberPath="UnitName" SelectedValuePath="UnitId" SelectedValue="{Binding CurrentSubItem.UnitId, UpdateSourceTrigger=PropertyChanged}" Padding="8,6" BorderBrush="#CBD5E1" BorderThickness="1" Background="White"/>
                                </Grid>
                                
                                <Grid Grid.Column="3" Margin="0,0,12,0">
                                    <TextBlock Text="الكمية" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                    <TextBox Text="{Binding SubItemQty, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                                </Grid>
                                
                                <Grid Grid.Column="4" Margin="0,0,12,0">
                                    <TextBlock Text="السعر" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                    <TextBox Text="{Binding SubItemPrice, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                                </Grid>
                                
                                <Grid Grid.Column="5" Margin="0,0,12,0">
                                    <TextBlock Text="خصم (%)" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                    <TextBox Text="{Binding SubItemDiscountPercent, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                                </Grid>

                                <Grid Grid.Column="6" Margin="0,0,12,0">
                                    <TextBlock Text="خصم مبلغ" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                    <TextBox Text="{Binding SubItemDiscountValue, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                                </Grid>

                                <Grid Grid.Column="7" Margin="0,0,12,0">
                                    <TextBlock Text="اجمالي" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                    <TextBox Text="{Binding SubItemTotal, Mode=OneWay, StringFormat=\{0:N2\}}" Style="{StaticResource FormTextBox}" IsEnabled="False" Background="#F1F5F9" Foreground="#DC2626" FontWeight="Bold"/>
                                </Grid>

                                <Button Grid.Column="8" Content="➕ إضافة" Style="{StaticResource PrimaryButton}" Command="{Binding AddSubItemCommand}" Padding="16,8" Background="#3B82F6"/>
                            </Grid>
                        </Border>

                        <!-- SubItems DataGrid -->
                        <Border Grid.Row="4" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" ClipToBounds="True" Height="250" Margin="0,0,0,24">
                            <DataGrid ItemsSource="{Binding FormSubItems}" AutoGenerateColumns="False" IsReadOnly="False" CanUserAddRows="False" SelectionMode="Single"
                                      GridLinesVisibility="Horizontal" HeadersVisibility="Column" BorderThickness="0" RowHeight="40" ColumnHeaderHeight="46" AlternatingRowBackground="#F8FAFC" Background="White" Foreground="#1E293B" FontSize="14" HorizontalGridLinesBrush="#F1F5F9"
                                      CellEditEnding="DataGrid_CellEditEnding">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#F1F5F9"/>
                                        <Setter Property="Foreground" Value="#334155"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="12,8"/>
                                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#DBEAFE"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="الصنف" Width="2*" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock VerticalAlignment="Center" Padding="4,0">
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="ItemId,ItemName">
                                                            <Binding Path="ItemId" />
                                                            <Binding Path="DataContext.Items" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="الوحدة" Width="100" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock VerticalAlignment="Center" Padding="4,0">
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="UnitId,UnitName">
                                                            <Binding Path="UnitId" />
                                                            <Binding Path="DataContext.Units" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="الكمية" Binding="{Binding Qty, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                                    <DataGridTextColumn Header="السعر" Binding="{Binding Price, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                                    <DataGridTextColumn Header="الخصم (%)" Binding="{Binding DiscPer, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                                    <DataGridTextColumn Header="قيمة الخصم" Binding="{Binding Disc, StringFormat=\{0:N2\}}" Width="80" IsReadOnly="True" Foreground="#F59E0B"/>
                                    <DataGridTextColumn Header="الإجمالي" Binding="{Binding Total, StringFormat=\{0:N2\}}" Width="100" IsReadOnly="True" FontWeight="SemiBold"/>
                                    
                                    <DataGridTemplateColumn Width="70" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="🗑️" Command="{Binding DataContext.RemoveSubItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Foreground="Red" FontSize="16" ToolTip="حذف الصنف"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- Totals Section (Responsive) -->
                        <Border Grid.Row="5" Background="#F8FAFC" CornerRadius="12" Padding="24,16" Margin="0,0,0,24" BorderBrush="#E2E8F0" BorderThickness="1">
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <StackPanel Margin="0,0,24,8">
                                    <TextBlock Text="اجمالي" Foreground="#64748B" FontSize="12" FontWeight="Bold"/>
                                    <TextBox Text="{Binding FormItem.Total, Mode=OneWay, StringFormat=\{0:N2\}}" Style="{StaticResource FormTextBox}" IsReadOnly="True" Background="#EFF6FF" Foreground="#1D4ED8" FontWeight="Bold" FontSize="15" MinWidth="100"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,24,8">
                                    <TextBlock Text="خصم إجمالي (%)" Foreground="#64748B" FontSize="12"/>
                                    <TextBox Text="{Binding DiscountPercentInput, UpdateSourceTrigger=PropertyChanged}" Width="70" Background="White" BorderBrush="#CBD5E1" Style="{StaticResource FormTextBox}" TextChanged="Totals_TextChanged"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,24,8">
                                    <TextBlock Text="خصم مبلغ" Foreground="#64748B" FontSize="12"/>
                                    <TextBox Text="{Binding DiscountValueInput, UpdateSourceTrigger=PropertyChanged}" Width="100" Background="White" BorderBrush="#CBD5E1" Style="{StaticResource FormTextBox}" TextChanged="Totals_TextChanged"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,24,8">
                                    <TextBlock Text="خدمة/إضافة" Foreground="#64748B" FontSize="12"/>
                                    <TextBox Text="{Binding FormItem.AddMoney, UpdateSourceTrigger=PropertyChanged}" Width="100" Background="White" BorderBrush="#CBD5E1" Style="{StaticResource FormTextBox}" TextChanged="Totals_TextChanged"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,24,8">
                                    <TextBlock Text="الصافي" Foreground="#64748B" FontSize="12"/>
                                    <TextBlock Text="{Binding FormItem.Net, StringFormat=\{0:N2\}}" FontSize="20" FontWeight="Bold" Foreground="#10B981"/>
                                </StackPanel>
                            </WrapPanel>
                        </Border>

                        <!-- Cash Mode Treasury Selector (Only visible in Cash mode) -->
                        <Border Grid.Row="6" Background="#ECFDF5" CornerRadius="12" Padding="24" Margin="0,0,0,24" BorderBrush="#A7F3D0" BorderThickness="1" Visibility="{Binding IsCashPaymentMode, Converter={StaticResource BoolToVis}}" IsEnabled="{Binding IsEditing}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="💳 اختر الخزينة التي سيتم خصم المبلغ (كاش) منها:" FontWeight="Bold" Foreground="#065F46" FontSize="16" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <ComboBox ItemsSource="{Binding Cashes}" DisplayMemberPath="CashName" SelectedValuePath="CashId" SelectedValue="{Binding FormPayments[0].CashId, UpdateSourceTrigger=PropertyChanged, FallbackValue=0}" Padding="16,10" BorderBrush="#34D399" BorderThickness="1" Background="White" MinWidth="250" FontSize="15" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <!-- Payments Section (Only visible in Credit mode) -->
                        <Border Grid.Row="7" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Padding="16" Margin="0,0,0,24" IsEnabled="{Binding IsEditing}" Visibility="{Binding IsCashPaymentMode, Converter={StaticResource InverseBoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="💰 المدفوعات" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,12"/>

                                <!-- Quick Add Payment -->
                                <Border Background="#F1F5F9" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" MinWidth="100"/> <!-- Date -->
                                            <ColumnDefinition Width="*" MinWidth="80"/>  <!-- Amount -->
                                            <ColumnDefinition Width="*" MinWidth="100"/> <!-- Cash -->
                                            <ColumnDefinition Width="2*" MinWidth="100"/>  <!-- Notes -->
                                            <ColumnDefinition Width="Auto"/>             <!-- Add btn -->
                                        </Grid.ColumnDefinitions>

                                        <Grid Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="التاريخ" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                            <DatePicker SelectedDate="{Binding CurrentPayment.PayDate, UpdateSourceTrigger=PropertyChanged}" Padding="8,4" BorderBrush="#CBD5E1" BorderThickness="1" Background="White"/>
                                        </Grid>

                                        <Grid Grid.Column="1" Margin="0,0,12,0">
                                            <TextBlock Text="المبلغ" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                            <TextBox Text="{Binding CurrentPayment.PayMoney, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                                        </Grid>

                                        <Grid Grid.Column="2" Margin="0,0,12,0">
                                            <TextBlock Text="الخزينة" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                            <ComboBox ItemsSource="{Binding Cashes}" DisplayMemberPath="CashName" SelectedValuePath="CashId" SelectedValue="{Binding CurrentPayment.CashId, UpdateSourceTrigger=PropertyChanged}" Padding="8,6" BorderBrush="#CBD5E1" BorderThickness="1" Background="White"/>
                                        </Grid>

                                        <Grid Grid.Column="3" Margin="0,0,12,0">
                                            <TextBlock Text="ملاحظات" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                            <TextBox Text="{Binding CurrentPayment.Notes, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                                        </Grid>

                                        <Button Grid.Column="4" Content="➕ إضافة" Style="{StaticResource PrimaryButton}" Command="{Binding AddPaymentCommand}" Padding="16,8" Background="#10B981"/>
                                    </Grid>
                                </Border>

                                <!-- Payments DataGrid -->
                                <Border CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" ClipToBounds="True" MaxHeight="160">
                                    <DataGrid ItemsSource="{Binding FormPayments}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single"
                                              GridLinesVisibility="Horizontal" HeadersVisibility="Column" BorderThickness="0" RowHeight="36" ColumnHeaderHeight="40"
                                              AlternatingRowBackground="#F8FAFC" Background="White" Foreground="#1E293B" FontSize="13" HorizontalGridLinesBrush="#F1F5F9">
                                        <DataGrid.ColumnHeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#F1F5F9"/>
                                                <Setter Property="Foreground" Value="#334155"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Padding" Value="10,6"/>
                                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            </Style>
                                        </DataGrid.ColumnHeaderStyle>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="التاريخ" Binding="{Binding PayDate, StringFormat=\{0:yyyy/MM/dd\}}" Width="120"/>
                                            <DataGridTextColumn Header="المبلغ" Binding="{Binding PayMoney, StringFormat=\{0:N2\}}" Width="120" FontWeight="SemiBold"/>
                                            <DataGridTemplateColumn Header="الخزينة" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock VerticalAlignment="Center" Padding="4,0">
                                                            <TextBlock.Text>
                                                                <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="CashId,CashName">
                                                                    <Binding Path="CashId" />
                                                                    <Binding Path="DataContext.Cashes" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="ملاحظات" Binding="{Binding Notes}" Width="*"/>
                                            <DataGridTemplateColumn Width="60">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="🗑️" Command="{Binding DataContext.RemovePaymentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Foreground="Red" FontSize="14" ToolTip="حذف الدفعة"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>

                                <!-- Payment Totals -->
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <StackPanel Margin="0,0,32,0">
                                        <TextBlock Text="إجمالي المدفوع" Foreground="#64748B" FontSize="12"/>
                                        <TextBlock Text="{Binding TotalPayed, StringFormat=\{0:N2\}}" FontSize="18" FontWeight="Bold" Foreground="#10B981"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="الباقي" Foreground="#64748B" FontSize="12"/>
                                        <TextBlock Text="{Binding Remaining, StringFormat=\{0:N2\}}" FontSize="18" FontWeight="Bold" Foreground="#EF4444"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Footer Action Buttons -->
                        <DockPanel Grid.Row="8">
                            <TextBlock DockPanel.Dock="Right" Text="{Binding StatusMessage}" Foreground="#10B981" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0" TextWrapping="Wrap" MaxWidth="300" HorizontalAlignment="Right"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" MinHeight="45">
                                <Button Content="✏️ تـعـديـل الفاتورة" Command="{Binding EditSelectedCommand}" Margin="0,0,12,0" Padding="16,10">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Setter Property="Background" Value="#F59E0B" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedInvoice}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                
                                <Button Content="💾 حـفـظ الفاتورة" Command="{Binding SaveCommand}" Margin="0,0,12,0" Padding="16,10">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                            <Setter Property="Background" Value="#10B981"/>
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                
                                <Button Content="✖ إلـغـاء" Command="{Binding CancelEditCommand}" Margin="0,0,16,0" Padding="16,10">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Content="🗑️ حـذف" Command="{Binding DeleteCommand}" Padding="16,10">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedInvoice}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </Grid>
                </Border>
            </ScrollViewer>
        </Grid>

        <!-- SEARCH Section -->
        <Grid Style="{StaticResource SearchContainerStyle}" Margin="16">
            <Border Background="White" CornerRadius="16" Padding="24" BorderBrush="#E2E8F0" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#0F172A" Opacity="0.04" BlurRadius="24" ShadowDepth="4" Direction="270" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,24">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                            <Border Background="#F3F4F6" CornerRadius="8" Padding="10" Margin="0,0,12,0">
                                <TextBlock Text="🔎" FontSize="20"/>
                            </Border>
                            <TextBlock Text="البحث في فواتير الشراء السابقة" FontSize="20" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button DockPanel.Dock="Right" Content="✖ الـرجـوع للـنمـوذج" Style="{StaticResource SecondaryButton}" Command="{Binding HideSearchPanelCommand}" HorizontalAlignment="Right" Padding="16,8"/>
                    </DockPanel>

                    <Border Grid.Row="1" Background="#F8FAFC" CornerRadius="12" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,24">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="كلمة البحث (رقم الفاتورة، اسم المورد):" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,16,0"/>
                            <TextBox Width="460" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" Padding="12,8" FontSize="15" Background="White"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" ClipToBounds="True">
                        <DataGrid ItemsSource="{Binding FilteredInvoices}" SelectedItem="{Binding SelectedInvoice, Mode=TwoWay}"
                                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single"
                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column" BorderThickness="0" RowHeight="48"
                                  ColumnHeaderHeight="54" AlternatingRowBackground="#F8FAFC" Background="White" Foreground="#1E293B" FontSize="14" HorizontalGridLinesBrush="#F1F5F9">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                    <Setter Property="Foreground" Value="#334155"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="16,12"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#DBEAFE"/>
                                            <Setter Property="Foreground" Value="#1D4ED8"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#EFF6FF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✅ اختيار" Style="{StaticResource PrimaryButton}" Margin="8,6" Padding="4" Background="#10B981" Foreground="White" FontSize="12" Command="{Binding DataContext.HideSearchPanelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="رقم الفاتورة" Binding="{Binding BuyId}" Width="100"/>
                                <DataGridTextColumn Header="التاريخ" Binding="{Binding BuyDate, StringFormat=\{0:yyyy/MM/dd\}}" Width="100"/>
                                <DataGridTemplateColumn Header="المورد" Width="200">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock VerticalAlignment="Center" Padding="4,0">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="SuppId,SuppName">
                                                        <Binding Path="SuppId" />
                                                        <Binding Path="DataContext.Suppliers" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="الإجمالي" Binding="{Binding Net}" Width="150"/>
                                <DataGridTextColumn Header="الملاحظات" Binding="{Binding Notes}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
