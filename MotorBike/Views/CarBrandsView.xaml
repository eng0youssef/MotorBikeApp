<UserControl x:Class="MotorBike.Views.CarBrandsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Loaded="OnLoaded" FlowDirection="RightToLeft">
    <Grid MinWidth="600" MinHeight="400" Background="#1E2233">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!--  Search Bar  -->
        <Border Grid.Row="0" Margin="0,0,0,12" Padding="12,8" Background="#272C3F" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="10">
            <Border.Effect><DropShadowEffect BlurRadius="8" Direction="270" Opacity="0.04" ShadowDepth="2" Color="#0F172A" /></Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" FontSize="16" Text="🔍" />
                <TextBox Grid.Column="1" FontSize="14" Style="{StaticResource FormTextBox}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Tag="ابحث عن ماركة..." />
                <Button Grid.Column="2" Margin="8,0,0,0" Padding="8,4" VerticalAlignment="Center"
                        Command="{Binding ClearSearchCommand}" Content="✖" FontSize="12" Style="{StaticResource SecondaryButton}"
                        Visibility="{Binding SearchText, Converter={StaticResource StringToVisibilityConverter}}" />
            </Grid>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="1" Background="#242940" CornerRadius="12" Margin="0,0,0,16"
                BorderBrush="#3D4560" BorderThickness="1" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" Direction="270" Opacity="0.08" ShadowDepth="4" Color="#000000" />
            </Border.Effect>
            <DataGrid ItemsSource="{Binding FilteredItems}"
                      SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" SelectionMode="Single"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      BorderThickness="0" RowHeight="44" ColumnHeaderHeight="48"
                      AlternatingRowBackground="#2A3040" Background="White"
                      Foreground="#ECEEF5" FontSize="13" HorizontalGridLinesBrush="#323848">
                <DataGrid.ColumnHeaderStyle>
                    <Style BasedOn="{StaticResource DarkColumnHeader}" TargetType="DataGridColumnHeader" />
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style BasedOn="{StaticResource DarkRow}" TargetType="DataGridRow" />
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <Style BasedOn="{StaticResource DarkCell}" TargetType="DataGridCell" />
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="الكود" Binding="{Binding BrandId}" Width="100"/>
                    <DataGridTextColumn Header="اسم الماركة" Binding="{Binding BrandName}" Width="*"/>
                    <DataGridTextColumn Header="ملاحظات" Binding="{Binding Notes}" Width="*"/>
                    <DataGridTemplateColumn Header="نشط" Width="100"><DataGridTemplateColumn.CellTemplate><DataTemplate><CheckBox IsChecked="{Binding Active, Mode=OneWay}" Style="{StaticResource ToggleSwitchStyle}" IsEnabled="False" HorizontalAlignment="Center"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Form Panel -->
        <Border Grid.Row="2" Background="#272C3F" CornerRadius="12" Padding="24"
                BorderBrush="#3D4560" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" Direction="270" Opacity="0.08" ShadowDepth="6" Color="#000000" />
            </Border.Effect>
            <StackPanel>
                <Grid Margin="0,0,0,24" IsEnabled="{Binding IsEditing}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition Height="16"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="الكود" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding FormItem.BrandId}" Style="{StaticResource FormTextBox}" IsReadOnly="True"/>

                    <TextBlock Grid.Row="0" Grid.Column="3" Text="اسم الماركة" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding FormItem.BrandName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>

                    <CheckBox Style="{StaticResource ToggleSwitchStyle}" Grid.Row="0" Grid.Column="6" Content="نشط" IsChecked="{Binding FormItem.Active}" VerticalAlignment="Center" FontSize="14"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="ملاحظات" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4" Text="{Binding FormItem.Notes, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                </Grid>

                <!-- Buttons + Status -->
                <DockPanel>
                    <WrapPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Button Content="➕ جديد" Style="{StaticResource PrimaryButton}" Margin="0,0,8,8" Command="{Binding AddNewCommand}"/>
                        <Button Content="✏️ تعديل" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8" Command="{Binding EditSelectedCommand}"/>
                        <Button Content="💾 حفظ" Style="{StaticResource PrimaryButton}" Margin="0,0,8,8" Command="{Binding SaveCommand}" IsEnabled="{Binding IsEditing}"/>
                        <Button Content="🗑️ حذف" Style="{StaticResource DangerButton}" Margin="0,0,8,8" Command="{Binding DeleteCommand}"/>
                        <Button Content="✖ إلغاء" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8" Command="{Binding CancelEditCommand}" IsEnabled="{Binding IsEditing}"/>
                    </WrapPanel>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#5BAE7C" FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center" HorizontalAlignment="Left" Margin="24,0,0,0"/>
                </DockPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
