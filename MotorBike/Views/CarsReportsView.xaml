<UserControl x:Class="MotorBike.Views.CarsReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1000"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Background="#F8FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Status Message -->
        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}"
                   Foreground="#6366F1" FontSize="14" FontWeight="SemiBold"
                   Margin="25,0,25,5"/>

        <!-- Filters Section -->
        <Border Grid.Row="0" Margin="20" Background="White" CornerRadius="12" Padding="20">
            <Border.Effect>
                <DropShadowEffect Color="#0F172A" Opacity="0.05" BlurRadius="10" ShadowDepth="2" Direction="270"/>
            </Border.Effect>
            <StackPanel>
                <WrapPanel Margin="0,0,0,10">

                    <!-- نوع التقرير -->
                    <StackPanel Margin="0,0,20,15">
                        <TextBlock Text="نوع التقرير" Foreground="#64748B" FontSize="13" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding ReportTypes}"
                                  SelectedItem="{Binding SelectedReportType}"
                                  Width="230" Padding="8" FontSize="14"/>
                    </StackPanel>

                    <!-- من تاريخ -->
                    <StackPanel Margin="0,0,20,15"
                                Visibility="{Binding IsDateRangeVisible, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <CheckBox IsChecked="{Binding IsFromDateChecked}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="من تاريخ" Foreground="#64748B" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <DatePicker SelectedDate="{Binding FromDate}"
                                    IsEnabled="{Binding IsFromDateChecked}"
                                    Width="150" Padding="6" FontSize="14"/>
                    </StackPanel>

                    <!-- إلى تاريخ -->
                    <StackPanel Margin="0,0,20,15"
                                Visibility="{Binding IsDateRangeVisible, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <CheckBox IsChecked="{Binding IsToDateChecked}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="إلى تاريخ" Foreground="#64748B" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <DatePicker SelectedDate="{Binding ToDate}"
                                    IsEnabled="{Binding IsToDateChecked}"
                                    Width="150" Padding="6" FontSize="14"/>
                    </StackPanel>

                    <!-- اختيار الموديل -->
                    <StackPanel Margin="0,0,20,15"
                                Visibility="{Binding IsCarModelVisible, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="الموديل (اختياري)" Foreground="#64748B" FontSize="13" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding CarModels}"
                                  SelectedItem="{Binding SelectedCarModel}"
                                  DisplayMemberPath="ModelName"
                                  Width="200" Padding="8" FontSize="14"/>
                    </StackPanel>

                    <!-- اختيار موتوسيكل معين -->
                    <StackPanel Margin="0,0,20,15"
                                Visibility="{Binding IsCarVisible, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="اختيار الموتوسيكل" Foreground="#64748B" FontSize="13" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Cars}"
                                  SelectedItem="{Binding SelectedCar}"
                                  DisplayMemberPath="ChassisNo"
                                  Width="220" Padding="8" FontSize="14"/>
                    </StackPanel>

                </WrapPanel>

                <!-- Action Buttons -->
                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="🔍 بحث"
                            Command="{Binding GenerateReportCommand}"
                            Width="120" Height="40"
                            Background="#3B82F6" Foreground="White"
                            FontSize="15" FontWeight="SemiBold" BorderThickness="0" Margin="10,0,0,0">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="🖨️ طباعة التقرير"
                            Command="{Binding PrintPdfCommand}"
                            Width="150" Height="40"
                            Background="#10B981" Foreground="White"
                            FontSize="15" FontWeight="SemiBold" BorderThickness="0" Margin="10,0,0,10">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="📄 تصدير PDF"
                            Command="{Binding ExportPdfCommand}"
                            Width="140" Height="40"
                            Background="#F59E0B" Foreground="White"
                            FontSize="15" FontWeight="SemiBold" BorderThickness="0" Margin="10,0,0,10">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                        </Button.Resources>
                    </Button>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="2" Margin="20,0,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Movement Table -->
            <Border Grid.Row="0" Margin="0,0,0,10" Background="White" CornerRadius="12" Padding="15">
                <Border.Effect>
                    <DropShadowEffect Color="#0F172A" Opacity="0.05" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                </Border.Effect>
                <DataGrid ItemsSource="{Binding ReportData}"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#E2E8F0"
                          BorderThickness="0"
                          Background="White"
                          RowBackground="White"
                          AlternatingRowBackground="#F8FAFC">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Style.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="0"/>
                                </Style>
                            </Style.Resources>
                            <Setter Property="Background"      Value="#F1F5F9"/>
                            <Setter Property="Foreground"      Value="#334155"/>
                            <Setter Property="FontWeight"      Value="SemiBold"/>
                            <Setter Property="Padding"         Value="12,10"/>
                            <Setter Property="BorderBrush"     Value="#E2E8F0"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding"         Value="12,10"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#E0E7FF"/>
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                </DataGrid>
            </Border>

            <!-- Car Status Summary Table (Small) -->
            <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="15"
                    Visibility="{Binding IsCarVisible, Converter={StaticResource BoolToVis}}"
                    d:Visibility="Visible">
                <Border.Effect>
                    <DropShadowEffect Color="#0F172A" Opacity="0.05" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="📋" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="الحالة الحالية للموتوسيكل" FontSize="15" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding CarStatusInfo}"
                              AutoGenerateColumns="True"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#E2E8F0"
                              BorderThickness="1"
                              BorderBrush="#CBD5E1"
                              Background="White"
                              RowBackground="White"
                              MaxHeight="150">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"      Value="#F8FAFC"/>
                                <Setter Property="Foreground"      Value="#475569"/>
                                <Setter Property="FontWeight"      Value="SemiBold"/>
                                <Setter Property="Padding"         Value="10,8"/>
                                <Setter Property="BorderBrush"     Value="#E2E8F0"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
