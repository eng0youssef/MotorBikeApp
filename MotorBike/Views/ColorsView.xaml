<UserControl x:Class="MotorBike.Views.ColorsView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:conv="clr-namespace:MotorBike.Converters" xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" FlowDirection="RightToLeft" Loaded="OnLoaded" mc:Ignorable="d">
    <UserControl.Resources>
        <conv:CashTypeConverter x:Key="TypeConverter" />
        <conv:HideZeroConverter x:Key="HideZeroConv" />
    </UserControl.Resources>
    <Grid MinWidth="600" MinHeight="400" Background="#1E2233">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Search Bar  -->
        <Border Grid.Row="0" Margin="0,0,0,12" Padding="12,8" Background="#272C3F" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" Direction="270" Opacity="0.04" ShadowDepth="2" Color="#0F172A" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" FontSize="16" Text="🔍" />
                <TextBox Grid.Column="1" FontSize="14" Style="{StaticResource FormTextBox}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Tag="ابحث عن لون..." />
                <Button Grid.Column="2" Margin="8,0,0,0" Padding="8,4" VerticalAlignment="Center"
                        Command="{Binding ClearSearchCommand}"
                        Content="✖" FontSize="12" Style="{StaticResource SecondaryButton}"
                        Visibility="{Binding SearchText, Converter={StaticResource StringToVisibilityConverter}}" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,0,0,16" Background="White" BorderBrush="#3D4560" BorderThickness="1"
                ClipToBounds="True" CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Direction="270" Opacity="0.04" ShadowDepth="4" Color="#0F172A" />
            </Border.Effect>
            <DataGrid AlternatingRowBackground="#2A3040" AutoGenerateColumns="False" Background="#242940" BorderThickness="0" CanUserAddRows="False"
                      ColumnHeaderHeight="48" FontSize="14" Foreground="#ECEEF5" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      HorizontalGridLinesBrush="#323848" IsReadOnly="True"
                      ItemsSource="{Binding FilteredItems}"
                      RowHeight="44"
                      SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                      SelectionMode="Single">
                <DataGrid.ColumnHeaderStyle>
                    <Style BasedOn="{StaticResource DarkColumnHeader}" TargetType="DataGridColumnHeader" />
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style BasedOn="{StaticResource DarkRow}" TargetType="DataGridRow" />
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <Style BasedOn="{StaticResource DarkCell}" TargetType="DataGridCell" />
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Width="100"
                                        Binding="{Binding ColorId}"
                                        Header="الكود" />
                    <DataGridTextColumn Width="*"
                                        Binding="{Binding ColorName}"
                                        Header="اسم اللون" />
                    <DataGridTextColumn Width="*"
                                        Binding="{Binding Notes}"
                                        Header="ملاحظات" />
                    <DataGridTemplateColumn Width="100" Header="نشط">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox HorizontalAlignment="Center"
                                          IsChecked="{Binding Active, Mode=OneWay}"
                                          IsEnabled="False"
                                          Style="{StaticResource ToggleSwitchStyle}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        <Border Grid.Row="2" Background="#272C3F" CornerRadius="12" Padding="24"
                BorderBrush="#3D4560" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Direction="270" Opacity="0.04" ShadowDepth="4" Color="#0F172A" />
            </Border.Effect>
            <StackPanel>
                <Grid Margin="0,0,0,24" IsEnabled="{Binding IsEditing}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="16" />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                               Style="{StaticResource FormLabel}"
                               Text="الكود" />
                    <TextBox Grid.Row="0" Grid.Column="1" IsReadOnly="True"
                             Style="{StaticResource FormTextBox}"
                             Text="{Binding FormItem.ColorId, Converter={StaticResource HideZeroConv}}" />
                    <TextBlock Grid.Row="0" Grid.Column="3" VerticalAlignment="Center"
                               Style="{StaticResource FormLabel}"
                               Text="اسم اللون" />
                    <TextBox Grid.Row="0" Grid.Column="4"
                             Style="{StaticResource FormTextBox}"
                             Text="{Binding FormItem.ColorName, UpdateSourceTrigger=PropertyChanged}" />
                    <CheckBox Grid.Row="0" Grid.Column="6" VerticalAlignment="Center" Content="نشط" FontSize="14"
                              IsChecked="{Binding FormItem.Active}"
                              Style="{StaticResource ToggleSwitchStyle}" />
                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                               Style="{StaticResource FormLabel}"
                               Text="ملاحظات" />
                    <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4"
                             Style="{StaticResource FormTextBox}"
                             Text="{Binding FormItem.Notes, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <DockPanel>
                    <WrapPanel DockPanel.Dock="Left" Orientation="Horizontal">
                        <Button Command="{Binding AddNewCommand}"
                                Content="➕ جديد" Margin="0,0,8,8"
                                Style="{StaticResource PrimaryButton}" />
                        <Button Command="{Binding EditSelectedCommand}"
                                Content="✏️ تعديل" Margin="0,0,8,8"
                                Style="{StaticResource SecondaryButton}" />
                        <Button Command="{Binding SaveCommand}"
                                Content="💾 حفظ" Margin="0,0,8,8"
                                IsEnabled="{Binding IsEditing}"
                                Style="{StaticResource PrimaryButton}" />
                        <Button Command="{Binding DeleteCommand}"
                                Content="🗑️ حذف" Margin="0,0,8,8"
                                Style="{StaticResource DangerButton}" />
                        <Button Command="{Binding CancelEditCommand}"
                                Content="✖ إلغاء" Margin="0,0,8,8"
                                IsEnabled="{Binding IsEditing}"
                                Style="{StaticResource SecondaryButton}" />
                    </WrapPanel>
                    <TextBlock Margin="24,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                               Foreground="#5BAE7C"
                               Text="{Binding StatusMessage}" />
                </DockPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
