<UserControl x:Class="MotorBike.Views.ColorsView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:conv="clr-namespace:MotorBike.Converters" xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" FlowDirection="RightToLeft" Loaded="OnLoaded" mc:Ignorable="d">
    <UserControl.Resources>
        <conv:CashTypeConverter x:Key="TypeConverter" />
        <conv:HideZeroConverter x:Key="HideZeroConv" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Margin="0,0,0,16" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                ClipToBounds="True" CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Direction="270" Opacity="0.04" ShadowDepth="4" Color="#0F172A" />
            </Border.Effect>
            <DataGrid AlternatingRowBackground="#F8FAFC" AutoGenerateColumns="False" Background="White" BorderThickness="0" CanUserAddRows="False"
                      ColumnHeaderHeight="48" FontSize="14" Foreground="#1E293B" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      HorizontalGridLinesBrush="#F1F5F9" IsReadOnly="True"
                      ItemsSource="{Binding Items}"
                      RowHeight="44"
                      SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                      SelectionMode="Single">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8FAFC" />
                        <Setter Property="Foreground" Value="#475569" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Padding" Value="16,12" />
                        <Setter Property="BorderBrush" Value="#E2E8F0" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Cursor" Value="Hand" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#DBEAFE" />
                                <Setter Property="Foreground" Value="#1D4ED8" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EFF6FF" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Width="100"
                                        Binding="{Binding ColorId}"
                                        Header="الكود" />
                    <DataGridTextColumn Width="*"
                                        Binding="{Binding ColorName}"
                                        Header="اسم اللون" />
                    <DataGridTextColumn Width="*"
                                        Binding="{Binding Notes}"
                                        Header="ملاحظات" />
                    <DataGridTemplateColumn Width="100" Header="نشط">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox HorizontalAlignment="Center"
                                          IsChecked="{Binding Active, Mode=OneWay}"
                                          IsEnabled="False"
                                          Style="{StaticResource ToggleSwitchStyle}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        <Border Grid.Row="1" Padding="24" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Direction="270" Opacity="0.04" ShadowDepth="4" Color="#0F172A" />
            </Border.Effect>
            <StackPanel>
                <Grid Margin="0,0,0,24" IsEnabled="{Binding IsEditing}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="16" />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                               Style="{StaticResource FormLabel}"
                               Text="الكود" />
                    <TextBox Grid.Row="0" Grid.Column="1" IsReadOnly="True"
                             Style="{StaticResource FormTextBox}"
                             Text="{Binding FormItem.ColorId, Converter={StaticResource HideZeroConv}}" />
                    <TextBlock Grid.Row="0" Grid.Column="3" VerticalAlignment="Center"
                               Style="{StaticResource FormLabel}"
                               Text="اسم اللون" />
                    <TextBox Grid.Row="0" Grid.Column="4"
                             Style="{StaticResource FormTextBox}"
                             Text="{Binding FormItem.ColorName, UpdateSourceTrigger=PropertyChanged}" />
                    <CheckBox Grid.Row="0" Grid.Column="6" VerticalAlignment="Center" Content="نشط" FontSize="14"
                              IsChecked="{Binding FormItem.Active}"
                              Style="{StaticResource ToggleSwitchStyle}" />
                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                               Style="{StaticResource FormLabel}"
                               Text="ملاحظات" />
                    <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4"
                             Style="{StaticResource FormTextBox}"
                             Text="{Binding FormItem.Notes, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                        <Button Command="{Binding AddNewCommand}"
                                Content="➕ جديد"
                                Style="{StaticResource PrimaryButton}" />
                        <Button Command="{Binding EditSelectedCommand}"
                                Content="✏️ تعديل"
                                Style="{StaticResource SecondaryButton}" />
                        <Button Command="{Binding SaveCommand}"
                                Content="💾 حفظ"
                                IsEnabled="{Binding IsEditing}"
                                Style="{StaticResource PrimaryButton}" />
                        <Button Command="{Binding DeleteCommand}"
                                Content="🗑️ حذف"
                                Style="{StaticResource DangerButton}" />
                        <Button Command="{Binding CancelEditCommand}"
                                Content="✖ إلغاء"
                                IsEnabled="{Binding IsEditing}"
                                Style="{StaticResource SecondaryButton}" />
                    </StackPanel>
                    <TextBlock Margin="24,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                               Foreground="#10B981"
                               Text="{Binding StatusMessage}" />
                </DockPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
