<Window x:Class="MotorBike.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تسجيل الدخول" MinHeight="680" MinWidth="450"
        WindowStartupLocation="CenterScreen" 
        FlowDirection="RightToLeft"
        Background="#F8FAFC">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.6"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
    <Grid>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="Grid.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,30,0,-30" To="0" Duration="0:0:0.6">
                            <ThicknessAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </ThicknessAnimation.EasingFunction>
                        </ThicknessAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>
        <!-- Background Banner -->
        <Border Background="#272C3F" MinHeight="220" VerticalAlignment="Top" />
        
        <Border Background="White" CornerRadius="16" Margin="32,48,32,32" Padding="32" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#0F172A" Opacity="0.08" BlurRadius="24" ShadowDepth="8" Direction="270" />
            </Border.Effect>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="🏍️" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="تسجيل الدخول" FontSize="22" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,0,0,32"/>

                <TextBlock Text="اسم المستخدم" Foreground="#272C3F" FontSize="15" Style="{StaticResource FormLabel}" />
                <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" Foreground="White" Style="{StaticResource FormTextBox}" Margin="0,0,0,16"/>

                <TextBlock Text="كلمة المرور" Foreground="#272C3F" FontSize="15" Style="{StaticResource FormLabel}"/>
                <!-- Password Box simulated with the same input styling -->
                <Border BorderBrush="#CBD5E1"  BorderThickness="1" CornerRadius="8" Background="#272C3F" Padding="12,10" Margin="0,0,0,24">
                    <PasswordBox x:Name="txtPassword"  Background="Transparent" BorderThickness="0" Foreground="White" FontSize="14" PasswordChanged="txtPassword_PasswordChanged"/>
                </Border>
                
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#EF4444" FontSize="13" Margin="0,0,0,16" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
                
                <Button Content="دخول" Style="{StaticResource PrimaryButton}" Command="{Binding LoginCommand}" FontSize="15" Padding="0,14"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
