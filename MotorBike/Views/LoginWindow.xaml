<Window x:Class="MotorBike.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تسجيل الدخول" Height="500" Width="750"
        WindowStartupLocation="CenterScreen" 
        FlowDirection="RightToLeft"
        Background="#1E2233"
        ResizeMode="NoResize"
        FocusManager.FocusedElement="{Binding ElementName=txtUserName}">
    
    <Window.Resources>
        <!--  Header style  -->
        <Style x:Key="LoginHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="26" />
            <Setter Property="FontWeight" Value="ExtraBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        
        <Style x:Key="LoginSubHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#7B84A0" />
            <Setter Property="Margin" Value="0,0,0,32" />
        </Style>

        <Style x:Key="SidePanelText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Opacity" Value="0.8" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Accent Panel -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#E8A54B" />
                    <GradientStop Offset="1" Color="#D4922F" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <!-- Decorative Elements -->
                <Ellipse Width="400" Height="400" Margin="-200,-100,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Fill="White" Opacity="0.05" />
                <Ellipse Width="200" Height="200" Margin="0,0,-100,-50" HorizontalAlignment="Right" VerticalAlignment="Bottom" Fill="Black" Opacity="0.1" />
                
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                    <Border Width="80" Height="80" CornerRadius="20" Background="White" Opacity="0.9" Margin="0,0,0,20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" Opacity="0.1" ShadowDepth="4" />
                        </Border.Effect>
                        <TextBlock Text="🏍️" FontSize="42" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Motor Bike" FontSize="20" FontWeight="Bold" Foreground="White"  Margin="0,-4,0,16" HorizontalAlignment="Center" />
                    <Border Height="3" Width="50" Background="White" Opacity="0.5" CornerRadius="1.5" Margin="0,0,0,24" />
                    <TextBlock Text=" إدارة المبيعات والمخازن بكفاءة " Style="{StaticResource SidePanelText}" TextWrapping="Wrap" />
                </StackPanel>

            </Grid>
        </Border>

        <!-- Right Login Form -->
        <Border Grid.Column="1" Background="#1E2233" Padding="50,0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="تسجيل الدخول" Style="{StaticResource LoginHeader}" />
                <TextBlock Text="الرجاء إدخال بيانات المستخدم للبدء" Style="{StaticResource LoginSubHeader}" />

                <!-- Username Input -->
                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="اسم المستخدم" Style="{StaticResource FormLabel}" Foreground="#9BA4B5" Margin="0,0,0,8" />
                    <TextBox x:Name="txtUserName"
                             Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource FormTextBox}" 
                             VerticalContentAlignment="Center"
                             Height="58"
                             KeyDown="txtUserName_KeyDown"/>
                </StackPanel>

                <!-- Password Input -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock Text="كلمة المرور" Style="{StaticResource FormLabel}" Foreground="#9BA4B5" Margin="0,0,0,8" />
                    <Border BorderBrush="#3D4560" BorderThickness="1" CornerRadius="8" Background="#272C3F" Height="48">
                        <Grid>
                            <PasswordBox x:Name="txtPassword" 
                                         CaretBrush="#E8A54B" 
                                         SelectionBrush="#E8A54B" 
                                         Background="Transparent" 
                                         BorderThickness="0" 
                                         Foreground="#ECEEF5" 
                                         FontSize="14" 
                                         Padding="12,0"
                                         VerticalContentAlignment="Center"
                                         PasswordChanged="txtPassword_PasswordChanged"
                                         KeyDown="txtPassword_KeyDown"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Error Message -->
                <Border Height="40" Margin="0,-10,0,10" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#D9534F" FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center"/>
                </Border>

                <!-- Action Buttons -->
                <Button Content="تسجيل دخول " 
                        Style="{StaticResource PrimaryButton}" 
                        Command="{Binding LoginCommand}" 
                        Height="48" 
                        FontSize="15" 
                        FontWeight="Bold" />

                <Button Content="إعدادات التفعيل" 
                        Style="{StaticResource SecondaryButton}" 
                        Margin="0,12,0,0"
                        Height="40" 
                        FontSize="13"
                        Click="btnActivation_Click" />

            </StackPanel>
        </Border>
    </Grid>
</Window>
