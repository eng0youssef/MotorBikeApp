<UserControl x:Class="MotorBike.Views.ImportInvoiceView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:conv="clr-namespace:MotorBike.Converters" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" FlowDirection="RightToLeft" Loaded="OnLoaded"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:HideZeroConverter x:Key="HideZeroConv" />
        <conv:IdToNameConverter x:Key="IdToNameConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        <Style x:Key="FormCard" TargetType="Border">
            <Setter Property="Background" Value="#272C3F" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#3D4560" />
            <Setter Property="Margin" Value="24" />
            <Setter Property="Padding" Value="32" />
        </Style>
        <Style x:Key="FormContainerStyle" TargetType="Grid">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="False">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SearchContainerStyle" TargetType="Grid">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>


    </UserControl.Resources>

    <Grid MinWidth="850" MinHeight="500" Background="#1E2233">
        <!--  FORM Section  -->
        <Grid Style="{StaticResource FormContainerStyle}">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" ScrollChanged="ScrollViewer_ScrollChanged" VerticalScrollBarVisibility="Auto">
                <Border Style="{StaticResource FormCard}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="24" Direction="270" Opacity="0.08" ShadowDepth="4" Color="#000000" />
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" /> 
                            <!--  Header  -->
                            <RowDefinition Height="Auto" /> 
                            <!--  Separator  -->
                            <RowDefinition Height="Auto" /> 
                            <!--  Main Info  -->
                            <RowDefinition Height="Auto" /> 
                            <!--  TabControl for SubItems  -->
                            <RowDefinition Height="Auto" /> 
                            <!--  Recalc Button  -->
                            <RowDefinition Height="Auto" /> 
                            <!--  Totals  -->
                            <RowDefinition Height="Auto" /> 
                            <!--  Actions  -->
                        </Grid.RowDefinitions>

                        <!--  Header  -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Border Margin="0,0,16,0" Padding="14,12" Background="#2F3549" CornerRadius="12">
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="26" Text="🌍" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock FontSize="22" FontWeight="Bold" Foreground="White" Text="فاتورة الاستيراد" />
                                    <TextBlock Margin="0,4,0,0" FontSize="14" Foreground="#9BA4B5" Text="تسجيل شحنات الاستيراد بتفاصيلها" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                                <Button Margin="0,0,12,0" Padding="16,10"
                                        Command="{Binding ShowSearchPanelCommand}"
                                        Content="🔍 بحث عن فاتورة سابقة"
                                        Style="{StaticResource SecondaryButton}" />
                                <Button Padding="16,10" Command="{Binding AddNewRecordCommand}" Content="➕ تـسـجيـل فاتورة جـديـدة" Style="{StaticResource PrimaryButton}" />
                            </StackPanel>
                        </Grid>

                        <Rectangle Grid.Row="1" Height="1" Margin="0,8,0,24" Fill="#3D4560" />

                        <!--  Main Info  -->
                        <Grid Grid.Row="2" IsEnabled="{Binding IsEditing}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" /> 
                                <ColumnDefinition Width="*" /> 
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="Auto" /> 
                                <ColumnDefinition Width="*" /> 
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="Auto" /> 
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /> 
                                <RowDefinition Height="20" />
                                <RowDefinition Height="Auto" /> 
                                <RowDefinition Height="20" />
                                <RowDefinition Height="Auto" /> 
                                <RowDefinition Height="20" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="رقم الفاتورة" />
                            <TextBox Grid.Row="0" Grid.Column="1" Background="#1E2233" FontWeight="Bold" IsReadOnly="True"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding FormItem.InvId, Converter={StaticResource HideZeroConv}}" />
                            <TextBlock Grid.Row="0" Grid.Column="3" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="التاريخ" />
                            <DatePicker Grid.Row="0" Grid.Column="4" Padding="10,4" FontSize="14"
                                        SelectedDate="{Binding FormItem.InvDate}" />
                            <TextBlock Grid.Row="0" Grid.Column="6" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="المورد" />
                            <!--  Supplier Smart Search  -->
                            <Grid Grid.Row="0" Grid.Column="7">
                                <TextBox x:Name="SupplierSearchBox" Padding="8,6" GotFocus="SupplierSearch_GotFocus"
                                         Style="{StaticResource FormTextBox}"
                                         Text="{Binding SupplierSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="ابحث عن المورد بالاسم" />
                                <Popup x:Name="SupplierSearchPopup"
                                       Width="{Binding ActualWidth, ElementName=SupplierSearchBox}"
                                       AllowsTransparency="True"
                                       IsOpen="{Binding IsSupplierSearchPopupOpen}"
                                       Placement="Bottom"
                                       PlacementTarget="{Binding ElementName=SupplierSearchBox}"
                                       StaysOpen="False">
                                    <Border MaxHeight="250" Background="#272C3F" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="8">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="16" Direction="270" Opacity="0.15" ShadowDepth="4" Color="#000000" />
                                        </Border.Effect>
                                        <ListBox Background="Transparent" BorderThickness="0" ItemsSource="{Binding FilteredSuppliersList}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="10,7" Cursor="Hand">
                                                        <TextBlock FontSize="13" Foreground="#ECEEF5" Text="{Binding SuppName, Mode=OneWay}" />
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                    <Setter Property="Padding" Value="0" />
                                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="SearchSupplier_Click" />
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#EFF6FF" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                        </ListBox>
                                    </Border>
                                </Popup>
                            </Grid>

                            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="اسم الشحنة" />
                            <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource FormTextBox}" Text="{Binding FormItem.InvName, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="2" Grid.Column="3" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="بلد المنشأ" />
                            <TextBox Grid.Row="2" Grid.Column="4" Style="{StaticResource FormTextBox}" Text="{Binding FormItem.MadeIn, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="2" Grid.Column="6" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="ميناء الشحن" />
                            <TextBox Grid.Row="2" Grid.Column="7" Style="{StaticResource FormTextBox}" Text="{Binding FormItem.ShipPort, UpdateSourceTrigger=PropertyChanged}" />

                            <!--  نوع الفاتورة FOB / CIF  -->
                            <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="نوع الفاتورة" />
                            <ComboBox Grid.Row="4" Grid.Column="1" Padding="10,6" DisplayMemberPath="Name" FontSize="14" FontWeight="SemiBold"
                                      ItemsSource="{Binding InvTypeList}"
                                      SelectedValue="{Binding SelectedInvType}"
                                      SelectedValuePath="Id" />
                            <TextBlock Grid.Row="4" Grid.Column="3" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="العملة" />
                            <ComboBox Grid.Row="4" Grid.Column="4" Padding="10,6" DisplayMemberPath="OmlaName" FontSize="14" IsEnabled="False"
                                      ItemsSource="{Binding Omlas}"
                                      SelectedValue="{Binding SelectedOmlaId}"
                                      SelectedValuePath="OmlaId" ToolTip="تُحدد تلقائياً من المورد" />
                            <TextBlock Grid.Row="4" Grid.Column="6" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="سعر الصرف" />
                            <TextBox Grid.Row="4" Grid.Column="7" Background="#1E2233" FontWeight="Bold" IsReadOnly="True"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding FormItem.OmlaRate, Mode=OneWay, StringFormat=\{0:N2\}}"
                                     ToolTip="يُثبّت من سعر العملة وقت إنشاء الفاتورة" />

                            <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center"
                                       Style="{StaticResource FormLabel}"
                                       Text="ملاحظات" />
                            <TextBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="7"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding FormItem.Notes, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <!--  TABS  -->
                        <TabControl Grid.Row="3" Margin="0,32,0,16" IsEnabled="{Binding IsEditing}">
                            <TabControl.Resources>
                                <Style TargetType="TabItem">
                                    <Setter Property="Padding" Value="16,8" />
                                    <Setter Property="FontSize" Value="15" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Foreground" Value="#64748B" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0,0,0,2" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Foreground" Value="#6366F1" />
                                            <Setter Property="BorderBrush" Value="#6366F1" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3D4560" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TabControl.Resources>

                            <!--  الأصناف  -->
                            <TabItem Header="📦 الأصناف المستوردة">
                                <Grid Margin="0,16,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Margin="0,0,0,16" Padding="16" Background="#1E2233" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3*" /> 
                                                <ColumnDefinition Width="2*" /> 
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="1.5*" /> 
                                                <ColumnDefinition Width="1.5*" /> 
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <!--  Smart Item Search  -->
                                            <Grid Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock Margin="2,-16,0,0" FontSize="11" Foreground="#9BA4B5" Text="✍️ بحث ذكي (بالاسم أو الباركود)" />
                                                <TextBox x:Name="ItemSearchBox" Padding="8,6" GotFocus="ItemSearch_GotFocus"
                                                         Style="{StaticResource FormTextBox}"
                                                         Text="{Binding ItemSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                         ToolTip="ابحث هنا عن الأصناف" />
                                                <Popup x:Name="ItemSearchPopup"
                                                       Width="{Binding ActualWidth, ElementName=ItemSearchBox}"
                                                       AllowsTransparency="True"
                                                       IsOpen="{Binding IsItemSearchPopupOpen}"
                                                       Placement="Bottom"
                                                       PlacementTarget="{Binding ElementName=ItemSearchBox}"
                                                       StaysOpen="False">
                                                    <Border MaxHeight="250" Background="#272C3F" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="8">
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="16" Direction="270" Opacity="0.15" ShadowDepth="4" Color="#000000" />
                                                        </Border.Effect>
                                                        <ListBox Background="Transparent" BorderThickness="0" ItemsSource="{Binding FilteredItemsList}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Padding="8,6" Cursor="Hand">
                                                                        <TextBlock FontSize="13" Foreground="#ECEEF5">
                                                                            <Run Text="{Binding ItemName, Mode=OneWay}" /><Run Foreground="#94A3B8" Text=" — " /><Run FontSize="11" Foreground="#9BA4B5" Text="سعر الاستيراد: " /><Run FontWeight="SemiBold" Foreground="#1D4ED8" Text="{Binding ImpPrice, StringFormat=\{0:N2\}, Mode=OneWay}" />
                                                                        </TextBlock>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                            <ListBox.ItemContainerStyle>
                                                                <Style TargetType="ListBoxItem">
                                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                                    <Setter Property="Padding" Value="0" />
                                                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="SearchItem_Click" />
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="#EFF6FF" />
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ListBox.ItemContainerStyle>
                                                        </ListBox>
                                                    </Border>
                                                </Popup>
                                            </Grid>
                                            <Grid Grid.Column="1" Margin="0,0,8,0">
                                                <TextBlock Margin="2,-16,0,0" FontSize="11" Foreground="#9BA4B5" Text="المخزن" />
                                                <ComboBox Padding="8,6" DisplayMemberPath="StoreName" FontSize="13"
                                                          ItemsSource="{Binding Stores}"
                                                          SelectedValue="{Binding CurrentSubItem.StoreId}"
                                                          SelectedValuePath="StoreId" />
                                            </Grid>
                                            <Grid Grid.Column="2" Margin="0,0,8,0">
                                                <TextBlock Margin="2,-16,0,0" FontSize="11" Foreground="#9BA4B5" Text="الوحدة" />
                                                <ComboBox Padding="8,6" DisplayMemberPath="UnitName" FontSize="13"
                                                          ItemsSource="{Binding CurrentItemUnits}"
                                                          SelectedValue="{Binding CurrentSubItemUnitId}"
                                                          SelectedValuePath="UnitId" />
                                            </Grid>
                                            <Grid Grid.Column="3" Margin="0,0,8,0">
                                                <TextBlock Margin="2,-16,0,0" FontSize="11" Foreground="#9BA4B5" Text="الكمية" />
                                                <TextBox FontSize="13" Style="{StaticResource FormTextBox}" Text="{Binding CurrentSubItem.Qty, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>
                                            <Grid Grid.Column="4" Margin="0,0,16,0">
                                                <TextBlock Margin="2,-16,0,0" FontSize="11" Foreground="#9BA4B5" Text="السعر الاستيرادي" />
                                                <TextBox FontSize="13" Style="{StaticResource FormTextBox}" Text="{Binding CurrentSubItem.Price, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>
                                            <Button Grid.Column="5" Padding="16,8"
                                                    Command="{Binding AddSubItemCommand}"
                                                    Content="➕ إضافة"
                                                    Style="{StaticResource PrimaryButton}" />
                                        </Grid>
                                    </Border>
                                    <DataGrid Grid.Row="1" MinHeight="150" AlternatingRowBackground="#222738" AutoGenerateColumns="False" Background="#242940" BorderBrush="#3D4560" BorderThickness="1" CanUserAddRows="False"
                                              CellEditEnding="DataGrid_CellEditEnding" FontSize="13" Foreground="#C8CEE0" GridLinesVisibility="Horizontal" HeadersVisibility="Column" HorizontalGridLinesBrush="#323848" IsReadOnly="False"
                                              ItemsSource="{Binding FormItems}"
                                              SelectionMode="Single">
                                        <DataGrid.ColumnHeaderStyle>
                                            <Style BasedOn="{StaticResource DarkColumnHeader}" TargetType="DataGridColumnHeader" />
                                        </DataGrid.ColumnHeaderStyle>
                                        <DataGrid.RowStyle>
                                            <Style BasedOn="{StaticResource DarkRow}" TargetType="DataGridRow" />
                                        </DataGrid.RowStyle>
                                        <DataGrid.CellStyle>
                                            <Style BasedOn="{StaticResource DarkCell}" TargetType="DataGridCell" />
                                        </DataGrid.CellStyle>
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Width="*" Header="الصنف" IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Padding="4,0" VerticalAlignment="Center">
                                                            <TextBlock.Text>
                                                                <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="ItemId,ItemName">
                                                                    <Binding Path="ItemId" />
                                                                    <Binding Path="DataContext.ItemsList" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Width="70" Binding="{Binding Qty, UpdateSourceTrigger=LostFocus}" Header="الكمية" />
                                            <DataGridTextColumn Width="80" Binding="{Binding Price, StringFormat=\{0:N2\}, UpdateSourceTrigger=LostFocus}" Header="السعر" />
                                            <DataGridTextColumn Width="90"
                                                                Binding="{Binding Total, StringFormat=\{0:N2\}}"
                                                                FontWeight="SemiBold" Header="الإجمالي (بالعملة)" IsReadOnly="True" />
                                            <DataGridTextColumn Width="90"
                                                                Binding="{Binding TotalLocal, StringFormat=\{0:N2\}}"
                                                                FontWeight="SemiBold" Header="الإجمالي (محلي)" IsReadOnly="True" />
                                            <DataGridTextColumn Width="80" Binding="{Binding CostPer, StringFormat=\{0:N4\}, UpdateSourceTrigger=LostFocus}" Foreground="#6366F1" Header="النسبة %" />
                                            <DataGridTextColumn Width="100"
                                                                Binding="{Binding ExpShareLocal, StringFormat=\{0:N2\}}"
                                                                Foreground="#DC2626" Header="تحمّل مصاريف (محلي)" IsReadOnly="True" />
                                            <DataGridTextColumn Width="100"
                                                                Binding="{Binding CostTotal, StringFormat=\{0:N2\}}"
                                                                FontWeight="SemiBold" Foreground="#059669" Header="الإجمالي النهائي (محلي)" IsReadOnly="True" />
                                            <DataGridTextColumn Width="90"
                                                                Binding="{Binding CostUnit, StringFormat=\{0:N2\}}"
                                                                FontWeight="SemiBold" Foreground="#0284C7" Header="تكلفة الوحدة (محلي)" IsReadOnly="True" />
                                            <DataGridTemplateColumn Width="50">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Background="Transparent" BorderThickness="0"
                                                                Command="{Binding DataContext.RemoveSubItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Content="🗑️" FontSize="14" Foreground="Red" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>

                                    </DataGrid>
                                </Grid>
                            </TabItem>

                            <!--  الموتوسيكلات  -->
                            <TabItem Header="🏍️ الموتوسيكلات">
                                <Grid Margin="0,16,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Margin="0,0,0,16" Padding="16" Background="#1E2233" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="12">
                                        <StackPanel>
                                            <TextBlock Margin="0,0,0,12" FontSize="12" FontWeight="SemiBold" Foreground="#9BA4B5" Text="تسجيل موتوسيكل جديد للشحنة:" />
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.5*" /> 
                                                    <ColumnDefinition Width="1.5*" /> 
                                                    <ColumnDefinition Width="*" /> 
                                                    <ColumnDefinition Width="*" /> 
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid Grid.Column="0" Margin="0,0,8,0">
                                                    <TextBlock Margin="2,-16,0,0" FontSize="11" Foreground="#9BA4B5" Text="الماركة" />
                                                    <ComboBox Padding="8,4" DisplayMemberPath="BrandName" FontSize="13" IsEditable="True" IsTextSearchEnabled="True"
                                                              ItemsSource="{Binding CarBrands}"
                                                              Text="{Binding NewCarBrandName, UpdateSourceTrigger=PropertyChanged}" />
                                                </Grid>
                                                <Grid Grid.Column="1" Margin="0,0,8,0">
                                                    <TextBlock Margin="2,-16,0,0" FontSize="11" Foreground="#9BA4B5" Text="الطراز *" />
                                                    <ComboBox Padding="8,4" DisplayMemberPath="ModelName" FontSize="13" IsEditable="True" IsTextSearchEnabled="True"
                                                              ItemsSource="{Binding FilteredCarModels}"
                                                              Text="{Binding NewCarModelName, UpdateSourceTrigger=PropertyChanged}" />
                                                </Grid>
                                                <Grid Grid.Column="2" Margin="0,0,8,0">
                                                    <TextBlock Margin="2,-16,0,0" FontSize="11" Foreground="#9BA4B5" Text="رقم الشاسيه *" />
                                                    <TextBox FontSize="13" Style="{StaticResource FormTextBox}" Text="{Binding NewCarChassisNo, UpdateSourceTrigger=PropertyChanged}" />
                                                </Grid>
                                                <Grid Grid.Column="3" Margin="0,0,8,0">
                                                    <TextBlock Margin="2,-16,0,0" FontSize="11" Foreground="#9BA4B5" Text="رقم الموتور" />
                                                    <TextBox FontSize="13" Style="{StaticResource FormTextBox}" Text="{Binding NewCarMotorNo, UpdateSourceTrigger=PropertyChanged}" />
                                                </Grid>
                                                <Grid Grid.Column="4" Margin="0,0,0,0">
                                                    <TextBlock Margin="2,-16,0,0" FontSize="11" Foreground="#9BA4B5" Text="رقم اللوحة" />
                                                    <TextBox FontSize="13" Style="{StaticResource FormTextBox}" Text="{Binding NewCarPlateNo, UpdateSourceTrigger=PropertyChanged}" />
                                                </Grid>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" /> 
                                                    <ColumnDefinition Width="*" /> 
                                                    <ColumnDefinition Width="*" /> 
                                                    <ColumnDefinition Width="*" /> 
                                                    <ColumnDefinition Width="1.5*" /> 
                                                    <ColumnDefinition Width="1.5*" /> 
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Grid Grid.Column="0" Margin="0,0,8,0">
                                                    <TextBlock Margin="2,-16,0,0" FontSize="11" Foreground="#9BA4B5" Text="سنة الصنع" />
                                                    <TextBox FontSize="13" Style="{StaticResource FormTextBox}" Text="{Binding NewCarYearNo, UpdateSourceTrigger=PropertyChanged}" />
                                                </Grid>
                                                <Grid Grid.Column="1" Margin="0,0,8,0">
                                                    <TextBlock Margin="2,-16,0,0" FontSize="11" Foreground="#9BA4B5" Text="اللون *" />
                                                    <ComboBox Padding="8,4" DisplayMemberPath="ColorName" FontSize="13" IsEditable="True" IsTextSearchEnabled="True"
                                                              ItemsSource="{Binding Colors}"
                                                              Text="{Binding NewCarColorName, UpdateSourceTrigger=PropertyChanged}" />
                                                </Grid>
                                                <Grid Grid.Column="2" Margin="0,0,8,0">
                                                    <TextBlock Margin="2,-16,0,0" FontSize="11" Foreground="#9BA4B5" Text="الكيلومتر" />
                                                    <TextBox FontSize="13" Style="{StaticResource FormTextBox}" Text="{Binding NewCarMileage, UpdateSourceTrigger=PropertyChanged}" />
                                                </Grid>
                                                <Grid Grid.Column="3" Margin="0,0,8,0">
                                                    <TextBlock Margin="2,-16,0,0" FontSize="11" Foreground="#9BA4B5" Text="CC" />
                                                    <TextBox FontSize="13" Style="{StaticResource FormTextBox}" Text="{Binding NewCarCC, UpdateSourceTrigger=PropertyChanged}" ToolTip="السعة الاسطوانية بالسم المكعب" />
                                                </Grid>
                                                <Grid Grid.Column="4" Margin="0,0,8,0">
