                                                                    <Binding Path="DataContext.FilteredPaymentCashList" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                                <DataGridTemplateColumn.CellEditingTemplate>
                                                    <DataTemplate>
                                                        <ComboBox Padding="4,2" Background="#242940" DisplayMemberPath="CashName" FontSize="13" Foreground="#C8CEE0"
                                                                  ItemsSource="{Binding DataContext.FilteredPaymentCashList, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  SelectedValue="{Binding CashId, UpdateSourceTrigger=PropertyChanged}"
                                                                  SelectedValuePath="CashId" />
