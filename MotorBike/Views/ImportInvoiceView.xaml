<UserControl x:Class="MotorBike.Views.ImportInvoiceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MotorBike.Converters"
             mc:Ignorable="d" xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Loaded="OnLoaded" FlowDirection="RightToLeft">
    <UserControl.Resources>
        <conv:IdToNameConverter x:Key="IdToNameConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="FormCard" TargetType="Border">
            <Setter Property="Background" Value="White"/><Setter Property="CornerRadius" Value="16"/><Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/><Setter Property="Margin" Value="24"/><Setter Property="Padding" Value="32"/>
        </Style>
        <Style x:Key="FormContainerStyle" TargetType="Grid">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="False"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SearchContainerStyle" TargetType="Grid">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="False"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/><Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/><Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F8FAFC">
        <!-- FORM Section -->
        <Grid Style="{StaticResource FormContainerStyle}">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" ScrollChanged="ScrollViewer_ScrollChanged">
                <Border Style="{StaticResource FormCard}">
                    <Border.Effect><DropShadowEffect Color="#0F172A" Opacity="0.04" BlurRadius="24" ShadowDepth="4" Direction="270"/></Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Header -->
                            <RowDefinition Height="Auto"/> <!-- Separator -->
                            <RowDefinition Height="Auto"/> <!-- Main Info -->
                            <RowDefinition Height="Auto"/> <!-- TabControl for SubItems -->
                            <RowDefinition Height="Auto"/> <!-- Totals -->
                            <RowDefinition Height="Auto"/> <!-- Actions -->
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Column="0">
                                <Border Background="#EEF2FF" CornerRadius="12" Padding="14,12" Margin="0,0,16,0">
                                    <TextBlock Text="🌍" FontSize="26" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="فاتورة الاستديراد" FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
                                    <TextBlock Text="تسجيل شحنات الاستيراد بتفاصيلها" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="🔍 بحث عن فاتورة سابقة" Style="{StaticResource SecondaryButton}" Command="{Binding ShowSearchPanelCommand}" Margin="0,0,12,0" Padding="16,10"/>
                                <Button Content="➕ تـسـجيـل فاتورة جـديـدة" Style="{StaticResource PrimaryButton}" Command="{Binding AddNewRecordCommand}" Padding="16,10"/>
                            </StackPanel>
                        </Grid>

                        <Rectangle Grid.Row="1" Height="1" Fill="#E2E8F0" Margin="0,8,0,24"/>

                        <!-- Main Info -->
                        <Grid Grid.Row="2" IsEnabled="{Binding IsEditing}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/> <ColumnDefinition Width="180"/> <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="100"/> <ColumnDefinition Width="180"/> <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="100"/> <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <RowDefinition Height="20"/>
                                <RowDefinition Height="Auto"/> <RowDefinition Height="20"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="رقم الفاتورة" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding FormItem.InvId}" Style="{StaticResource FormTextBox}" IsReadOnly="True" Background="#F8FAFC" FontWeight="Bold"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="التاريخ" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <DatePicker Grid.Row="0" Grid.Column="4" SelectedDate="{Binding FormItem.InvDate}" Padding="10,4" FontSize="14"/>
                            <TextBlock Grid.Row="0" Grid.Column="6" Text="المورد" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <!-- Supplier Smart Search -->
                            <Grid Grid.Row="0" Grid.Column="7">
                                <TextBox x:Name="SupplierSearchBox" Text="{Binding SupplierSearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" Padding="8,6" ToolTip="ابحث عن المورد بالاسم" GotFocus="SupplierSearch_GotFocus"/>
                                <Popup x:Name="SupplierSearchPopup" IsOpen="{Binding IsSupplierSearchPopupOpen}" StaysOpen="False" Placement="Bottom" PlacementTarget="{Binding ElementName=SupplierSearchBox}" Width="{Binding ActualWidth, ElementName=SupplierSearchBox}" AllowsTransparency="True">
                                    <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" MaxHeight="250">
                                        <Border.Effect><DropShadowEffect Color="#0F172A" Opacity="0.1" BlurRadius="16" ShadowDepth="4" Direction="270"/></Border.Effect>
                                        <ListBox ItemsSource="{Binding FilteredSuppliersList}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemTemplate><DataTemplate>
                                                <Border Padding="10,7" Cursor="Hand"><TextBlock FontSize="13" Foreground="#334155" Text="{Binding SuppName, Mode=OneWay}"/></Border>
                                            </DataTemplate></ListBox.ItemTemplate>
                                            <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="Padding" Value="0"/>
                                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="SearchSupplier_Click"/>
                                                <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#EFF6FF"/></Trigger></Style.Triggers>
                                            </Style></ListBox.ItemContainerStyle>
                                        </ListBox>
                                    </Border>
                                </Popup>
                            </Grid>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="اسم الشحنة" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding FormItem.InvName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="بلد المنشأ" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="4" Text="{Binding FormItem.MadeIn, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                            <TextBlock Grid.Row="2" Grid.Column="6" Text="ميناء الشحن" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="7" Text="{Binding FormItem.ShipPort, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="العملة" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding Omlas}" DisplayMemberPath="OmlaName" SelectedValuePath="OmlaId" SelectedValue="{Binding SelectedOmlaId}" Padding="10,6" FontSize="14"/>
                            <TextBlock Grid.Row="4" Grid.Column="3" Text="سعر الصرف" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="4" Grid.Column="4" Text="{Binding FormItem.OmlaRate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                            <TextBlock Grid.Row="4" Grid.Column="6" Text="ملاحظات" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="4" Grid.Column="7" Text="{Binding FormItem.Notes, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                        </Grid>

                        <!-- TABS -->
                        <TabControl Grid.Row="3" Margin="0,32,0,16" IsEnabled="{Binding IsEditing}">
                            <TabControl.Resources>
                                <Style TargetType="TabItem">
                                    <Setter Property="Padding" Value="16,8"/>
                                    <Setter Property="FontSize" Value="15"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#64748B"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Foreground" Value="#6366F1"/>
                                            <Setter Property="BorderBrush" Value="#6366F1"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F8FAFC"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TabControl.Resources>

                            <!-- الأصناف -->
                            <TabItem Header="📦 الأصناف المستوردة">
                                <Grid Margin="0,16,0,0">
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#F8FAFC" CornerRadius="12" Padding="16" Margin="0,0,0,16" BorderBrush="#E2E8F0" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/> <ColumnDefinition Width="100"/> <ColumnDefinition Width="100"/> 
                                                <ColumnDefinition Width="80"/> <ColumnDefinition Width="90"/> <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Smart Item Search -->
                                            <Grid Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock Text="✍️ بحث ذكي (بالاسم أو الباركود)" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                                <TextBox x:Name="ItemSearchBox" Text="{Binding ItemSearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" Padding="8,6" ToolTip="ابحث هنا عن الأصناف" GotFocus="ItemSearch_GotFocus"/>
                                                <Popup x:Name="ItemSearchPopup" IsOpen="{Binding IsItemSearchPopupOpen}" StaysOpen="False" Placement="Bottom" PlacementTarget="{Binding ElementName=ItemSearchBox}" Width="{Binding ActualWidth, ElementName=ItemSearchBox}" AllowsTransparency="True">
                                                    <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" MaxHeight="250">
                                                        <Border.Effect><DropShadowEffect Color="#0F172A" Opacity="0.1" BlurRadius="16" ShadowDepth="4" Direction="270"/></Border.Effect>
                                                        <ListBox ItemsSource="{Binding FilteredItemsList}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                            <ListBox.ItemTemplate><DataTemplate>
                                                                <Border Padding="8,6" Cursor="Hand"><TextBlock FontSize="13" Foreground="#334155">
                                                                    <Run Text="{Binding ItemName, Mode=OneWay}"/><Run Text=" — " Foreground="#94A3B8"/><Run Text="سعر: " Foreground="#64748B" FontSize="11"/><Run Text="{Binding Price0, StringFormat=\{0:N2\}, Mode=OneWay}" Foreground="#1D4ED8" FontWeight="SemiBold"/>
                                                                </TextBlock></Border>
                                                            </DataTemplate></ListBox.ItemTemplate>
                                                            <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem">
                                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="Padding" Value="0"/>
                                                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="SearchItem_Click"/>
                                                                <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#EFF6FF"/></Trigger></Style.Triggers>
                                                            </Style></ListBox.ItemContainerStyle>
                                                        </ListBox>
                                                    </Border>
                                                </Popup>
                                            </Grid>
                                            <Grid Grid.Column="1" Margin="0,0,8,0">
                                                <TextBlock Text="المخزن" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                                <ComboBox ItemsSource="{Binding Stores}" DisplayMemberPath="StoreName" SelectedValuePath="StoreId" SelectedValue="{Binding CurrentSubItem.StoreId}" Padding="8,6" FontSize="13"/>
                                            </Grid>
                                            <Grid Grid.Column="2" Margin="0,0,8,0">
                                                <TextBlock Text="الوحدة" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                                <ComboBox ItemsSource="{Binding CurrentItemUnits}" DisplayMemberPath="UnitName" SelectedValuePath="UnitId" SelectedValue="{Binding CurrentSubItem.UnitId}" Padding="8,6" FontSize="13"/>
                                            </Grid>
                                            <Grid Grid.Column="3" Margin="0,0,8,0">
                                                <TextBlock Text="الكمية" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                                <TextBox Text="{Binding CurrentSubItem.Qty, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" FontSize="13"/>
                                            </Grid>
                                            <Grid Grid.Column="4" Margin="0,0,16,0">
                                                <TextBlock Text="السعر الاستيرادي" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                                <TextBox Text="{Binding CurrentSubItem.Price, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" FontSize="13"/>
                                            </Grid>
                                            <Button Grid.Column="5" Content="➕ إضافة" Style="{StaticResource PrimaryButton}" Command="{Binding AddSubItemCommand}" Padding="16,8"/>
                                        </Grid>
                                    </Border>
                                    <DataGrid Grid.Row="1" ItemsSource="{Binding FormItems}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single"
                                              GridLinesVisibility="Horizontal" HeadersVisibility="Column" BorderThickness="1" BorderBrush="#E2E8F0" Height="200"
                                              AlternatingRowBackground="#F8FAFC" Background="White" Foreground="#1E293B" FontSize="13" HorizontalGridLinesBrush="#F1F5F9" ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="الصنف" Width="*"><DataGridTemplateColumn.CellTemplate><DataTemplate>
                                                <TextBlock VerticalAlignment="Center" Padding="4,0"><TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="ItemId,ItemName">
                                                        <Binding Path="ItemId"/><Binding Path="DataContext.ItemsList" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                    </MultiBinding></TextBlock.Text></TextBlock>
                                            </DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                            <DataGridTextColumn Header="الكمية" Binding="{Binding Qty}" Width="80"/>
                                            <DataGridTextColumn Header="السعر" Binding="{Binding Price, StringFormat=\{0:N2\}}" Width="100"/>
                                            <DataGridTextColumn Header="الإجمالي" Binding="{Binding Total, StringFormat=\{0:N2\}}" Width="100" FontWeight="SemiBold"/>
                                            <DataGridTemplateColumn Width="50"><DataGridTemplateColumn.CellTemplate><DataTemplate>
                                                <Button Content="🗑️" Command="{Binding DataContext.RemoveSubItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Foreground="Red" FontSize="14"/>
                                            </DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </TabItem>

                            <!-- الموتوسيكلات -->
                            <TabItem Header="🏍️ الموتوسيكلات">
                                <Grid Margin="0,16,0,0">
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#F8FAFC" CornerRadius="12" Padding="16" Margin="0,0,0,16" BorderBrush="#E2E8F0" BorderThickness="1">
                                        <StackPanel>
                                            <!-- اختيار موتوسيكل موجود -->
                                            <TextBlock Text="اختيار موتوسيكل موجود في قاعدة البيانات:" Foreground="#64748B" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/> <ColumnDefinition Width="100"/> <ColumnDefinition Width="120"/> <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid Grid.Column="0" Margin="0,0,8,0">
                                                    <TextBlock Text="الموتوسيكل / السيارة" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                                    <ComboBox ItemsSource="{Binding CarsList}" DisplayMemberPath="ShasehNo" SelectedValuePath="CarId" SelectedValue="{Binding CurrentSubCar.CarId}" Padding="8,6" FontSize="13" IsEditable="True"/>
                                                </Grid>
                                                <Grid Grid.Column="1" Margin="0,0,8,0">
                                                    <TextBlock Text="كيلومتر" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                                    <TextBox Text="{Binding CurrentSubCar.Mileage, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" FontSize="13"/>
                                                </Grid>
                                                <Grid Grid.Column="2" Margin="0,0,16,0">
                                                    <TextBlock Text="التكلفة الاستيرادية" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                                    <TextBox Text="{Binding CurrentSubCar.Total, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" FontSize="13"/>
                                                </Grid>
                                                <Button Grid.Column="3" Content="➕ إضافة" Style="{StaticResource PrimaryButton}" Command="{Binding AddSubCarCommand}" Padding="16,8"/>
                                            </Grid>

                                            <!-- فاصل -->
                                            <Rectangle Height="1" Fill="#E2E8F0" Margin="0,16"/>

                                            <!-- إضافة موتوسيكل جديد غير مسجل -->
                                            <Border Background="#FEF3C7" CornerRadius="8" Padding="12" BorderBrush="#FDE68A" BorderThickness="1" Margin="0,0,0,4">
                                                <TextBlock Text="⚠️ موتوسيكل جديد — لسه مش مسجل في قاعدة البيانات" FontWeight="SemiBold" Foreground="#92400E" FontSize="13"/>
                                            </Border>
                                            <Grid Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/> <ColumnDefinition Width="*"/> <ColumnDefinition Width="*"/> <ColumnDefinition Width="100"/> <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid Grid.Column="0" Margin="0,0,8,0">
                                                    <TextBlock Text="اسم الموتوسيكل / الموديل" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                                    <TextBox Text="{Binding NewCarName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" FontSize="13"/>
                                                </Grid>
                                                <Grid Grid.Column="1" Margin="0,0,8,0">
                                                    <TextBlock Text="رقم الشاسيه *" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                                    <TextBox Text="{Binding NewCarShasehNo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" FontSize="13"/>
                                                </Grid>
                                                <Grid Grid.Column="2" Margin="0,0,8,0">
                                                    <TextBlock Text="رقم الموتور" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                                    <TextBox Text="{Binding NewCarEngineNo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" FontSize="13"/>
                                                </Grid>
                                                <Grid Grid.Column="3" Margin="0,0,16,0">
                                                    <TextBlock Text="التكلفة الاستيرادية" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                                    <TextBox Text="{Binding NewCarTotal, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" FontSize="13"/>
                                                </Grid>
                                                <Button Grid.Column="4" Content="➕ إضافة مؤقت" Style="{StaticResource SecondaryButton}" Command="{Binding AddNewCarCommand}" Padding="16,8" Background="#F59E0B" Foreground="White" BorderBrush="#F59E0B"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                    <DataGrid Grid.Row="1" ItemsSource="{Binding FormCars}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single"
                                              GridLinesVisibility="Horizontal" HeadersVisibility="Column" BorderThickness="1" BorderBrush="#E2E8F0" Height="200"
                                              AlternatingRowBackground="#F8FAFC" Background="White" Foreground="#1E293B" FontSize="13" HorizontalGridLinesBrush="#F1F5F9" ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="الموتوسيكل" Width="*"><DataGridTemplateColumn.CellTemplate><DataTemplate>
                                                <TextBlock VerticalAlignment="Center" Padding="4,0"><TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="CarId,ShasehNo">
                                                        <Binding Path="CarId"/><Binding Path="DataContext.CarsList" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                    </MultiBinding></TextBlock.Text></TextBlock>
                                            </DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                            <DataGridTextColumn Header="المسافة" Binding="{Binding Mileage}" Width="100"/>
                                            <DataGridTextColumn Header="التكلفة" Binding="{Binding Total, StringFormat=\{0:N2\}}" Width="100" FontWeight="SemiBold"/>
                                            <DataGridTemplateColumn Width="50"><DataGridTemplateColumn.CellTemplate><DataTemplate>
                                                <Button Content="🗑️" Command="{Binding DataContext.RemoveSubCarCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Foreground="Red" FontSize="14"/>
                                            </DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </TabItem>

                            <!-- المصروفات الجمركية -->
                            <TabItem Header="🧾 المصروفات">
                                <Grid Margin="0,16,0,0">
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#F8FAFC" CornerRadius="12" Padding="16" Margin="0,0,0,16" BorderBrush="#E2E8F0" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/> <ColumnDefinition Width="150"/> <ColumnDefinition Width="120"/> <ColumnDefinition Width="100"/> <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock Text="بند المصروف" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                                <ComboBox ItemsSource="{Binding ExpenseTypes}" DisplayMemberPath="ExpName" SelectedValuePath="ExpId" SelectedValue="{Binding CurrentSubExp.ExpId}" Padding="8,6" FontSize="13"/>
                                            </Grid>
                                            <Grid Grid.Column="1" Margin="0,0,8,0">
                                                <TextBlock Text="الخزنة المسدد منها" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                                <ComboBox ItemsSource="{Binding CashList}" DisplayMemberPath="CashName" SelectedValuePath="CashId" SelectedValue="{Binding CurrentSubExp.CashId}" Padding="8,6" FontSize="13"/>
                                            </Grid>
                                            <Grid Grid.Column="2" Margin="0,0,8,0">
                                                <TextBlock Text="المبلغ المدفوع" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                                <TextBox Text="{Binding CurrentSubExp.PayTotal, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" FontSize="13"/>
                                            </Grid>
                                            <Grid Grid.Column="3" Margin="0,0,16,0">
                                                <TextBlock Text="تاريخ الدفع" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                                <DatePicker SelectedDate="{Binding CurrentSubExp.PayDate}" Padding="8,4" FontSize="13"/>
                                            </Grid>
                                            <Button Grid.Column="4" Content="➕ إضافة" Style="{StaticResource PrimaryButton}" Command="{Binding AddSubExpCommand}" Padding="16,8"/>
                                        </Grid>
                                    </Border>
                                    <DataGrid Grid.Row="1" ItemsSource="{Binding FormExps}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single"
                                              GridLinesVisibility="Horizontal" HeadersVisibility="Column" BorderThickness="1" BorderBrush="#E2E8F0" Height="200"
                                              AlternatingRowBackground="#F8FAFC" Background="White" Foreground="#1E293B" FontSize="13" HorizontalGridLinesBrush="#F1F5F9" ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="بند المصروف" Width="*"><DataGridTemplateColumn.CellTemplate><DataTemplate>
                                                <TextBlock VerticalAlignment="Center" Padding="4,0"><TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="ExpId,ExpName">
                                                        <Binding Path="ExpId"/><Binding Path="DataContext.ExpenseTypes" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                    </MultiBinding></TextBlock.Text></TextBlock>
                                            </DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                            <DataGridTextColumn Header="المبلغ" Binding="{Binding PayTotal, StringFormat=\{0:N2\}}" Width="100" FontWeight="SemiBold"/>
                                            <DataGridTextColumn Header="تاريخ الدفع" Binding="{Binding PayDate, StringFormat=\{0:yyyy/MM/dd\}}" Width="100"/>
                                            <DataGridTemplateColumn Width="50"><DataGridTemplateColumn.CellTemplate><DataTemplate>
                                                <Button Content="🗑️" Command="{Binding DataContext.RemoveSubExpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Foreground="Red" FontSize="14"/>
                                            </DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </TabItem>

                            <!-- الدفعات -->
                            <TabItem Header="💰 الدفعات للموردين">
                                <Grid Margin="0,16,0,0">
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#F8FAFC" CornerRadius="12" Padding="16" Margin="0,0,0,16" BorderBrush="#E2E8F0" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/> <ColumnDefinition Width="150"/> <ColumnDefinition Width="120"/> <ColumnDefinition Width="100"/> <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock Text="ملاحظات الدفعة" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                                <TextBox Text="{Binding CurrentSubPayment.Notes, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" FontSize="13"/>
                                            </Grid>
                                            <Grid Grid.Column="1" Margin="0,0,8,0">
                                                <TextBlock Text="الخزنة المسدد منها" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                                <ComboBox ItemsSource="{Binding CashList}" DisplayMemberPath="CashName" SelectedValuePath="CashId" SelectedValue="{Binding CurrentSubPayment.CashId}" Padding="8,6" FontSize="13"/>
                                            </Grid>
                                            <Grid Grid.Column="2" Margin="0,0,8,0">
                                                <TextBlock Text="المبلغ المدفوع" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                                <TextBox Text="{Binding CurrentSubPayment.PayMoney, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" FontSize="13"/>
                                            </Grid>
                                            <Grid Grid.Column="3" Margin="0,0,16,0">
                                                <TextBlock Text="تاريخ الدفع" Foreground="#64748B" FontSize="11" Margin="2,-16,0,0"/>
                                                <DatePicker SelectedDate="{Binding CurrentSubPayment.PayDate}" Padding="8,4" FontSize="13"/>
                                            </Grid>
                                            <Button Grid.Column="4" Content="➕ إضافة" Style="{StaticResource PrimaryButton}" Command="{Binding AddSubPaymentCommand}" Padding="16,8"/>
                                        </Grid>
                                    </Border>
                                    <DataGrid Grid.Row="1" ItemsSource="{Binding FormPayments}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single"
                                              GridLinesVisibility="Horizontal" HeadersVisibility="Column" BorderThickness="1" BorderBrush="#E2E8F0" Height="200"
                                              AlternatingRowBackground="#F8FAFC" Background="White" Foreground="#1E293B" FontSize="13" HorizontalGridLinesBrush="#F1F5F9" ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="الملاحظات" Binding="{Binding Notes}" Width="*"/>
                                            <DataGridTextColumn Header="المبلغ" Binding="{Binding PayMoney, StringFormat=\{0:N2\}}" Width="100" FontWeight="SemiBold"/>
                                            <DataGridTextColumn Header="تاريخ الدفع" Binding="{Binding PayDate, StringFormat=\{0:yyyy/MM/dd\}}" Width="100"/>
                                            <DataGridTemplateColumn Width="50"><DataGridTemplateColumn.CellTemplate><DataTemplate>
                                                <Button Content="🗑️" Command="{Binding DataContext.RemoveSubPaymentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Foreground="Red" FontSize="14"/>
                                            </DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </TabItem>
                        </TabControl>

                        <!-- Totals -->
                        <Border Grid.Row="4" Background="#EEF2FF" CornerRadius="12" Padding="20" Margin="0,0,0,24" BorderBrush="#C7D2FE" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="90"/><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="100"/><ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="إجمالي الأصناف/المركبات" Style="{StaticResource FormLabel}" VerticalAlignment="Center" FontWeight="Bold" Foreground="#4F46E5" FontSize="12" TextWrapping="Wrap"/>
                                <TextBox Grid.Column="1" Text="{Binding FormItem.InvTotal, Mode=OneWay, StringFormat=\{0:N2\}}" Style="{StaticResource FormTextBox}" IsReadOnly="True" Background="#EEF2FF" Foreground="#4F46E5" FontWeight="Bold" FontSize="15" BorderThickness="0"/>
                                <TextBlock Grid.Column="3" Text="إجمالي المصروفات" Style="{StaticResource FormLabel}" VerticalAlignment="Center" FontWeight="Bold"/>
                                <TextBox Grid.Column="4" Text="{Binding FormItem.ExpTotal, Mode=OneWay, StringFormat=\{0:N2\}}" Style="{StaticResource FormTextBox}" IsReadOnly="True" Background="#EEF2FF" FontSize="15" BorderThickness="0"/>
                                <TextBlock Grid.Column="6" Text="التكلفة الإجمالية للفاتورة" Style="{StaticResource FormLabel}" VerticalAlignment="Center" FontWeight="Bold" Foreground="#4F46E5" TextWrapping="Wrap"/>
                                <TextBox Grid.Column="7" Text="{Binding FormItem.TotalCost, Mode=OneWay, StringFormat=\{0:N2\}}" Style="{StaticResource FormTextBox}" IsReadOnly="True" Background="#E0E7FF" Foreground="#3730A3" FontWeight="Bold" FontSize="18"/>
                            </Grid>
                        </Border>

                        <!-- Footer Action Buttons -->
                        <DockPanel Grid.Row="5">
                            <TextBlock DockPanel.Dock="Right" Text="{Binding StatusMessage}" Foreground="#10B981" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0" TextWrapping="Wrap" MaxWidth="300" HorizontalAlignment="Right"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" MinHeight="45">
                                <Button Content="✏️ تـعـديـل" Command="{Binding EditSelectedCommand}" Margin="0,0,12,0" Padding="16,10">
                                    <Button.Style><Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                        <Setter Property="Visibility" Value="Visible"/><Setter Property="Background" Value="#F59E0B"/><Setter Property="Foreground" Value="White"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedInvoice}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                        </Style.Triggers>
                                    </Style></Button.Style>
                                </Button>
                                <Button Content="💾 حـفـظ" Command="{Binding SaveCommand}" Margin="0,0,12,0" Padding="16,10">
                                    <Button.Style><Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                        <Setter Property="Background" Value="#10B981"/><Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers><DataTrigger Binding="{Binding IsEditing}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                                    </Style></Button.Style>
                                </Button>
                                <Button Content="✖ إلـغـاء" Command="{Binding CancelEditCommand}" Margin="0,0,16,0" Padding="16,10">
                                    <Button.Style><Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers><DataTrigger Binding="{Binding IsEditing}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                                    </Style></Button.Style>
                                </Button>
                                <Button Content="🗑️ حـذف" Command="{Binding DeleteCommand}" Padding="16,10">
                                    <Button.Style><Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedInvoice}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                        </Style.Triggers>
                                    </Style></Button.Style>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </Grid>
                </Border>
            </ScrollViewer>
        </Grid>

        <!-- SEARCH Section -->
        <Grid Style="{StaticResource SearchContainerStyle}" Margin="24">
            <Border Background="White" CornerRadius="16" Padding="32" BorderBrush="#E2E8F0" BorderThickness="1">
                <Border.Effect><DropShadowEffect Color="#0F172A" Opacity="0.04" BlurRadius="24" ShadowDepth="4" Direction="270"/></Border.Effect>
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,24">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                            <Border Background="#F3F4F6" CornerRadius="8" Padding="10" Margin="0,0,12,0"><TextBlock Text="🔎" FontSize="20"/></Border>
                            <TextBlock Text="البحث في فواتير الاستيراد" FontSize="20" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button DockPanel.Dock="Right" Content="✖ الـرجـوع للـنمـوذج" Style="{StaticResource SecondaryButton}" Command="{Binding HideSearchPanelCommand}" HorizontalAlignment="Right" Padding="16,8"/>
                    </DockPanel>
                    <Border Grid.Row="1" Background="#F8FAFC" CornerRadius="12" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,24">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="كلمة البحث (رقم الفاتورة، اسم الفاتورة):" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,16,0"/>
                            <TextBox Width="460" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" Padding="12,8" FontSize="15" Background="White"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="2" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" ClipToBounds="True">
                        <DataGrid ItemsSource="{Binding FilteredInvoices}" SelectedItem="{Binding SelectedInvoice, Mode=TwoWay}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single"
                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column" BorderThickness="0" RowHeight="48" ColumnHeaderHeight="54"
                                  AlternatingRowBackground="#F8FAFC" Background="White" Foreground="#1E293B" FontSize="14" HorizontalGridLinesBrush="#F1F5F9">
                            <DataGrid.ColumnHeaderStyle><Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F1F5F9"/><Setter Property="Foreground" Value="#334155"/>
                                <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Padding" Value="16,12"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/><Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style></DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle><Style TargetType="DataGridRow"><Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#DBEAFE"/><Setter Property="Foreground" Value="#1D4ED8"/></Trigger>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#EFF6FF"/></Trigger>
                                </Style.Triggers>
                            </Style></DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="100"><DataGridTemplateColumn.CellTemplate><DataTemplate>
                                    <Button Content="✅ اختيار" Style="{StaticResource PrimaryButton}" Margin="8,6" Padding="4" Background="#6366F1" BorderBrush="#6366F1" Foreground="White" FontSize="12" Command="{Binding DataContext.HideSearchPanelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                </DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                <DataGridTextColumn Header="رقم الفاتورة" Binding="{Binding InvId}" Width="100"/>
                                <DataGridTextColumn Header="اسم الشحنة" Binding="{Binding InvName}" Width="150"/>
                                <DataGridTextColumn Header="التاريخ" Binding="{Binding InvDate, StringFormat=\{0:yyyy/MM/dd\}}" Width="100"/>
                                <DataGridTemplateColumn Header="المورد" Width="200"><DataGridTemplateColumn.CellTemplate><DataTemplate>
                                    <TextBlock VerticalAlignment="Center" Padding="4,0"><TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="SuppId,SuppName">
                                            <Binding Path="SuppId"/><Binding Path="DataContext.Suppliers" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                        </MultiBinding></TextBlock.Text></TextBlock>
                                </DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                <DataGridTextColumn Header="التكلفة الإجمالية" Binding="{Binding TotalCost}" Width="150" FontWeight="Bold" Foreground="#3730A3"/>
                                <DataGridTextColumn Header="المنشأ" Binding="{Binding MadeIn}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
