                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#7B84A0" Text="كلمة البحث (رقم الفاتورة، اسم الفاتورة):" />
                            <TextBox Grid.Column="1" Padding="12,8" HorizontalAlignment="Stretch" Background="#2A3040" FontSize="15"
                                     Style="{StaticResource FormTextBox}"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Border>
                    <Border Grid.Row="2" BorderBrush="#3D4560" BorderThickness="1" ClipToBounds="True" CornerRadius="12">
                        <DataGrid AlternatingRowBackground="#222738" AutoGenerateColumns="False" Background="#242940" BorderThickness="0" CanUserAddRows="False" ColumnHeaderHeight="54" FontSize="13" Foreground="#C8CEE0"
                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column" HorizontalGridLinesBrush="#323848" IsReadOnly="True"
                                  ItemsSource="{Binding FilteredInvoices}"
                                  RowHeight="48"
                                  SelectedItem="{Binding SelectedInvoice, Mode=TwoWay}"
                                  SelectionMode="Single">


                            <DataGrid.ColumnHeaderStyle>
                                <Style BasedOn="{StaticResource DarkColumnHeader}" TargetType="DataGridColumnHeader" />
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style BasedOn="{StaticResource DarkRow}" TargetType="DataGridRow" />
                            </DataGrid.RowStyle>
                            <DataGrid.CellStyle>
                                <Style BasedOn="{StaticResource DarkCell}" TargetType="DataGridCell" />
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Margin="8,6" Padding="4" Background="#6366F1" BorderBrush="#6366F1"
                                                    Command="{Binding DataContext.HideSearchPanelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    Content="✅ اختيار" FontSize="12" Foreground="White"
                                                    Style="{StaticResource PrimaryButton}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="100" Binding="{Binding InvId}" Header="رقم الفاتورة" />
                                <DataGridTextColumn Width="150" Binding="{Binding InvName}" Header="اسم الشحنة" />
                                <DataGridTextColumn Width="100" Binding="{Binding InvDate, StringFormat=\{0:yyyy/MM/dd\}}" Header="التاريخ" />
                                <DataGridTemplateColumn Width="200" Header="المورد">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Padding="4,0" VerticalAlignment="Center">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="SuppId,SuppName">
                                                        <Binding Path="SuppId" />
                                                        <Binding Path="DataContext.Suppliers" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="150"
                                                    Binding="{Binding TotalCost}"
                                                    FontWeight="Bold" Foreground="#E0E7FF" Header="التكلفة الإجمالية" />
                                <DataGridTextColumn Width="*" Binding="{Binding MadeIn}" Header="المنشأ" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
