                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Margin="0,0,16,0" Padding="16,10" Command="{Binding CancelEditCommand}" Content="✖ إلـغـاء">
