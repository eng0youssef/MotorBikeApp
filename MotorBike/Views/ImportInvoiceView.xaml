                        <!--  Totals  -->
                        <StackPanel Grid.Row="4" Margin="0,0,0,8" HorizontalAlignment="Left" Orientation="Horizontal">
                            <Button Padding="16,8"
                                    Command="{Binding RecalcAllPercentagesCommand}"
                                    Content="🔄 إعادة حساب النسبة % تلقائي" FontSize="13" FontWeight="SemiBold" ToolTip="يعيد حساب النسبة المئوية لكل الأصناف والموتوسيكلات تلقائياً بناءً على إجمالي كل صنف">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource SecondaryButton}" TargetType="Button">
                                        <Setter Property="Background" Value="#F59E0B" />
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="BorderBrush" Value="#D97706" />
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
