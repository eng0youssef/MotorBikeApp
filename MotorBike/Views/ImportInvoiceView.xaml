                                            <DataGridTextColumn Width="140" Binding="{Binding PayMoney, StringFormat=\{0:N2\}, UpdateSourceTrigger=LostFocus}" FontWeight="SemiBold" Header="المبلغ" />
                                            <DataGridTextColumn Width="140"
                                                                Binding="{Binding OmlaRate, StringFormat=\{0:N4\}, UpdateSourceTrigger=LostFocus}"
                                                                FontWeight="SemiBold" Foreground="#6366F1" Header="سعر الصرف" />
                                            <DataGridTemplateColumn Width="160" Header="الخزينة">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Padding="4,0" VerticalAlignment="Center">
                                                            <TextBlock.Text>
                                                                <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="CashId,CashName">
