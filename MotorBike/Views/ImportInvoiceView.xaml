<UserControl x:Class="MotorBike.Views.ImportInvoiceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MotorBike.Converters"
             mc:Ignorable="d" xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Loaded="OnLoaded" FlowDirection="RightToLeft">
    <UserControl.Resources>
        <conv:HideZeroConverter x:Key="HideZeroConv"/>
        <conv:IdToNameConverter x:Key="IdToNameConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="FormCard" TargetType="Border">
            <Setter Property="Background" Value="#272C3F"/><Setter Property="CornerRadius" Value="16"/><Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3D4560"/><Setter Property="Margin" Value="24"/><Setter Property="Padding" Value="32"/>
        </Style>
        <Style x:Key="FormContainerStyle" TargetType="Grid">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="False"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SearchContainerStyle" TargetType="Grid">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                <DataTrigger Binding="{Binding IsSearchPanelVisible}" Value="False"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
            </Style.Triggers>
        </Style>

        
    </UserControl.Resources>

    <Grid Background="#1E2233" MinWidth="850" MinHeight="500">
        <!-- FORM Section -->
        <Grid Style="{StaticResource FormContainerStyle}">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" ScrollChanged="ScrollViewer_ScrollChanged">
                <Border Style="{StaticResource FormCard}">
                    <Border.Effect><DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="24" ShadowDepth="4" Direction="270"/></Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Header -->
                            <RowDefinition Height="Auto"/> <!-- Separator -->
                            <RowDefinition Height="Auto"/> <!-- Main Info -->
                            <RowDefinition Height="Auto"/> <!-- TabControl for SubItems -->
                            <RowDefinition Height="Auto"/> <!-- Recalc Button -->
                            <RowDefinition Height="Auto"/> <!-- Totals -->
                            <RowDefinition Height="Auto"/> <!-- Actions -->
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Column="0">
                                <Border Background="#2F3549" CornerRadius="12" Padding="14,12" Margin="0,0,16,0">
                                    <TextBlock Text="🌍" FontSize="26" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="فاتورة الاستيراد" FontSize="22" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="تسجيل شحنات الاستيراد بتفاصيلها" FontSize="14" Foreground="#9BA4B5" Margin="0,4,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="🔍 بحث عن فاتورة سابقة" Style="{StaticResource SecondaryButton}" Command="{Binding ShowSearchPanelCommand}" Margin="0,0,12,0" Padding="16,10"/>
                                <Button Content="➕ تـسـجيـل فاتورة جـديـدة" Style="{StaticResource PrimaryButton}" Command="{Binding AddNewRecordCommand}" Padding="16,10"/>
                            </StackPanel>
                        </Grid>

                        <Rectangle Grid.Row="1" Height="1" Fill="#3D4560" Margin="0,8,0,24"/>

                        <!-- Main Info -->
                        <Grid Grid.Row="2" IsEnabled="{Binding IsEditing}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="*"/> <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="*"/> <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <RowDefinition Height="20"/>
                                <RowDefinition Height="Auto"/> <RowDefinition Height="20"/>
                                <RowDefinition Height="Auto"/> <RowDefinition Height="20"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="رقم الفاتورة" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding FormItem.InvId , Converter={StaticResource HideZeroConv}}" Style="{StaticResource FormTextBox}" IsReadOnly="True" Background="#1E2233" FontWeight="Bold"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="التاريخ" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <DatePicker Grid.Row="0" Grid.Column="4" SelectedDate="{Binding FormItem.InvDate}" Padding="10,4" FontSize="14"/>
                            <TextBlock Grid.Row="0" Grid.Column="6" Text="المورد" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <!-- Supplier Smart Search -->
                            <Grid Grid.Row="0" Grid.Column="7">
                                <TextBox x:Name="SupplierSearchBox" Text="{Binding SupplierSearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" Padding="8,6" ToolTip="ابحث عن المورد بالاسم" GotFocus="SupplierSearch_GotFocus"/>
                                <Popup x:Name="SupplierSearchPopup" IsOpen="{Binding IsSupplierSearchPopupOpen}" StaysOpen="False" Placement="Bottom" PlacementTarget="{Binding ElementName=SupplierSearchBox}" Width="{Binding ActualWidth, ElementName=SupplierSearchBox}" AllowsTransparency="True">
                                    <Border Background="#272C3F" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="8" MaxHeight="250">
                                        <Border.Effect><DropShadowEffect Color="#000000" Opacity="0.15" BlurRadius="16" ShadowDepth="4" Direction="270"/></Border.Effect>
                                        <ListBox ItemsSource="{Binding FilteredSuppliersList}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemTemplate><DataTemplate>
                                                <Border Padding="10,7" Cursor="Hand"><TextBlock FontSize="13" Foreground="#ECEEF5" Text="{Binding SuppName, Mode=OneWay}"/></Border>
                                            </DataTemplate></ListBox.ItemTemplate>
                                            <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="Padding" Value="0"/>
                                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="SearchSupplier_Click"/>
                                                <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#EFF6FF"/></Trigger></Style.Triggers>
                                            </Style></ListBox.ItemContainerStyle>
                                        </ListBox>
                                    </Border>
                                </Popup>
                            </Grid>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="اسم الشحنة" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding FormItem.InvName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="بلد المنشأ" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="4" Text="{Binding FormItem.MadeIn, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                            <TextBlock Grid.Row="2" Grid.Column="6" Text="ميناء الشحن" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="7" Text="{Binding FormItem.ShipPort, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>

                            <!-- نوع الفاتورة FOB / CIF -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="نوع الفاتورة" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="4" Grid.Column="1"
                                      ItemsSource="{Binding InvTypeList}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding SelectedInvType}"
                                      Padding="10,6" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="4" Grid.Column="3" Text="العملة" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="4" Grid.Column="4" ItemsSource="{Binding Omlas}" DisplayMemberPath="OmlaName" SelectedValuePath="OmlaId" SelectedValue="{Binding SelectedOmlaId}" Padding="10,6" FontSize="14" IsEnabled="False" ToolTip="تُحدد تلقائياً من المورد"/>
                            <TextBlock Grid.Row="4" Grid.Column="6" Text="سعر الصرف" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="4" Grid.Column="7" Text="{Binding FormItem.OmlaRate, Mode=OneWay, StringFormat=\{0:N2\}}" Style="{StaticResource FormTextBox}" IsReadOnly="True" Background="#1E2233" FontWeight="Bold" ToolTip="يُثبّت من سعر العملة وقت إنشاء الفاتورة"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="ملاحظات" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="7" Text="{Binding FormItem.Notes, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                        </Grid>

                        <!-- TABS -->
                        <TabControl Grid.Row="3" Margin="0,32,0,16" IsEnabled="{Binding IsEditing}">
                            <TabControl.Resources>
                                <Style TargetType="TabItem">
                                    <Setter Property="Padding" Value="16,8"/>
                                    <Setter Property="FontSize" Value="15"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#64748B"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Foreground" Value="#6366F1"/>
                                            <Setter Property="BorderBrush" Value="#6366F1"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3D4560"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TabControl.Resources>

                            <!-- الأصناف -->
                            <TabItem Header="📦 الأصناف المستوردة">
                                <Grid Margin="0,16,0,0">
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#1E2233" CornerRadius="12" Padding="16" Margin="0,0,0,16" BorderBrush="#3D4560" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3*"/> <ColumnDefinition Width="2*"/> <ColumnDefinition Width="2*"/> 
                                                <ColumnDefinition Width="1.5*"/> <ColumnDefinition Width="1.5*"/> <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Smart Item Search -->
                                            <Grid Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock Text="✍️ بحث ذكي (بالاسم أو الباركود)" Foreground="#9BA4B5" FontSize="11" Margin="2,-16,0,0"/>
                                                <TextBox x:Name="ItemSearchBox" Text="{Binding ItemSearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" Padding="8,6" ToolTip="ابحث هنا عن الأصناف" GotFocus="ItemSearch_GotFocus"/>
                                                <Popup x:Name="ItemSearchPopup" IsOpen="{Binding IsItemSearchPopupOpen}" StaysOpen="False" Placement="Bottom" PlacementTarget="{Binding ElementName=ItemSearchBox}" Width="{Binding ActualWidth, ElementName=ItemSearchBox}" AllowsTransparency="True">
                                                    <Border Background="#272C3F" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="8" MaxHeight="250">
                                                        <Border.Effect><DropShadowEffect Color="#000000" Opacity="0.15" BlurRadius="16" ShadowDepth="4" Direction="270"/></Border.Effect>
                                                        <ListBox ItemsSource="{Binding FilteredItemsList}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                            <ListBox.ItemTemplate><DataTemplate>
                                                                <Border Padding="8,6" Cursor="Hand"><TextBlock FontSize="13" Foreground="#ECEEF5">
                                                                    <Run Text="{Binding ItemName, Mode=OneWay}"/><Run Text=" — " Foreground="#94A3B8"/><Run Text="سعر الاستيراد: " Foreground="#9BA4B5" FontSize="11"/><Run Text="{Binding ImpPrice, StringFormat=\{0:N2\}, Mode=OneWay}" Foreground="#1D4ED8" FontWeight="SemiBold"/>
                                                                </TextBlock></Border>
                                                            </DataTemplate></ListBox.ItemTemplate>
                                                            <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem">
                                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="Padding" Value="0"/>
                                                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="SearchItem_Click"/>
                                                                <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#EFF6FF"/></Trigger></Style.Triggers>
                                                            </Style></ListBox.ItemContainerStyle>
                                                        </ListBox>
                                                    </Border>
                                                </Popup>
                                            </Grid>
                                            <Grid Grid.Column="1" Margin="0,0,8,0">
                                                <TextBlock Text="المخزن" Foreground="#9BA4B5" FontSize="11" Margin="2,-16,0,0"/>
                                                <ComboBox ItemsSource="{Binding Stores}" DisplayMemberPath="StoreName" SelectedValuePath="StoreId" SelectedValue="{Binding CurrentSubItem.StoreId}" Padding="8,6" FontSize="13"/>
                                            </Grid>
                                            <Grid Grid.Column="2" Margin="0,0,8,0">
                                                <TextBlock Text="الوحدة" Foreground="#9BA4B5" FontSize="11" Margin="2,-16,0,0"/>
                                                <ComboBox ItemsSource="{Binding CurrentItemUnits}" DisplayMemberPath="UnitName" SelectedValuePath="UnitId" SelectedValue="{Binding CurrentSubItemUnitId}" Padding="8,6" FontSize="13"/>
                                            </Grid>
                                            <Grid Grid.Column="3" Margin="0,0,8,0">
                                                <TextBlock Text="الكمية" Foreground="#9BA4B5" FontSize="11" Margin="2,-16,0,0"/>
                                                <TextBox Text="{Binding CurrentSubItem.Qty, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" FontSize="13"/>
                                            </Grid>
                                            <Grid Grid.Column="4" Margin="0,0,16,0">
                                                <TextBlock Text="السعر الاستيرادي" Foreground="#9BA4B5" FontSize="11" Margin="2,-16,0,0"/>
                                                <TextBox Text="{Binding CurrentSubItem.Price, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" FontSize="13"/>
                                            </Grid>
                                            <Button Grid.Column="5" Content="➕ إضافة" Style="{StaticResource PrimaryButton}" Command="{Binding AddSubItemCommand}" Padding="16,8"/>
                                        </Grid>
                                    </Border>
                                    <DataGrid Grid.Row="1" ItemsSource="{Binding FormItems}" AutoGenerateColumns="False" IsReadOnly="False" CanUserAddRows="False" SelectionMode="Single"
                                              CellEditEnding="DataGrid_CellEditEnding"
                                              GridLinesVisibility="Horizontal" HeadersVisibility="Column" BorderThickness="1" BorderBrush="#3D4560" MinHeight="150"
                                              AlternatingRowBackground="#222738" Background="#242940" Foreground="#C8CEE0" FontSize="13" HorizontalGridLinesBrush="#323848" >
                                        <DataGrid.ColumnHeaderStyle>
                                    <Style BasedOn="{StaticResource DarkColumnHeader}" TargetType="DataGridColumnHeader" />
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.RowStyle>
                                    <Style BasedOn="{StaticResource DarkRow}" TargetType="DataGridRow" />
                                </DataGrid.RowStyle>
                                <DataGrid.CellStyle>
                                    <Style BasedOn="{StaticResource DarkCell}" TargetType="DataGridCell" />
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="الصنف" Width="*" IsReadOnly="True"><DataGridTemplateColumn.CellTemplate><DataTemplate>
                                                <TextBlock VerticalAlignment="Center" Padding="4,0"><TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="ItemId,ItemName">
                                                        <Binding Path="ItemId"/><Binding Path="DataContext.ItemsList" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                    </MultiBinding></TextBlock.Text></TextBlock>
                                            </DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                            <DataGridTextColumn Header="الكمية" Binding="{Binding Qty, UpdateSourceTrigger=LostFocus}" Width="70"/>
                                            <DataGridTextColumn Header="السعر" Binding="{Binding Price, StringFormat=\{0:N2\}, UpdateSourceTrigger=LostFocus}" Width="80"/>
                                            <DataGridTextColumn Header="الإجمالي (بالعملة)" Binding="{Binding Total, StringFormat=\{0:N2\}}" Width="90" FontWeight="SemiBold" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="الإجمالي (محلي)" Binding="{Binding TotalLocal, StringFormat=\{0:N2\}}" Width="90" FontWeight="SemiBold" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="النسبة %" Binding="{Binding CostPer, StringFormat=\{0:N4\}, UpdateSourceTrigger=LostFocus}" Width="80" Foreground="#6366F1"/>
                                            <DataGridTextColumn Header="تحمّل مصاريف (محلي)" Binding="{Binding ExpShareLocal, StringFormat=\{0:N2\}}" Width="100" Foreground="#DC2626" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="الإجمالي النهائي (محلي)" Binding="{Binding CostTotal, StringFormat=\{0:N2\}}" Width="100" Foreground="#059669" FontWeight="SemiBold" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="تكلفة الوحدة (محلي)" Binding="{Binding CostUnit, StringFormat=\{0:N2\}}" Width="90" Foreground="#0284C7" FontWeight="SemiBold" IsReadOnly="True"/>
                                            <DataGridTemplateColumn Width="50"><DataGridTemplateColumn.CellTemplate><DataTemplate>
                                                <Button Content="🗑️" Command="{Binding DataContext.RemoveSubItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Foreground="Red" FontSize="14"/>
                                            </DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                        </DataGrid.Columns>

                                    </DataGrid>
                                </Grid>
                            </TabItem>

                            <!-- الموتوسيكلات -->
                            <TabItem Header="🏍️ الموتوسيكلات">
                                <Grid Margin="0,16,0,0">
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#1E2233" CornerRadius="12" Padding="16" Margin="0,0,0,16" BorderBrush="#3D4560" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="تسجيل موتوسيكل جديد للشحنة:" Foreground="#9BA4B5" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*"/> <ColumnDefinition Width="*"/> <ColumnDefinition Width="*"/> <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid Grid.Column="0" Margin="0,0,8,0">
                                                    <TextBlock Text="الموديل *" Foreground="#9BA4B5" FontSize="11" Margin="2,-16,0,0"/>
                                                    <ComboBox ItemsSource="{Binding CarModels}" DisplayMemberPath="ModelName" SelectedValuePath="ModelId" SelectedValue="{Binding NewCarModelId}" Padding="8,6" FontSize="13" IsEditable="True"/>
                                                </Grid>
                                                <Grid Grid.Column="1" Margin="0,0,8,0">
                                                    <TextBlock Text="رقم الشاسيه *" Foreground="#9BA4B5" FontSize="11" Margin="2,-16,0,0"/>
                                                    <TextBox Text="{Binding NewCarChassisNo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" FontSize="13"/>
                                                </Grid>
                                                <Grid Grid.Column="2" Margin="0,0,8,0">
                                                    <TextBlock Text="رقم الموتور" Foreground="#9BA4B5" FontSize="11" Margin="2,-16,0,0"/>
                                                    <TextBox Text="{Binding NewCarMotorNo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" FontSize="13"/>
                                                </Grid>
                                                <Grid Grid.Column="3" Margin="0,0,0,0">
                                                    <TextBlock Text="رقم اللوحة" Foreground="#9BA4B5" FontSize="11" Margin="2,-16,0,0"/>
                                                    <TextBox Text="{Binding NewCarPlateNo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" FontSize="13"/>
                                                </Grid>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/> <ColumnDefinition Width="*"/> <ColumnDefinition Width="*"/> <ColumnDefinition Width="2*"/> <ColumnDefinition Width="1.5*"/> <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid Grid.Column="0" Margin="0,0,8,0">
                                                    <TextBlock Text="سنة الصنع" Foreground="#9BA4B5" FontSize="11" Margin="2,-16,0,0"/>
                                                    <TextBox Text="{Binding NewCarYearNo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" FontSize="13"/>
                                                </Grid>
                                                <Grid Grid.Column="1" Margin="0,0,8,0">
                                                    <TextBlock Text="اللون *" Foreground="#9BA4B5" FontSize="11" Margin="2,-16,0,0"/>
                                                    <ComboBox ItemsSource="{Binding Colors}" DisplayMemberPath="ColorName" SelectedValuePath="ColorId" SelectedValue="{Binding NewCarColorId}" Padding="8,6" FontSize="13" IsEditable="True"/>
                                                </Grid>
                                                <Grid Grid.Column="2" Margin="0,0,8,0">
                                                    <TextBlock Text="الكيلومتر" Foreground="#9BA4B5" FontSize="11" Margin="2,-16,0,0"/>
                                                    <TextBox Text="{Binding NewCarMileage, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" FontSize="13"/>
                                                </Grid>
                                                <Grid Grid.Column="3" Margin="0,0,8,0">
                                                    <TextBlock Text="ملاحظات" Foreground="#9BA4B5" FontSize="11" Margin="2,-16,0,0"/>
                                                    <TextBox Text="{Binding NewCarNotes, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" FontSize="13"/>
                                                </Grid>
                                                <Grid Grid.Column="4" Margin="0,0,16,0">
                                                    <TextBlock Text="سعر الاستيراد" Foreground="#9BA4B5" FontSize="11" Margin="2,-16,0,0"/>
                                                    <TextBox Text="{Binding NewCarTotal, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" FontSize="13"/>
                                                </Grid>
                                                <Button Grid.Column="5" Content="➕ إضافة للشحنة" Style="{StaticResource PrimaryButton}" Command="{Binding AddNewCarCommand}" Padding="16,8"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                    <DataGrid Grid.Row="1" ItemsSource="{Binding FormCars}" AutoGenerateColumns="False" IsReadOnly="False" CanUserAddRows="False" SelectionMode="Single"
                                              CellEditEnding="DataGrid_CellEditEnding"
                                              GridLinesVisibility="Horizontal" HeadersVisibility="Column" BorderThickness="1" BorderBrush="#3D4560" MinHeight="150"
                                              AlternatingRowBackground="#222738" Background="#242940" Foreground="#C8CEE0" FontSize="13" HorizontalGridLinesBrush="#323848" >
                                        <DataGrid.ColumnHeaderStyle>
                                    <Style BasedOn="{StaticResource DarkColumnHeader}" TargetType="DataGridColumnHeader" />
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.RowStyle>
                                    <Style BasedOn="{StaticResource DarkRow}" TargetType="DataGridRow" />
                                </DataGrid.RowStyle>
                                <DataGrid.CellStyle>
                                    <Style BasedOn="{StaticResource DarkCell}" TargetType="DataGridCell" />
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="الموتوسيكل" Width="*" IsReadOnly="True"><DataGridTemplateColumn.CellTemplate><DataTemplate>
                                                <TextBlock VerticalAlignment="Center" Padding="4,0"><TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="CarId,ChassisNo">
                                                        <Binding Path="CarId"/><Binding Path="DataContext.CarsList" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                    </MultiBinding></TextBlock.Text></TextBlock>
                                            </DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                            <DataGridTextColumn Header="المسافة" Binding="{Binding Mileage}" Width="80" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="السعر (بالعملة)" Binding="{Binding Total, StringFormat=\{0:N2\}, UpdateSourceTrigger=LostFocus}" Width="100" FontWeight="SemiBold"/>
                                            <DataGridTextColumn Header="السعر (محلي)" Binding="{Binding TotalLocal, StringFormat=\{0:N2\}}" Width="90" FontWeight="SemiBold" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="النسبة %" Binding="{Binding CostPer, StringFormat=\{0:N4\}, UpdateSourceTrigger=LostFocus}" Width="80" Foreground="#6366F1"/>
                                            <DataGridTextColumn Header="تحمّل مصاريف (محلي)" Binding="{Binding ExpShareLocal, StringFormat=\{0:N2\}}" Width="100" Foreground="#DC2626" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="الإجمالي النهائي (محلي)" Binding="{Binding CostTotal, StringFormat=\{0:N2\}}" Width="100" Foreground="#059669" FontWeight="SemiBold" IsReadOnly="True"/>
                                            <DataGridTemplateColumn Width="50"><DataGridTemplateColumn.CellTemplate><DataTemplate>
                                                <Button Content="🗑️" Command="{Binding DataContext.RemoveSubCarCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Foreground="Red" FontSize="14"/>
                                            </DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                        </DataGrid.Columns>

                                    </DataGrid>
                                </Grid>
                            </TabItem>

                            <!-- المصروفات الجمركية -->
                            <TabItem Header="🧾 المصروفات">
                                <Grid Margin="0,16,0,0">
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#1E2233" CornerRadius="12" Padding="16" Margin="0,0,0,16" BorderBrush="#3D4560" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/> <ColumnDefinition Width="2*"/> <ColumnDefinition Width="1.5*"/> <ColumnDefinition Width="1.5*"/> <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock Text="بند المصروف" Foreground="#9BA4B5" FontSize="11" Margin="2,-16,0,0"/>
                                                <ComboBox ItemsSource="{Binding ExpenseTypes}" DisplayMemberPath="ExpName" SelectedValuePath="ExpId" SelectedValue="{Binding CurrentSubExp.ExpId}" Padding="8,6" FontSize="13"/>
                                            </Grid>
                                            <Grid Grid.Column="1" Margin="0,0,8,0">
                                                <TextBlock Text="الخزنة المسدد منها" Foreground="#9BA4B5" FontSize="11" Margin="2,-16,0,0"/>
                                                <ComboBox ItemsSource="{Binding CashList}" DisplayMemberPath="CashName" SelectedValuePath="CashId" SelectedValue="{Binding CurrentSubExp.CashId}" Padding="8,6" FontSize="13"/>
                                            </Grid>
                                            <Grid Grid.Column="2" Margin="0,0,8,0">
                                                <TextBlock Text="المبلغ المدفوع" Foreground="#9BA4B5" FontSize="11" Margin="2,-16,0,0"/>
                                                <TextBox Text="{Binding CurrentSubExp.PayTotal, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" FontSize="13"/>
                                            </Grid>
                                            <Grid Grid.Column="3" Margin="0,0,16,0">
                                                <TextBlock Text="تاريخ الدفع" Foreground="#9BA4B5" FontSize="11" Margin="2,-16,0,0"/>
                                                <DatePicker SelectedDate="{Binding CurrentSubExp.PayDate}" Padding="8,4" FontSize="13"/>
                                            </Grid>
                                            <Button Grid.Column="4" Content="➕ إضافة" Style="{StaticResource PrimaryButton}" Command="{Binding AddSubExpCommand}" Padding="16,8"/>
                                        </Grid>
                                    </Border>
                                    <DataGrid Grid.Row="1" ItemsSource="{Binding FormExps}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single"
                                              GridLinesVisibility="Horizontal" HeadersVisibility="Column" BorderThickness="1" BorderBrush="#3D4560" MinHeight="150"
                                              AlternatingRowBackground="#222738" Background="#242940" Foreground="#C8CEE0" FontSize="13" HorizontalGridLinesBrush="#323848" >
                                        <DataGrid.ColumnHeaderStyle>
                                    <Style BasedOn="{StaticResource DarkColumnHeader}" TargetType="DataGridColumnHeader" />
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.RowStyle>
                                    <Style BasedOn="{StaticResource DarkRow}" TargetType="DataGridRow" />
                                </DataGrid.RowStyle>
                                <DataGrid.CellStyle>
                                    <Style BasedOn="{StaticResource DarkCell}" TargetType="DataGridCell" />
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="بند المصروف" Width="*"><DataGridTemplateColumn.CellTemplate><DataTemplate>
                                                <TextBlock VerticalAlignment="Center" Padding="4,0"><TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="ExpId,ExpName">
                                                        <Binding Path="ExpId"/><Binding Path="DataContext.ExpenseTypes" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                    </MultiBinding></TextBlock.Text></TextBlock>
                                            </DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                            <DataGridTextColumn Header="المبلغ" Binding="{Binding PayTotal, StringFormat=\{0:N2\}}" Width="100" FontWeight="SemiBold"/>
                                            <DataGridTextColumn Header="تاريخ الدفع" Binding="{Binding PayDate, StringFormat=\{0:yyyy/MM/dd\}}" Width="100"/>
                                            <DataGridTemplateColumn Width="50"><DataGridTemplateColumn.CellTemplate><DataTemplate>
                                                <Button Content="🗑️" Command="{Binding DataContext.RemoveSubExpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Foreground="Red" FontSize="14"/>
                                            </DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </TabItem>

                            <!-- الدفعات -->
                            <TabItem Header="💰 الدفعات للموردين">
                                <Grid Margin="0,16,0,0">
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#1E2233" CornerRadius="12" Padding="16" Margin="0,0,0,16" BorderBrush="#3D4560" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/> <ColumnDefinition Width="2*"/> <ColumnDefinition Width="1.5*"/> <ColumnDefinition Width="1.5*"/> <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock Text="ملاحظات الدفعة" Foreground="#9BA4B5" FontSize="11" Margin="2,-16,0,0"/>
                                                <TextBox Text="{Binding CurrentSubPayment.Notes, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" FontSize="13"/>
                                            </Grid>
                                            <Grid Grid.Column="1" Margin="0,0,8,0">
                                                <TextBlock Text="الخزنة المسدد منها" Foreground="#9BA4B5" FontSize="11" Margin="2,-16,0,0"/>
                                                <ComboBox ItemsSource="{Binding FilteredPaymentCashList}" DisplayMemberPath="CashName" SelectedValuePath="CashId" SelectedValue="{Binding CurrentSubPayment.CashId}" Padding="8,6" FontSize="13"/>
                                            </Grid>
                                            <Grid Grid.Column="2" Margin="0,0,8,0">
                                                <TextBlock Text="المبلغ المدفوع" Foreground="#9BA4B5" FontSize="11" Margin="2,-16,0,0"/>
                                                <TextBox Text="{Binding CurrentSubPayment.PayMoney, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" FontSize="13"/>
                                            </Grid>
                                            <Grid Grid.Column="3" Margin="0,0,16,0">
                                                <TextBlock Text="تاريخ الدفع" Foreground="#9BA4B5" FontSize="11" Margin="2,-16,0,0"/>
                                                <DatePicker SelectedDate="{Binding CurrentSubPayment.PayDate}" Padding="8,4" FontSize="13"/>
                                            </Grid>
                                            <Button Grid.Column="4" Content="➕ إضافة" Style="{StaticResource PrimaryButton}" Command="{Binding AddSubPaymentCommand}" Padding="16,8"/>
                                        </Grid>
                                    </Border>
                                    <DataGrid Grid.Row="1" x:Name="PaymentsDataGrid" ItemsSource="{Binding FormPayments}" AutoGenerateColumns="False" IsReadOnly="False" CanUserAddRows="False" SelectionMode="Single"
                                              CellEditEnding="PaymentsDataGrid_CellEditEnding"
                                              GridLinesVisibility="Horizontal" HeadersVisibility="Column" BorderThickness="1" BorderBrush="#3D4560" MinHeight="150"
                                              AlternatingRowBackground="#222738" Background="#242940" Foreground="#C8CEE0" FontSize="13" HorizontalGridLinesBrush="#323848" >
                                        <DataGrid.ColumnHeaderStyle>
                                    <Style BasedOn="{StaticResource DarkColumnHeader}" TargetType="DataGridColumnHeader" />
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.RowStyle>
                                    <Style BasedOn="{StaticResource DarkRow}" TargetType="DataGridRow" />
                                </DataGrid.RowStyle>
                                <DataGrid.CellStyle>
                                    <Style BasedOn="{StaticResource DarkCell}" TargetType="DataGridCell" />
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                            <DataGridTextColumn Header="الملاحظات" Binding="{Binding Notes, UpdateSourceTrigger=LostFocus}" Width="*"/>
                                            <DataGridTextColumn Header="المبلغ" Binding="{Binding PayMoney, StringFormat=\{0:N2\}, UpdateSourceTrigger=LostFocus}" Width="100" FontWeight="SemiBold"/>
                                            <DataGridTextColumn Header="سعر الصرف" Binding="{Binding OmlaRate, StringFormat=\{0:N4\}, UpdateSourceTrigger=LostFocus}" Width="100" Foreground="#6366F1" FontWeight="SemiBold"/>
                                            <DataGridTemplateColumn Header="الخزينة" Width="150">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock VerticalAlignment="Center" Padding="4,0"><TextBlock.Text>
                                                            <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="CashId,CashName">
                                                                <Binding Path="CashId"/><Binding Path="DataContext.FilteredPaymentCashList" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                            </MultiBinding></TextBlock.Text></TextBlock>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                                <DataGridTemplateColumn.CellEditingTemplate>
                                                    <DataTemplate>
                                                        <ComboBox ItemsSource="{Binding DataContext.FilteredPaymentCashList, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  DisplayMemberPath="CashName" SelectedValuePath="CashId"
                                                                  SelectedValue="{Binding CashId, UpdateSourceTrigger=PropertyChanged}"
                                                                  Padding="4,2" FontSize="13" Background="#242940" Foreground="#C8CEE0"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellEditingTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="تاريخ الدفع" Binding="{Binding PayDate, StringFormat=\{0:yyyy/MM/dd\}}" Width="100" />
                                            <DataGridTemplateColumn Width="50"><DataGridTemplateColumn.CellTemplate><DataTemplate>
                                                <Button Content="🗑️" Command="{Binding DataContext.RemoveSubPaymentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Foreground="Red" FontSize="14"/>
                                            </DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                        </DataGrid.Columns>

                                    </DataGrid>
                                </Grid>
                            </TabItem>
                        </TabControl>

                        <!-- Totals -->
                        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <Button Content="🔄 إعادة حساب النسبة % تلقائي" Command="{Binding RecalcAllPercentagesCommand}" Padding="16,8" FontSize="13" FontWeight="SemiBold" ToolTip="يعيد حساب النسبة المئوية لكل الأصناف والموتوسيكلات تلقائياً بناءً على إجمالي كل صنف">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                        <Setter Property="Background" Value="#F59E0B"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderBrush" Value="#D97706"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                        <Border Grid.Row="5" Background="#2F3549" CornerRadius="12" Padding="20" Margin="0,0,0,24" BorderBrush="#C7D2FE" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- الصف الأول -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="إجمالي الفاتورة (بالعملة)" Style="{StaticResource FormLabel}" VerticalAlignment="Center" FontWeight="Bold" Foreground="#A5B4FC" FontSize="11" TextWrapping="Wrap"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding FormItem.InvTotal, Mode=OneWay, StringFormat=\{0:N2\}}" Style="{StaticResource FormTextBox}" IsReadOnly="True" Background="#2F3549" Foreground="#A5B4FC" FontWeight="Bold" FontSize="14" BorderThickness="0"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="إجمالي المصروفات (بالمحلي)" Style="{StaticResource FormLabel}" VerticalAlignment="Center" FontWeight="Bold" FontSize="11" TextWrapping="Wrap"/>
                                <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding FormItem.ExpTotal, Mode=OneWay, StringFormat=\{0:N2\}}" Style="{StaticResource FormTextBox}" IsReadOnly="True" Background="#2F3549" FontSize="14" BorderThickness="0"/>
                                <TextBlock Grid.Row="0" Grid.Column="6" Text="فرق العملات" Style="{StaticResource FormLabel}" VerticalAlignment="Center" FontWeight="Bold" FontSize="11" TextWrapping="Wrap"/>
                                <TextBox Grid.Row="0" Grid.Column="7" Text="{Binding FormItem.FrokOmla, Mode=OneWay, StringFormat=\{0:N2\}}" Style="{StaticResource FormTextBox}" IsReadOnly="True" Background="#2F3549" FontSize="14" ToolTip="يُحسب تلقائياً من فرق سعر الصرف بين الفاتورة والدفعات"/>

                                <!-- الصف الثاني -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="إجمالي الفاتورة (بالمحلي)" Style="{StaticResource FormLabel}" VerticalAlignment="Center" FontWeight="Bold" FontSize="11" TextWrapping="Wrap"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding FormItem.InvTotalLocal, Mode=OneWay, StringFormat=\{0:N2\}}" Style="{StaticResource FormTextBox}" IsReadOnly="True" Background="#2F3549" FontSize="14" BorderThickness="0" ToolTip="حاصل ضرب الإجمالي بالعملة الأجنبية × سعر الصرف"/>
                                <TextBlock Grid.Row="2" Grid.Column="6" Text="التكلفة الإجمالية بالمحلي" Style="{StaticResource FormLabel}" VerticalAlignment="Center" FontWeight="Bold" Foreground="#A5B4FC" FontSize="11" TextWrapping="Wrap"/>
                                <TextBox Grid.Row="2" Grid.Column="7" Text="{Binding FormItem.TotalCost, Mode=OneWay, StringFormat=\{0:N2\}}" Style="{StaticResource FormTextBox}" IsReadOnly="True" Background="#3D4560" Foreground="#E0E7FF" FontWeight="Bold" FontSize="18"/>
                            </Grid>
                        </Border>

                        <!-- Footer Action Buttons -->
                        <DockPanel Grid.Row="6">
                            <TextBlock DockPanel.Dock="Right" Text="{Binding StatusMessage}" Foreground="#10B981" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0" TextWrapping="Wrap" MaxWidth="300" HorizontalAlignment="Right"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" MinHeight="45">
                                <Button Content="✏️ تـعـديـل" Command="{Binding EditSelectedCommand}" Margin="0,0,12,0" Padding="16,10">
                                    <Button.Style><Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                        <Setter Property="Visibility" Value="Visible"/><Setter Property="Background" Value="#F59E0B"/><Setter Property="Foreground" Value="White"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedInvoice}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                        </Style.Triggers>
                                    </Style></Button.Style>
                                </Button>
                                <Button Content="💾 حـفـظ" Command="{Binding SaveCommand}" Margin="0,0,12,0" Padding="16,10">
                                    <Button.Style><Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                        <Setter Property="Background" Value="#10B981"/><Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers><DataTrigger Binding="{Binding IsEditing}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                                    </Style></Button.Style>
                                </Button>
                                <Button Content="✖ إلـغـاء" Command="{Binding CancelEditCommand}" Margin="0,0,16,0" Padding="16,10">
                                    <Button.Style><Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers><DataTrigger Binding="{Binding IsEditing}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                                    </Style></Button.Style>
                                </Button>
                                <Button Content="🗑️ حـذف" Command="{Binding DeleteCommand}" Padding="16,10">
                                    <Button.Style><Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedInvoice}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                        </Style.Triggers>
                                    </Style></Button.Style>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </Grid>
                </Border>
            </ScrollViewer>
        </Grid>

        <!-- SEARCH Section -->
        <Grid Style="{StaticResource SearchContainerStyle}" Margin="24">
            <Border Background="#272C3F" CornerRadius="16" Padding="32" BorderBrush="#3D4560" BorderThickness="1">
                <Border.Effect><DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="24" ShadowDepth="4" Direction="270"/></Border.Effect>
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,24">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                            <Border Background="#2A3040" CornerRadius="8" Padding="10" Margin="0,0,12,0"><TextBlock Text="🔎" FontSize="20"/></Border>
                            <TextBlock Text="البحث في فواتير الاستيراد" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button DockPanel.Dock="Right" Content="✖ الـرجـوع للـنمـوذج" Style="{StaticResource SecondaryButton}" Command="{Binding HideSearchPanelCommand}" HorizontalAlignment="Right" Padding="16,8"/>
                    </DockPanel>
                    <Border Grid.Row="1" Background="#1E2233" CornerRadius="12" Padding="16" BorderBrush="#3D4560" BorderThickness="1" Margin="0,0,0,24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="كلمة البحث (رقم الفاتورة، اسم الفاتورة):" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#7B84A0" Margin="0,0,16,0"/>
                            <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" HorizontalAlignment="Stretch" Padding="12,8" FontSize="15" Background="#2A3040"/>
                        </Grid>
                    </Border>
                    <Border Grid.Row="2" CornerRadius="12" BorderBrush="#3D4560" BorderThickness="1" ClipToBounds="True">
                        <DataGrid ItemsSource="{Binding FilteredInvoices}" SelectedItem="{Binding SelectedInvoice, Mode=TwoWay}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single"
                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column" BorderThickness="0" RowHeight="48" ColumnHeaderHeight="54"
                                  AlternatingRowBackground="#222738" Background="#242940" Foreground="#C8CEE0" FontSize="13" HorizontalGridLinesBrush="#323848">
                            
                            
                            <DataGrid.ColumnHeaderStyle>
                                    <Style BasedOn="{StaticResource DarkColumnHeader}" TargetType="DataGridColumnHeader" />
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.RowStyle>
                                    <Style BasedOn="{StaticResource DarkRow}" TargetType="DataGridRow" />
                                </DataGrid.RowStyle>
                                <DataGrid.CellStyle>
                                    <Style BasedOn="{StaticResource DarkCell}" TargetType="DataGridCell" />
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                <DataGridTemplateColumn Width="100"><DataGridTemplateColumn.CellTemplate><DataTemplate>
                                    <Button Content="✅ اختيار" Style="{StaticResource PrimaryButton}" Margin="8,6" Padding="4" Background="#6366F1" BorderBrush="#6366F1" Foreground="White" FontSize="12" Command="{Binding DataContext.HideSearchPanelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                </DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                <DataGridTextColumn Header="رقم الفاتورة" Binding="{Binding InvId}" Width="100"/>
                                <DataGridTextColumn Header="اسم الشحنة" Binding="{Binding InvName}" Width="150"/>
                                <DataGridTextColumn Header="التاريخ" Binding="{Binding InvDate, StringFormat=\{0:yyyy/MM/dd\}}" Width="100"/>
                                <DataGridTemplateColumn Header="المورد" Width="200"><DataGridTemplateColumn.CellTemplate><DataTemplate>
                                    <TextBlock VerticalAlignment="Center" Padding="4,0"><TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="SuppId,SuppName">
                                            <Binding Path="SuppId"/><Binding Path="DataContext.Suppliers" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                        </MultiBinding></TextBlock.Text></TextBlock>
                                </DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                <DataGridTextColumn Header="التكلفة الإجمالية" Binding="{Binding TotalCost}" Width="150" FontWeight="Bold" Foreground="#E0E7FF"/>
                                <DataGridTextColumn Header="المنشأ" Binding="{Binding MadeIn}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
