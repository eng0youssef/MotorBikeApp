                                                    <DataTemplate>
                                                        <TextBlock Padding="4,0" VerticalAlignment="Center">
                                                            <TextBlock.Text>
                                                                <MultiBinding Converter="{StaticResource IdToNameConverter}" ConverterParameter="ExpId,ExpName">
                                                                    <Binding Path="ExpId" />
                                                                    <Binding Path="DataContext.ExpenseTypes" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Width="100" Binding="{Binding PayTotal, StringFormat=\{0:N2\}}" FontWeight="SemiBold" Header="المبلغ" />
                                            <DataGridTextColumn Width="100" Binding="{Binding PayDate, StringFormat=\{0:yyyy/MM/dd\}}" Header="تاريخ الدفع" />
                                            <DataGridTemplateColumn Width="50">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Background="Transparent" BorderThickness="0"
                                                                Command="{Binding DataContext.RemoveSubExpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
