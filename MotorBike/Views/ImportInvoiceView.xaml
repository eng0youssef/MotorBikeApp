                                              CanUserAddRows="False" CellEditEnding="PaymentsDataGrid_CellEditEnding" FontSize="13" Foreground="#C8CEE0" GridLinesVisibility="Horizontal" HeadersVisibility="Column" HorizontalGridLinesBrush="#323848" IsReadOnly="False"
                                              ItemsSource="{Binding FormPayments}"
                                              SelectionMode="Single">
                                        <DataGrid.ColumnHeaderStyle>
                                            <Style BasedOn="{StaticResource DarkColumnHeader}" TargetType="DataGridColumnHeader" />
                                        </DataGrid.ColumnHeaderStyle>
                                        <DataGrid.RowStyle>
                                            <Style BasedOn="{StaticResource DarkRow}" TargetType="DataGridRow" />
                                        </DataGrid.RowStyle>
                                        <DataGrid.CellStyle>
                                            <Style BasedOn="{StaticResource DarkCell}" TargetType="DataGridCell" />
                                        </DataGrid.CellStyle>
