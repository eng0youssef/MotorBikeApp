                                            <DataGridTextColumn Width="*" Binding="{Binding Notes, UpdateSourceTrigger=LostFocus}" Header="الملاحظات" />
                                            <DataGridTemplateColumn Width="50">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Background="Transparent" BorderThickness="0"
                                                                Command="{Binding DataContext.RemoveSubPaymentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
