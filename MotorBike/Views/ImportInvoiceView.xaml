                                         Text="{Binding FormItem.InvTotal, Mode=OneWay, StringFormat=\{0:N2\}}" />
                                <TextBlock Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" FontSize="11" FontWeight="Bold"
                                           Style="{StaticResource FormLabel}"
                                           Text="إجمالي المصروفات (بالمحلي)" TextWrapping="Wrap" />
                                <TextBox Grid.Row="0" Grid.Column="4" Background="#2F3549" BorderThickness="0" FontSize="14" IsReadOnly="True"
                                         Style="{StaticResource FormTextBox}"
                                         Text="{Binding FormItem.ExpTotal, Mode=OneWay, StringFormat=\{0:N2\}}" />
                                <TextBlock Grid.Row="0" Grid.Column="6" VerticalAlignment="Center" FontSize="11" FontWeight="Bold"
