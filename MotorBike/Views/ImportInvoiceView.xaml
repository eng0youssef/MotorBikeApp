                                       Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap" />
                            <StackPanel MinHeight="45" HorizontalAlignment="Left" Orientation="Horizontal">
                                <Button Margin="0,0,12,0" Padding="16,10" Command="{Binding EditSelectedCommand}" Content="✏️ تـعـديـل">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource SecondaryButton}" TargetType="Button">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Setter Property="Background" Value="#F59E0B" />
                                            <Setter Property="Foreground" Value="White" />
