<UserControl x:Class="MotorBike.Views.PaymentsDataView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" d:DesignHeight="800" d:DesignWidth="1000" FlowDirection="RightToLeft"
             mc:Ignorable="d">
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.0" To="1.0" Duration="0:0:0.5" />
                    <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,30,0,-30" To="0" Duration="0:0:0.5">
                        <ThicknessAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
    <UserControl.Resources>

        <Style x:Key="CategoryHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="Margin" Value="0,20,0,15" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="IconBorderStyle" TargetType="Border">
            <Setter Property="Width" Value="64" />
            <Setter Property="Height" Value="64" />
            <Setter Property="CornerRadius" Value="32" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="IconTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="30" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="TitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer MinWidth="600" MinHeight="400" Background="#272C3F" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40">
            <!--  Header section  -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Margin="0,0,0,8" FontSize="32" FontWeight="Bold" Foreground="White" Text="المدفوعات والتحويلات" />
                <TextBlock FontSize="16" Foreground="LightGray" Text="إدارة كافة المدفوعات والتحصيلات وحركة الخزائن في النظام من مكان واحد." />
            </StackPanel>

            <!--  العملاء والموردين  -->
            <StackPanel Margin="0,10,0,10" Orientation="Horizontal">
                <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" FontSize="20" Foreground="White" Text="🤝" />
                <TextBlock Margin="0" Foreground="White" Style="{StaticResource CategoryHeaderStyle}" Text="العملاء والموردين" />
            </StackPanel>
            <WrapPanel Margin="0,0,0,30">
                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="CusPayments"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Background="#DBEAFE" Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="👥" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="سداد العملاء" />
                    </StackPanel>
                </Button>
                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="SuppPayments"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Background="#FEE2E2" Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="🏭" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="سداد الموردين" />
                    </StackPanel>
                </Button>
            </WrapPanel>

            <!--  المصروفات والخزائن  -->
            <StackPanel Margin="0,10,0,10" Orientation="Horizontal">
                <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" FontSize="20" Foreground="White" Text="🏦" />
                <TextBlock Margin="0" Foreground="White" Style="{StaticResource CategoryHeaderStyle}" Text="المصروفات والخزائن" />
            </StackPanel>
            <WrapPanel Margin="0,0,0,30">
                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="ExpPayments"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Background="#F3E8FF" Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="🧾" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="صرف المصروفات" />
                    </StackPanel>
                </Button>
                <Button Width="210" Height="170" Margin="0,0,20,20"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="CashTransfers"
                        Style="{StaticResource CardButtonStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <Border Background="#ECFEFF" Style="{StaticResource IconBorderStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="🔄" />
                        </Border>
                        <TextBlock Style="{StaticResource TitleTextStyle}" Text="تحويلات الخزينة" />
                    </StackPanel>
                </Button>
            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
