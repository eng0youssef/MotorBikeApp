<UserControl x:Class="MotorBike.Views.CashTransfersView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:conv="clr-namespace:MotorBike.Converters" FlowDirection="RightToLeft" Loaded="OnLoaded">
    <UserControl.Resources>
        <conv:IdToNameConverter x:Key="IdToNameConverter" />
    </UserControl.Resources>

    <Grid MinWidth="800" MinHeight="500" Background="#1E2233">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <Grid Grid.Row="0" Margin="24,24,24,16">
            <StackPanel Orientation="Horizontal">
                <Border Margin="0,0,16,0" Padding="14,12" Background="#18414A" CornerRadius="12">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="26" Text="🔄" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="22" FontWeight="Bold" Foreground="White" Text="تحويلات الخزينة" />
                    <TextBlock Margin="0,4,0,0" FontSize="14" Foreground="#9BA4B5" Text="نقل وتبادل الأموال بين الخزائن المختلفة" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <!--  DataGrid Card  -->
        <Border Grid.Row="1" Margin="24,0,24,16" Background="#272C3F" BorderBrush="#3D4560" BorderThickness="1" ClipToBounds="True" CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Direction="270" Opacity="0.08" ShadowDepth="4" Color="#000000" />
            </Border.Effect>
            <DataGrid AlternatingRowBackground="#222738" AutoGenerateColumns="False" Background="#242940" BorderThickness="0" CanUserAddRows="False" ColumnHeaderHeight="48" FontSize="13" Foreground="#C8CEE0"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column" HorizontalGridLinesBrush="#323848" IsReadOnly="True"
                      ItemsSource="{Binding Items}"
                      RowHeight="44"
                      SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                      SelectionMode="Single">
                <DataGrid.ColumnHeaderStyle>
                    <Style BasedOn="{StaticResource DarkColumnHeader}" TargetType="DataGridColumnHeader" />
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style BasedOn="{StaticResource DarkRow}" TargetType="DataGridRow" />
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <Style BasedOn="{StaticResource DarkCell}" TargetType="DataGridCell" />
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Width="100" Binding="{Binding PayId}" Header="رقم التحويل" />
                    <DataGridTextColumn Width="100" Binding="{Binding PayDate, StringFormat=\{0:yyyy/MM/dd\}}" Header="التاريخ" />
                    <DataGridTemplateColumn Width="180" Header="من خزينة">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                    <TextBlock Foreground="#EF4444" Text="📤 " />
                                    <TextBlock>
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource IdToNameConverter}">
                                                <Binding Path="CashId" />
                                                <Binding Path="DataContext.CashList" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Width="180" Header="إلى خزينة">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                    <TextBlock Foreground="#10B981" Text="📥 " />
                                    <TextBlock>
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource IdToNameConverter}">
                                                <Binding Path="CashTo" />
                                                <Binding Path="DataContext.CashList" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Width="120" Binding="{Binding PayMoney, StringFormat=\{0:N2\}}" FontWeight="SemiBold" Header="المبلغ" />
                    <DataGridTextColumn Width="*" Binding="{Binding Notes}" Header="ملاحظات" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!--  Form Card  -->
        <Border Grid.Row="2" Margin="24,0,24,24" Padding="24" Background="#272C3F" BorderBrush="#3D4560" BorderThickness="1" CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Direction="270" Opacity="0.08" ShadowDepth="4" Color="#000000" />
            </Border.Effect>
            <StackPanel>
                <Grid Margin="0,0,0,24" IsEnabled="{Binding IsEditing}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                               Style="{StaticResource FormLabel}"
                               Text="رقم التحويل" />
                    <TextBox Grid.Row="0" Grid.Column="1" Background="#2A3040" Foreground="#ECEEF5" IsReadOnly="True"
                             Style="{StaticResource FormTextBox}"
                             Text="{Binding FormItem.PayId}" />
                    <TextBlock Grid.Row="0" Grid.Column="3" VerticalAlignment="Center"
                               Style="{StaticResource FormLabel}"
                               Text="التاريخ" />
                    <DatePicker Grid.Row="0" Grid.Column="4" Padding="10,4" FontSize="14"
                                SelectedDate="{Binding FormItem.PayDate}" />
                    <TextBlock Grid.Row="0" Grid.Column="6" VerticalAlignment="Center"
                               Style="{StaticResource FormLabel}"
                               Text="المبلغ" />
                    <TextBox Grid.Row="0" Grid.Column="7" Style="{StaticResource FormTextBox}" Text="{Binding PayMoney, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                               Style="{StaticResource FormLabel}"
                               Text="من خزينة" />
                    <StackPanel Grid.Row="2" Grid.Column="1" VerticalAlignment="Center">
                        <ComboBox Padding="10,6" DisplayMemberPath="CashName" FontSize="14"
                                  ItemsSource="{Binding CashList}"
                                  SelectedValue="{Binding SelectedCashId, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="CashId" />
                        <TextBlock Margin="0,4,0,0" FontSize="12" FontWeight="SemiBold" Foreground="#10B981"
                                   Text="{Binding FromCashBalance, StringFormat='رصيد الخزينة: {0:N2}'}" />
                    </StackPanel>
                    <TextBlock Grid.Row="2" Grid.Column="3" VerticalAlignment="Center"
                               Style="{StaticResource FormLabel}"
                               Text="إلى خزينة" />
                    <StackPanel Grid.Row="2" Grid.Column="4" VerticalAlignment="Center">
                        <ComboBox Padding="10,6" DisplayMemberPath="CashName" FontSize="14"
                                  ItemsSource="{Binding CashList}"
                                  SelectedValue="{Binding SelectedCashTo, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="CashId" />
                        <TextBlock Margin="0,4,0,0" FontSize="12" FontWeight="SemiBold" Foreground="#10B981"
                                   Text="{Binding ToCashBalance, StringFormat='رصيد الخزينة: {0:N2}'}" />
                    </StackPanel>

                    <!-- سعر العملة المحول منها -->
                    <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="{Binding FromCurrencyName, StringFormat='سعر ({0})'}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource FormLabel}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDifferentCurrency}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBox Grid.Row="4" Grid.Column="1" Padding="8,6"
                             Text="{Binding FromRate, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBox}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDifferentCurrency}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- سعر العملة المحول إليها -->
                    <TextBlock Grid.Row="4" Grid.Column="3" VerticalAlignment="Center" Text="{Binding ToCurrencyName, StringFormat='سعر ({0})'}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource FormLabel}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDifferentCurrency}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBox Grid.Row="4" Grid.Column="4" Padding="8,6"
                             Text="{Binding ToRate, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBox}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDifferentCurrency}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- المبلغ المحول -->
                    <TextBlock Grid.Row="4" Grid.Column="6" VerticalAlignment="Center" Text="المبلغ المحول">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource FormLabel}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDifferentCurrency}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Grid.Row="4" Grid.Column="7" VerticalAlignment="Center"
                               FontSize="15" FontWeight="Bold" Foreground="#F59E0B"
                               Text="{Binding ToAmount, StringFormat='{}{0:N2}'}"
                               ToolTip="المبلغ بعد التحويل بعملة الخزينة الوجهة">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDifferentCurrency}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center"
                               Style="{StaticResource FormLabel}"
                               Text="ملاحظات" />
                    <TextBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="7"
                             Style="{StaticResource FormTextBox}"
                             Text="{Binding FormItem.Notes, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <DockPanel>
                    <WrapPanel DockPanel.Dock="Left" Orientation="Horizontal">
                        <Button Margin="0,0,8,8" Padding="16,10" Command="{Binding PrintReceiptCommand}" Content="🖨️ طباعة إيصال">
                            <Button.Style>
                                <Style BasedOn="{StaticResource SecondaryButton}" TargetType="Button">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Setter Property="Background" Value="#3B82F6" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedItem}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Margin="0,0,8,8" Command="{Binding AddNewCommand}" Content="➕ تحويل جديد" Style="{StaticResource PrimaryButton}" />
                        <Button Margin="0,0,8,8" Command="{Binding EditSelectedCommand}" Content="✏️ تـعـديل" Style="{StaticResource SecondaryButton}" />
                        <Button Margin="0,0,8,8"
                                Command="{Binding SaveCommand}"
                                Content="💾 حـفـظ"
                                IsEnabled="{Binding IsEditing}"
                                Style="{StaticResource PrimaryButton}" />
                        <Button Margin="0,0,8,8" Command="{Binding DeleteCommand}" Content="🗑️ حـذف" Style="{StaticResource DangerButton}" />
                        <Button Margin="0,0,8,8"
                                Command="{Binding CancelEditCommand}"
                                Content="✖ إلـغـاء"
                                IsEnabled="{Binding IsEditing}"
                                Style="{StaticResource SecondaryButton}" />
                    </WrapPanel>
                    <TextBlock Margin="24,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="#10B981"
                               Text="{Binding StatusMessage}" />
                </DockPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
