<Window x:Class="MotorBike.Views.DbConnectionSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MotorBike.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:DbConnectionSetupViewModel}"
        mc:Ignorable="d"
        Title="إعداد الاتصال بقاعدة البيانات"
        Icon="pack://application:,,,/Assets/logo.png"
        Width="880" Height="680"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        Background="#1A1E2C"
        FontFamily="Segoe UI"
        FontSize="14"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Tab Button Style -->
        <Style x:Key="TabBtn" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6B7490"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E8A54B"/>
                                <Setter Property="Foreground" Value="#E8A54B"/>
                                <Setter TargetName="Bd" Property="Background" Value="#1F2436"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#ECEEF5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="SetupTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#252A3C"/>
            <Setter Property="Foreground" Value="#ECEEF5"/>
            <Setter Property="BorderBrush" Value="#3A4060"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#E8A54B"/>
            <Setter Property="SelectionBrush" Value="#E8A54B"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#E8A54B"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#5A6080"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Field Label -->
        <Style x:Key="FieldLbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9CA3C2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Primary Button -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#E8A54B"/>
            <Setter Property="Foreground" Value="#1A1E2C"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F0B65A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D4923C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#3A4060"/>
                                <Setter Property="Foreground" Value="#6B7490"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button -->
        <Style x:Key="SecBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3C2"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#3A4060"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#252A3C"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#5A6080"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#3A4060"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2A3050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Green/Test Button -->
        <Style x:Key="TestBtn" TargetType="Button" BasedOn="{StaticResource SecBtn}">
            <Setter Property="Foreground" Value="#4ADE80"/>
            <Setter Property="BorderBrush" Value="#2A4038"/>
        </Style>

        <!-- Red/Danger Button -->
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource SecBtn}">
            <Setter Property="Foreground" Value="#F87171"/>
            <Setter Property="BorderBrush" Value="#4A2030"/>
        </Style>

        <!-- Status Box -->
        <Style x:Key="StatusBox" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,14,0,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Tabs -->
            <RowDefinition Height="*"/>
            <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ══ Header ══ -->
        <Border Grid.Row="0" Background="#1E2233" Padding="32,22,32,20"
                BorderBrush="#2A3050" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Icon + Warning -->
                <Border Grid.Column="0" Width="48" Height="48" CornerRadius="12"
                        Background="#3A2010" Margin="0,0,16,0" VerticalAlignment="Center">
                    <TextBlock Text="⚠️" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="تعذّر الاتصال بقاعدة البيانات"
                               FontSize="19" FontWeight="Bold" Foreground="#ECEEF5"/>
                    <TextBlock Text="يرجى مراجعة إعدادات الاتصال أو التحقق من تشغيل SQL Server"
                               FontSize="12" Foreground="#6B7490" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Tabs ══ -->
        <Border Grid.Row="1" Background="#1A1E2C" BorderBrush="#2A3050" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="TabConnection" Content="🔌  إعدادات الاتصال"
                             Style="{StaticResource TabBtn}" IsChecked="True"
                             GroupName="SetupTabs"/>
                <RadioButton x:Name="TabNetwork" Content="🌐  إعداد الشبكة"
                             Style="{StaticResource TabBtn}"
                             GroupName="SetupTabs"/>
            </StackPanel>
        </Border>

        <!-- ══ Content Area ══ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid>

                <!-- ─────────────────── Tab 1: Connection ─────────────────── -->
                <StackPanel Margin="32,28,32,32">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=TabConnection}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- Card -->
                    <Border Background="#1E2233" CornerRadius="14" Padding="28,24"
                            BorderBrush="#2A3050" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect Color="#000" Opacity="0.3" BlurRadius="20" ShadowDepth="4"/>
                        </Border.Effect>
                        <StackPanel>

                            <!-- Card Title -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Width="4" Height="20" CornerRadius="2" Background="#E8A54B" Margin="0,0,12,0"/>
                                <TextBlock Text="نص الاتصال بقاعدة البيانات (Connection String)"
                                           FontSize="14" FontWeight="Bold" Foreground="#ECEEF5"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Connection String TextBox -->
                            <TextBlock Text="نص الاتصال" Style="{StaticResource FieldLbl}"/>
                            <TextBox Text="{Binding ConnectionString, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource SetupTextBox}"
                                     Height="72" TextWrapping="Wrap"
                                     FontFamily="Consolas" FontSize="12"
                                     VerticalScrollBarVisibility="Auto"
                                     AcceptsReturn="False"
                                     Margin="0,0,0,20"/>

                            <!-- Buttons Row -->
                            <StackPanel Orientation="Horizontal">

                                <!-- Save & Proceed -->
                                <Button Command="{Binding SaveCommand}" Margin="0,0,10,0">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
                                            <Setter Property="Content" Value="💾  حفظ والمتابعة"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSaving}" Value="True">
                                                    <Setter Property="Content" Value="⏳  جاري الحفظ..."/>
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- Test -->
                                <Button Command="{Binding TestConnectionCommand}" Margin="0,0,10,0">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TestBtn}">
                                            <Setter Property="Content" Value="🔌  اختبار الاتصال"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTesting}" Value="True">
                                                    <Setter Property="Content" Value="⏳  جاري الاختبار..."/>
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- Reset to Default -->
                                <Button Content="↩️  استعادة الافتراضي"
                                        Style="{StaticResource DangerBtn}"
                                        Command="{Binding ResetToDefaultCommand}"/>

                            </StackPanel>

                            <!-- Status Message -->
                            <Border Visibility="{Binding IsStatusVisible, Converter={StaticResource BoolToVis}}"
                                    Margin="0,14,0,0" Padding="14,10" CornerRadius="8">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStatusSuccess}" Value="True">
                                                <Setter Property="Background" Value="#1A3028"/>
                                                <Setter Property="BorderBrush" Value="#2A5040"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsStatusSuccess}" Value="False">
                                                <Setter Property="Background" Value="#2A1820"/>
                                                <Setter Property="BorderBrush" Value="#5A2030"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"
                                           FontSize="12" LineHeight="20">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsStatusSuccess}" Value="True">
                                                    <Setter Property="Foreground" Value="#4ADE80"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsStatusSuccess}" Value="False">
                                                    <Setter Property="Foreground" Value="#F87171"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                        </StackPanel>
                    </Border>

                    <!-- Help hints -->
                    <Border Background="#1E2233" CornerRadius="14" Padding="24,20"
                            BorderBrush="#2A3050" BorderThickness="1" Margin="0,16,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Width="4" Height="20" CornerRadius="2" Background="#7B9EC8" Margin="0,0,12,0"/>
                                <TextBlock Text="صيغ الاتصال الشائعة"
                                           FontSize="13" FontWeight="Bold" Foreground="#ECEEF5"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- SQL Express -->
                            <TextBlock Text="SQL Server Express (الافتراضي)" Foreground="#6B7490"
                                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <Border Background="#13172A" CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#A0AACC" TextWrapping="Wrap">
                                    Server=.\SQLEXPRESS;Database=MotorBike_DB;Trusted_Connection=True;TrustServerCertificate=True;
                                </TextBlock>
                            </Border>

                            <!-- Remote Server -->
                            <TextBlock Text="سيرفر شبكة محلية (عبر IP)" Foreground="#6B7490"
                                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <Border Background="#13172A" CornerRadius="6" Padding="12,8">
                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#A0AACC" TextWrapping="Wrap">
                                    Server=192.168.1.X\SQLEXPRESS;Database=MotorBike_DB;Trusted_Connection=True;TrustServerCertificate=True;
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ─────────────────── Tab 2: Network ─────────────────── -->
                <StackPanel Margin="32,28,32,32">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=TabNetwork}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- IP Info Row -->
                    <Border Background="#1E2233" CornerRadius="12" Padding="20,16"
                            BorderBrush="#2A3050" BorderThickness="1" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🖥️" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="عنوان IP لهذا الجهاز" Foreground="#6B7490" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding LocalIpAddress}" Foreground="#E8A54B"
                                           FontSize="16" FontWeight="Bold" FontFamily="Consolas" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Card 1: This machine as Server -->
                    <Border Background="#1E2233" CornerRadius="14" Padding="28,24"
                            BorderBrush="#2A3050" BorderThickness="1" Margin="0,0,0,16">
                        <Border.Effect>
                            <DropShadowEffect Color="#000" Opacity="0.25" BlurRadius="16" ShadowDepth="3"/>
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="4" Height="20" CornerRadius="2" Background="#4ADE80" Margin="0,0,12,0"/>
                                <TextBlock Text="هذا الجهاز هو السيرفر"
                                           FontSize="14" FontWeight="Bold" Foreground="#ECEEF5"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock TextWrapping="Wrap" Foreground="#6B7490" FontSize="12" LineHeight="20"
                                       Margin="0,0,0,16">
                                يتصل هذا الجهاز مباشرة بنسخة SQL Server المحلية. يمكن للأجهزة الأخرى على نفس الشبكة الاتصال بعنوان IP أعلاه.
                            </TextBlock>

                            <!-- Create Server User Option -->
                            <CheckBox Content="إنشاء حساب مستخدم جديد للأجهزة الفرعية (مستحسن)"
                                      IsChecked="{Binding CreateServerUser}"
                                      Foreground="#9CA3C2" FontSize="13" Margin="0,0,0,12"/>

                            <Grid Margin="0,0,0,16" Visibility="{Binding CreateServerUser, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="اسم المستخدم (User Name)" Style="{StaticResource FieldLbl}"/>
                                    <TextBox Text="{Binding NewServerUserName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SetupTextBox}" Height="40" Margin="0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="كلمة المرور (Password)" Style="{StaticResource FieldLbl}"/>
                                    <TextBox Text="{Binding NewServerPassword, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SetupTextBox}" Height="40" Margin="0"/>
                                </StackPanel>
                            </Grid>

                            <Button HorizontalAlignment="Right"
                                    Command="{Binding UseThisAsServerCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
                                        <Setter Property="Content" Value="✅  استخدام هذا الجهاز كسيرفر (SQL Local)"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTesting}" Value="True">
                                                <Setter Property="Content" Value="⏳  جاري الإعداد..."/>
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Card 2: Connect to another server -->
                    <Border Background="#1E2233" CornerRadius="14" Padding="28,24"
                            BorderBrush="#2A3050" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect Color="#000" Opacity="0.25" BlurRadius="16" ShadowDepth="3"/>
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="4" Height="20" CornerRadius="2" Background="#7B9EC8" Margin="0,0,12,0"/>
                                <TextBlock Text="الاتصال بسيرفر آخر على الشبكة"
                                           FontSize="14" FontWeight="Bold" Foreground="#ECEEF5"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock TextWrapping="Wrap" Foreground="#6B7490" FontSize="12" LineHeight="20"
                                       Margin="0,0,0,16">
                                أدخل عنوان IP الجهاز الذي يعمل عليه SQL Server واضغط "اختبار" لمحاولة الاتصال وتحميل الإعدادات تلقائياً.
                            </TextBlock>

                            <!-- IP + Instance + Port row -->
                            <TextBlock Text="عنوان IP السيرفر" Style="{StaticResource FieldLbl}"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding ServerIpAddress, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource SetupTextBox}"
                                         Height="42" FontFamily="Consolas"
                                         Margin="0,0,10,0"
                                         VerticalContentAlignment="Center"
                                         xml:lang="en-US"
                                         FlowDirection="LeftToRight"
                                         HorizontalContentAlignment="Left"/>
                                <Button Grid.Column="1" Command="{Binding TestServerConnectionCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TestBtn}">
                                            <Setter Property="Content" Value="🔌  اختبار الاتصال بالسيرفر"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTesting}" Value="True">
                                                    <Setter Property="Content" Value="⏳  ..."/>
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>

                            <!-- Instance Name + Port (advanced) -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="اسم الـ Instance (SQL Instance Name)" Style="{StaticResource FieldLbl}"/>
                                    <TextBox Text="{Binding InstanceName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SetupTextBox}" Height="40"
                                             FontFamily="Consolas" FlowDirection="LeftToRight"
                                             HorizontalContentAlignment="Left"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="الـ Port (اختياري)" Style="{StaticResource FieldLbl}"/>
                                    <TextBox Text="{Binding SqlPort, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SetupTextBox}" Height="40"
                                             FontFamily="Consolas" FlowDirection="LeftToRight"
                                             HorizontalContentAlignment="Left"
                                             ToolTip="اترك فارغاً إذا كنت تستخدم Instance Name"/>
                                </StackPanel>
                            </Grid>

                            <!-- Auth Options -->
                            <CheckBox Content="استخدام مصادقة SQL Server (اسم مستخدم وكلمة مرور)"
                                      IsChecked="{Binding UseSqlServerAuth}"
                                      Foreground="#9CA3C2" FontSize="13" Margin="0,0,0,12"/>
                            
                            <Grid Margin="0,0,0,16" Visibility="{Binding UseSqlServerAuth, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="اسم المستخدم (User ID)" Style="{StaticResource FieldLbl}"/>
                                    <TextBox Text="{Binding SqlServerUserName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SetupTextBox}" Height="40" Margin="0"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="كلمة المرور (Password)" Style="{StaticResource FieldLbl}"/>
                                    <TextBox Text="{Binding SqlServerPassword, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SetupTextBox}" Height="40" Margin="0"/>
                                </StackPanel>
                            </Grid>

                            <!-- Save Remote Button (ظاهر بعد نجاح الاختبار) -->
                            <Button Command="{Binding SaveRemoteConnectionCommand}"
                                    Margin="0,0,0,4" HorizontalAlignment="Right"
                                    Visibility="{Binding CanSaveRemote, Converter={StaticResource BoolToVis}}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
                                        <Setter Property="Content" Value="💾  حفظ الاتصال بالسيرفر"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSaving}" Value="True">
                                                <Setter Property="Content" Value="⏳  جاري الحفظ..."/>
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- Network Status -->
                            <Border Visibility="{Binding IsNetworkStatusVisible, Converter={StaticResource BoolToVis}}"
                                    Margin="0,14,0,0" Padding="14,10" CornerRadius="8">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsNetworkSuccess}" Value="True">
                                                <Setter Property="Background" Value="#1A3028"/>
                                                <Setter Property="BorderBrush" Value="#2A5040"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsNetworkSuccess}" Value="False">
                                                <Setter Property="Background" Value="#2A1820"/>
                                                <Setter Property="BorderBrush" Value="#5A2030"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding NetworkStatus}" TextWrapping="Wrap"
                                           FontSize="12" LineHeight="20">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsNetworkSuccess}" Value="True">
                                                    <Setter Property="Foreground" Value="#4ADE80"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsNetworkSuccess}" Value="False">
                                                    <Setter Property="Foreground" Value="#F87171"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                        </StackPanel>
                    </Border>
                </StackPanel>

            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
