<Window x:Class="MotorBike.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MotorBike.ViewModels"
        xmlns:views="clr-namespace:MotorBike.Views"
        mc:Ignorable="d"
        Title="نظام إدارة وكالة الموتوسيكلات" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        FlowDirection="RightToLeft" FontFamily="Segoe UI" FontSize="14">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:CompanyViewModel}"><views:CompanyView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:UsersViewModel}"><views:UsersView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:UnitsViewModel}"><views:UnitsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ItemCategoriesViewModel}"><views:ItemCategoriesView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StoresViewModel}"><views:StoresView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CarBrandsViewModel}"><views:CarBrandsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CarModelsViewModel}"><views:CarModelsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ColorsViewModel}"><views:ColorsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CashViewModel}"><views:CashView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:OmlaViewModel}"><views:OmlaView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ExpGroupsViewModel}"><views:ExpGroupsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CitiesViewModel}"><views:CitiesView/></DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- القائمة الجانبية -->
        <Border Grid.Column="0" Background="#1E293B">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="16" Background="#0F172A">
                    <StackPanel>
                        <TextBlock Text="🏍️" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="موتوربايك" FontSize="18" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="نظام إدارة الوكالة" FontSize="11"
                                   Foreground="#94A3B8" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="بيانات عامة" Foreground="#64748B" FontSize="11" FontWeight="SemiBold" Margin="16,12,0,4"/>
                        <Button Content="🏢  بيانات الشركة" Command="{Binding NavigateToCommand}" CommandParameter="Company" Style="{StaticResource MenuButtonStyle}"/>
                        <Button Content="👤  المستخدمين" Command="{Binding NavigateToCommand}" CommandParameter="Users" Style="{StaticResource MenuButtonStyle}"/>
                        <Button Content="🌆  المدن" Command="{Binding NavigateToCommand}" CommandParameter="Cities" Style="{StaticResource MenuButtonStyle}"/>

                        <TextBlock Text="المخازن والأصناف" Foreground="#64748B" FontSize="11" FontWeight="SemiBold" Margin="16,16,0,4"/>
                        <Button Content="📏  وحدات الأصناف" Command="{Binding NavigateToCommand}" CommandParameter="Units" Style="{StaticResource MenuButtonStyle}"/>
                        <Button Content="📂  مجموعات الأصناف" Command="{Binding NavigateToCommand}" CommandParameter="ItemCategories" Style="{StaticResource MenuButtonStyle}"/>
                        <Button Content="🏪  المخازن" Command="{Binding NavigateToCommand}" CommandParameter="Stores" Style="{StaticResource MenuButtonStyle}"/>

                        <TextBlock Text="بيانات المركبات" Foreground="#64748B" FontSize="11" FontWeight="SemiBold" Margin="16,16,0,4"/>
                        <Button Content="🏭  ماركات الموتوسيكلات" Command="{Binding NavigateToCommand}" CommandParameter="CarBrands" Style="{StaticResource MenuButtonStyle}"/>
                        <Button Content="🏍️  موديلات الماركة" Command="{Binding NavigateToCommand}" CommandParameter="CarModels" Style="{StaticResource MenuButtonStyle}"/>
                        <Button Content="🎨  الألوان" Command="{Binding NavigateToCommand}" CommandParameter="Colors" Style="{StaticResource MenuButtonStyle}"/>

                        <TextBlock Text="البيانات المالية" Foreground="#64748B" FontSize="11" FontWeight="SemiBold" Margin="16,16,0,4"/>
                        <Button Content="💰  الخزائن" Command="{Binding NavigateToCommand}" CommandParameter="Cash" Style="{StaticResource MenuButtonStyle}"/>
                        <Button Content="💱  العملات" Command="{Binding NavigateToCommand}" CommandParameter="Omla" Style="{StaticResource MenuButtonStyle}"/>
                        <Button Content="📋  مجموعات المصروفات" Command="{Binding NavigateToCommand}" CommandParameter="ExpGroups" Style="{StaticResource MenuButtonStyle}"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- المحتوى الرئيسي -->
        <DockPanel Grid.Column="1" Background="#F1F5F9">
            <Border DockPanel.Dock="Top" Background="White" Padding="20,12"
                    BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <TextBlock Text="{Binding CurrentPageTitle}" FontSize="20" FontWeight="SemiBold" Foreground="#1E293B"/>
            </Border>
            <ContentControl Content="{Binding CurrentViewModel}" Margin="16"/>
        </DockPanel>
    </Grid>
</Window>
