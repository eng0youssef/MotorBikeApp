<Window x:Class="MotorBike.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MotorBike.ViewModels"
        xmlns:views="clr-namespace:MotorBike.Views"
        mc:Ignorable="d"
        Title="نظام إدارة وكالة الموتوسيكلات" MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        FlowDirection="RightToLeft" FontFamily="Segoe UI" FontSize="14">
    
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.0" To="1.0" Duration="0:0:0.6" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:CompanyViewModel}"><views:CompanyView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:UsersViewModel}"><views:UsersView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:UnitsViewModel}"><views:UnitsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ItemCategoriesViewModel}"><views:ItemCategoriesView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ItemsViewModel}"><views:ItemsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StoresViewModel}"><views:StoresView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CarBrandsViewModel}"><views:CarBrandsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CarModelsViewModel}"><views:CarModelsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ColorsViewModel}"><views:ColorsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CashViewModel}"><views:CashView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:OmlaViewModel}"><views:OmlaView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ExpGroupsViewModel}"><views:ExpGroupsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ExpensesViewModel}"><views:ExpensesView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CitiesViewModel}"><views:CitiesView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:InspectionsViewModel}"><views:InspectionsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CustomersViewModel}"><views:CustomersView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SuppliersViewModel}"><views:SuppliersView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:BasicDataViewModel}"><views:BasicDataView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:BuysViewModel}"><views:BuysView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CarsViewModel}"><views:CarsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SalesViewModel}"><views:SalesView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:BuyCarViewModel}"><views:BuyCarView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SalesCarViewModel}"><views:SalesCarView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReBuyViewModel}"><views:ReBuyView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReSalesViewModel}"><views:ReSalesView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ImportDataViewModel}"><views:ImportDataView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ImportSuppliersViewModel}"><views:ImportSuppliersView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ImportExpensesViewModel}"><views:ImportExpensesView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ImportInvoiceViewModel}"><views:ImportInvoiceView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ImportPaymentsViewModel}"><views:ImportPaymentsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CusPaymentsViewModel}"><views:CusPaymentsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SuppPaymentsViewModel}"><views:SuppPaymentsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ExpPaymentsViewModel}"><views:ExpPaymentsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CashTransfersViewModel}"><views:CashTransfersView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:PaymentsDataViewModel}"><views:PaymentsDataView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:OpenStockViewModel}"><views:OpenStockView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsDataViewModel}"><views:ReportsDataView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StoreReportsViewModel}"><views:StoreReportsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SalesReportsViewModel}"><views:SalesReportsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:PurchasesReportsViewModel}"><views:PurchasesReportsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProfitsReportsViewModel}"><views:ProfitsReportsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CarsReportsViewModel}"><views:CarsReportsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ImportReportsViewModel}"><views:ImportReportsView/></DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="Grid.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,20,0,-20" To="0" Duration="0:0:0.6">
                            <ThicknessAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </ThicknessAnimation.EasingFunction>
                        </ThicknessAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ Sidebar ══ -->
        <Border Grid.Column="0" Background="#1A1E2C">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.2" BlurRadius="16" Direction="0" ShadowDepth="4"/>
            </Border.Effect>
            <DockPanel>
                <!-- Logo / Brand -->
                <Border DockPanel.Dock="Top" Padding="20,22,20,18" Background="#171B28">
                    <StackPanel>
                        <Border HorizontalAlignment="Center" Width="52" Height="52" CornerRadius="12" Margin="0,0,0,10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#E8A54B" Offset="0"/>
                                    <GradientStop Color="#D4922F" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="🏍️" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="موتوربايك" FontSize="19" FontWeight="Bold"
                                   Foreground="#ECEEF5" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Accent divider -->
                <Border DockPanel.Dock="Top" Height="1" Margin="20,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#E8A54B" Offset="0.5"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,14,0,16">
                        <TextBlock Text="الأساسيات" Foreground="#6B7490" FontSize="12" FontWeight="Bold" Margin="24,10,0,6"/>
                        <Button Content="📂  البيانات الأساسية" Command="{Binding NavigateToCommand}" CommandParameter="BasicData" Style="{StaticResource MenuButtonStyle}"/>
                        <Button Content="🏍️  الموتوسيكلات" Command="{Binding NavigateToCommand}" CommandParameter="Cars" Style="{StaticResource MenuButtonStyle}"/>
                        <Button Content="🔍  الكشف الفني" Command="{Binding NavigateToCommand}" CommandParameter="Inspections" Style="{StaticResource MenuButtonStyle}"/>

                        <TextBlock Text="المدفوعات والتحويلات" Foreground="#6B7490" FontSize="12" FontWeight="Bold" Margin="24,18,0,6"/>
                        <Button Content="💳   المدفوعات والتحويلات" Command="{Binding NavigateToCommand}" CommandParameter="PaymentsData" Style="{StaticResource MenuButtonStyle}"/>

                        <TextBlock Text="الفواتير" Foreground="#6B7490" FontSize="10" FontWeight="Bold" Margin="24,18,0,6"/>
                        <Button Content="📄  فاتورة الشراء" Command="{Binding NavigateToCommand}" CommandParameter="Buys" Style="{StaticResource MenuButtonStyle}"/>
                        <Button Content="📃  فاتورة المبيعات" Command="{Binding NavigateToCommand}" CommandParameter="Sales" Style="{StaticResource MenuButtonStyle}"/>
                        <Button Content="🏍️  شراء موتوسيكل" Command="{Binding NavigateToCommand}" CommandParameter="BuyCar" Style="{StaticResource MenuButtonStyle}"/>
                        <Button Content="🏍️  بيع موتوسيكل" Command="{Binding NavigateToCommand}" CommandParameter="SalesCar" Style="{StaticResource MenuButtonStyle}"/>

                        <TextBlock Text="المرتجعات" Foreground="#6B7490" FontSize="12" FontWeight="Bold" Margin="24,18,0,6"/>
                        <Button Content="↩️  مرتجع المشتريات" Command="{Binding NavigateToCommand}" CommandParameter="ReBuy" Style="{StaticResource MenuButtonStyle}"/>
                        <Button Content="↩️  مرتجع المبيعات" Command="{Binding NavigateToCommand}" CommandParameter="ReSales" Style="{StaticResource MenuButtonStyle}"/>

                        <TextBlock Text="الاستيراد" Foreground="#6B7490" FontSize="12" FontWeight="Bold" Margin="24,18,0,6"/>
                        <Button Content="🌍  إدارة الاستيراد" Command="{Binding NavigateToCommand}" CommandParameter="ImportData" Style="{StaticResource MenuButtonStyle}"/>

                        <!--<TextBlock Text="التقارير" Foreground="#6B7490" FontSize="10" FontWeight="Bold" Margin="24,18,0,6"/>
                        <Button Content="📊  التقارير" Command="{Binding NavigateToCommand}" CommandParameter="ReportsData" Style="{StaticResource MenuButtonStyle}"/>-->
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ══ Main Content Area ══ -->
        <Border Grid.Column="1" Background="#1E2233" ClipToBounds="True">
            <DockPanel>
                <!-- Top Bar -->
                <Border DockPanel.Dock="Top" Padding="28,16" Background="#222738"
                        BorderBrush="#323848" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock Text="{Binding CurrentPageTitle}" FontSize="20" FontWeight="Bold" Foreground="#ECEEF5" VerticalAlignment="Center"/>
                        <!-- Subtle accent line -->
                        <Border Height="2" VerticalAlignment="Bottom" Margin="-28,-16,-28,-16" HorizontalAlignment="Stretch">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#E8A54B" Offset="0"/>
                                    <GradientStop Color="#E8A54B" Offset="0.15"/>
                                    <GradientStop Color="Transparent" Offset="0.4"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>
                </Border>
                <ContentControl Content="{Binding CurrentViewModel}" Margin="0"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
